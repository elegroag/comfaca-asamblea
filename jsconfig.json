{
    "compilerOptions": {
        "baseUrl": "./resources/js",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "allowUmdGlobalAccess": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "noImplicitOverride": true,
        "strictPropertyInitialization": false,
        "strictFunctionTypes": false,
        "noImplicitThis": false,
        "module": "UMD",
        "target": "ES2020",
        "checkJs": true,
        "diagnostics": true,
        "moduleResolution": "node",
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "allowJs": true,
        "alwaysStrict": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "moduleDetection": "force",
        "allowImportingTsExtensions": true,
        "paths": {
            "@/*": [
                "./resources/js/*"
            ],
            "ziggy-js": [
                "./vendor/tightenco/ziggy"
            ]
        }
    },
    "include": [
        "resources/js/**/*.js",
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts"
    ],
    "typeAcquisition": {
        "enable": true,
        "include": [
            "jquery",
            "backbone",
            "underscore",
            "select2",
            "sweetalert2",
            "noty",
            "bootstrap",
            "Chart"
        ]
    }
}