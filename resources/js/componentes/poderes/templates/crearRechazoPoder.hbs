<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
    <div class="mb-4 md:mb-0">
        <h4 class="text-2xl font-bold text-blue-600">Registrar Rechazo</h4>
    </div>
    <div id='showSubnav'></div>
</div>

<div class="w-full max-w-7xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex flex-wrap justify-center gap-6">
            <!-- Poderdante Form -->
            <div class="w-full md:w-5/12">
                <div class="space-y-4">
                    <div>
                        <label for="poderdante_nit" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-red-500">*</span> Poderdante nit
                        </label>
                        <div toggle-error='poderdante_nit' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id='poderdante_nit' name="poderdante_nit" placeholder='poderdante nit' />
                            <button type='button' id='bt_buscar_poderdante'
                                class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label for="poderdante_cedula" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Representante identificación
                        </label>
                        <div toggle-error='poderdante_cedula' class="error text-red-500 text-sm mb-1" for="required">
                        </div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id='poderdante_cedula' name="poderdante_cedula" placeholder='identificacion' />
                        </div>
                    </div>

                    <div>
                        <label for="razsoc_poderdante" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Razón social
                        </label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm leading-relaxed"
                                name="razsoc_poderdante" id="razsoc_poderdante" placeholder='razón social' />
                        </div>
                    </div>

                    <div>
                        <label for="repleg_poderdante" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Representante legal
                        </label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-user"></i>
                            </span>
                            <input
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm leading-relaxed"
                                name="repleg_poderdante" id="repleg_poderdante" placeholder='representante legal' />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Apoderado Form -->
            <div class="w-full md:w-5/12">
                <div class="space-y-4">
                    <div>
                        <label for="apoderado_nit" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-red-500">*</span> Apoderado nit
                        </label>
                        <div toggle-error='apoderado_nit' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id='apoderado_nit' name="apoderado_nit" placeholder='apoderado nit' />
                            <button type='button' id='bt_buscar_apoderado'
                                class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label for="apoderado_cedula" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Representante identificación
                        </label>
                        <div toggle-error='apoderado_cedula' class="error text-red-500 text-sm mb-1" for="required">
                        </div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id="apoderado_cedula" name="apoderado_cedula" placeholder='identificacion' />
                        </div>
                    </div>

                    <div>
                        <label for="razsoc_apoderado" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Razón social
                        </label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm leading-relaxed"
                                name="razsoc_apoderado" id="razsoc_apoderado" placeholder='razón social' />
                        </div>
                    </div>

                    <div>
                        <label for="repleg_apoderado" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Representante legal
                        </label>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-user"></i>
                            </span>
                            <input
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm leading-relaxed"
                                name="repleg_apoderado" id="repleg_apoderado" placeholder='representante legal' />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Fecha y Radicado -->
            <div class="w-full md:w-1/3">
                <div class="space-y-4">
                    <div>
                        <label for="fecha" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-blue-500">*</span> Fecha
                        </label>
                        <div toggle-error='fecha' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-calendar"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id='fecha' name="fecha" placeholder='fecha' readonly style='background:#fff' />
                        </div>
                    </div>

                    <div>
                        <label for="radicado" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-red-500">*</span> Radicado
                        </label>
                        <div toggle-error='radicado' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-hashtag"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id="radicado" name="radicado" placeholder='radicado' />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Criterio de Rechazo -->
            <div class="w-full">
                <div>
                    <label for="criterio_rechazo" class="block text-sm font-medium text-gray-700 mb-1">
                        <span class="text-red-500">*</span> Criterio Rechazo:
                    </label>
                    <div toggle-error='criterio_rechazo' class="error text-red-500 text-sm mb-1" for="required"></div>
                    <div class="flex gap-2">
                        <select
                            class='flex-1 min-w-0 block w-full px-3 py-2 border border-gray-300 bg-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500'
                            id='criterio_rechazo' name='criterio_rechazo'>
                            <option value=''>Selecciona aquí..</option>
                            <% _.each(criterios_rechazos, function(criterio){ %>
                                <option value='<%=criterio.id%>'>
                                    <%=criterio.estatutos +' '+ criterio.detalle%></option>
                            <% })%>
                        </select>
                        <button type=' button'
                                        class='inline-flex items-center px-4 py-2 bg-blue-100 text-blue-700 font-medium text-sm rounded-lg hover:bg-blue-200 transition-colors'
                                        id='copyMemory'>
                                        <i class="fas fa-copy mr-2"></i> Copy
                                        </button>
                    </div>
                </div>
            </div>

            <!-- Nota/Motivo -->
            <div class="w-full">
                <div>
                    <label for="motivo" class="block text-sm font-medium text-gray-700 mb-1">
                        <span class="text-red-500">*</span> Nota:
                    </label>
                    <div toggle-error='motivo' class="error text-red-500 text-sm mb-1" for="required"></div>
                    <textarea rows="4"
                        class="w-full px-3 py-2 border border-gray-300 bg-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
                        id='motivo' name="motivo" placeholder='motivo rechazo aquí.'></textarea>
                </div>
            </div>

            <!-- Botón Continuar -->
            <div class="w-full">
                <div class="text-center">
                    <button type='button'
                        class='inline-flex items-center px-6 py-2.5 border border-green-600 text-green-600 font-medium text-sm leading-tight uppercase rounded-lg hover:bg-green-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-green-300 transition-colors'
                        id='btnRegistraRechazo'>
                        <i class="fas fa-check mr-2"></i> Continuar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>