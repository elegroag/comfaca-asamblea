<div class="mb-6">
    <h4 class="text-2xl font-bold text-blue-600">Cargue Masivo</h4>
</div>

<div class="w-full max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="space-y-6">
            <div class="w-full">
                <div class="space-y-4">
                    <div>
                        <label for="archivo_masivo" class="block text-sm font-medium text-gray-700 mb-1">
                            <span class="text-red-500">*</span> Archivo
                        </label>
                        <div toggle-error='archivo' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-file-upload"></i>
                            </span>
                            <input style='display:none' type='file' data-event='upload' name='archivo_masivo'
                                id='archivo_masivo' onchange='handleFiles()' />
                            <div class="flex-1 min-w-0 block w-full px-3 py-2 border border-gray-300 bg-white text-sm leading-relaxed cursor-pointer hover:bg-gray-50 transition-colors"
                                data-toggle-file='searchfile' id='name_archivo' name="name_archivo">nombre archivo</div>
                            <button type='button' data-toggle-file='searchfile'
                                class="inline-flex items-center px-3 py-2 border border-l-0 border-gray-300 bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                                <i class="fas fa-search"></i>
                            </button>
                            <button type='button' disabled id='remover_archivo'
                                class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-sm text-blue-800">
                            <strong>Requiere de un archivo csv separado por (;) con:</strong><br />
                            Columna 1 Codigo<br />
                            Columna 2 Fecha<br />
                            Columna 3 Nit Apoderado<br />
                            Columna 4 Nit Poderdante<br />
                            Columna 5 Estado, solo admite (A) Activo (I) Inactivo (R) Revocado<br />
                            Columna 6 Radicado<br />
                            Columna 7 Cedula Apoderado<br />
                            Columna 8 Nombre Apoderado<br />
                            Columna 9 Cedula Poderdante<br />
                            Columna 10 Nombre Poderdante<br />
                            Columna 11 Motivos Rechazo
                        </p>
                    </div>
                </div>
            </div>

            <div class="w-full">
                <div class="text-center">
                    <button type='button' disabled
                        class="inline-flex items-center px-6 py-2.5 border border-green-600 text-green-600 font-medium text-sm leading-tight uppercase rounded-lg hover:bg-green-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-green-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-transparent disabled:hover:text-green-600"
                        id='bt_hacer_cargue'>
                        <i class="fas fa-upload mr-2"></i> Continuar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>