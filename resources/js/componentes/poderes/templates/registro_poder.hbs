<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-success text-white">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h5 class="mb-0">
                        <i class="fa fa-file-contract mr-2"></i>Crear Nuevo Poder
                    </h5>
                </div>
                <div class="col-md-4 text-right">
                    <div id='showSubnav'></div>
                </div>
            </div>
        </div>

        <div class="card-body">
            <!-- Información del Formulario -->
            <div class="alert alert-success">
                <h6 class="alert-heading">
                    <i class="fa fa-info-circle mr-2"></i>Registro de Poder
                </h6>
                <p class="mb-0">
                    Complete los datos del poderdante y apoderado para registrar un nuevo poder.<br>
                    Los campos marcados con <span class="text-danger">*</span> son obligatorios.
                </p>
            </div>

            <form id="form_registro_poder" class="needs-validation" novalidate>
                <div class="row justify-content-center">
                    <!-- Avatar Central -->
                    <div class="col-lg-2 col-md-3">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <img src="/img/default-avatar.png" alt="Avatar"
                                    class="rounded-circle img-fluid border border-success"
                                    style="width: 100px; height: 100px; object-fit: cover;" />
                            </div>
                            <h6 class="text-success font-weight-bold">Poderdante - Apoderado</h6>
                            <small class="text-muted">
                                <i class="fa fa-handshake mr-1"></i>Nueva Relación
                            </small>
                        </div>
                    </div>

                    <!-- Formulario de Poderdante -->
                    <div class="col-lg-4 col-md-4">
                        <div class="card border-primary">
                            <div class="card-header bg-light">
                                <h6 class="mb-0 text-primary">
                                    <i class="fa fa-building mr-2"></i>Datos del Poderdante
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label for="poderdante_nit" class="font-weight-bold text-muted">
                                        <i class="fa fa-id-card mr-1"></i>NIT <span class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='poderdante_nit' class="error text-danger small" for="required">
                                    </div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-primary text-white">
                                                <i class="fa fa-building"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" id='poderdante_nit'
                                            name="poderdante_nit" placeholder='Ingrese NIT del poderdante' required />
                                        <div class="input-group-append">
                                            <button type='button' id='bt_buscar_poderdante' class="btn btn-primary"
                                                title="Buscar Poderdante">
                                                <i class="fa fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="poderdante_cedula" class="font-weight-bold text-muted">
                                        <i class="fa fa-user mr-1"></i>Identificación del Representante <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='poderdante_cedula' class="error text-danger small"
                                        for="required"></div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-primary text-white">
                                                <i class="fa fa-user-tie"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="poderdante_cedula"
                                            id='poderdante_cedula' placeholder='Identificación del representante'
                                            required />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="razsoc_poderdante" class="font-weight-bold text-muted">
                                        <i class="fa fa-industry mr-1"></i>Razón Social <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-primary text-white">
                                                <i class="fa fa-building"></i>
                                            </span>
                                        </div>
                                        <div class="form-control bg-light" style='line-height:2'
                                            name='razsoc_poderdante' id="razsoc_poderdante">
                                            Razón social del poderdante
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="repleg_poderdante" class="font-weight-bold text-muted">
                                        <i class="fa fa-user-tie mr-1"></i>Representante Legal <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-primary text-white">
                                                <i class="fa fa-user"></i>
                                            </span>
                                        </div>
                                        <div class="form-control bg-light" style='line-height:2'
                                            name="repleg_poderdante" id="repleg_poderdante">
                                            Nombre del representante legal
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Formulario de Apoderado -->
                    <div class="col-lg-4 col-md-4">
                        <div class="card border-success">
                            <div class="card-header bg-light">
                                <h6 class="mb-0 text-success">
                                    <i class="fa fa-user-shield mr-2"></i>Datos del Apoderado
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label for="apoderado_nit" class="font-weight-bold text-muted">
                                        <i class="fa fa-id-card mr-1"></i>NIT <span class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='apoderado_nit' class="error text-danger small" for="required">
                                    </div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-success text-white">
                                                <i class="fa fa-building"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" id='apoderado_nit' name="apoderado_nit"
                                            placeholder='Ingrese NIT del apoderado' required />
                                        <div class="input-group-append">
                                            <button type='button' id='bt_buscar_apoderado' class="btn btn-success"
                                                title="Buscar Apoderado">
                                                <i class="fa fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="apoderado_cedula" class="font-weight-bold text-muted">
                                        <i class="fa fa-user mr-1"></i>Identificación del Representante <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='apoderado_cedula' class="error text-danger small" for="required">
                                    </div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-success text-white">
                                                <i class="fa fa-user-tie"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="apoderado_cedula"
                                            placeholder='Identificación del representante' required />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="razsoc_apoderado" class="font-weight-bold text-muted">
                                        <i class="fa fa-industry mr-1"></i>Razón Social <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-success text-white">
                                                <i class="fa fa-building"></i>
                                            </span>
                                        </div>
                                        <div class="form-control bg-light" style='line-height:2' name='razsoc_apoderado'
                                            id="razsoc_apoderado">
                                            Razón social del apoderado
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="repleg_apoderado" class="font-weight-bold text-muted">
                                        <i class="fa fa-user-tie mr-1"></i>Representante Legal <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-success text-white">
                                                <i class="fa fa-user"></i>
                                            </span>
                                        </div>
                                        <div class="form-control bg-light" style='line-height:2' name='repleg_apoderado'
                                            id="repleg_apoderado">
                                            Nombre del representante legal
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información Adicional -->
                    <div class="col-lg-3 col-md-5">
                        <div class="card border-info">
                            <div class="card-header bg-light">
                                <h6 class="mb-0 text-info">
                                    <i class="fa fa-info-circle mr-2"></i>Información del Poder
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label for="fecha" class="font-weight-bold text-muted">
                                        <i class="fa fa-calendar mr-1"></i>Fecha <span class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='fecha' class="error text-danger small" for="required"></div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-info text-white">
                                                <i class="fa fa-calendar-alt"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control bg-light" name="fecha"
                                            placeholder='Fecha del poder' readonly style='background:#fff' required />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="radicado" class="font-weight-bold text-muted">
                                        <i class="fa fa-hashtag mr-1"></i>Número de Radicado <span
                                            class="text-danger">*</span>
                                    </label>
                                    <div toggle-error='radicado' class="error text-danger small" for="required"></div>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-info text-white">
                                                <i class="fa fa-file-alt"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="radicado"
                                            placeholder='Número de radicado' required />
                                    </div>
                                </div>

                                <!-- Opciones Adicionales -->
                                <div class="form-group mt-4">
                                    <div class="custom-control custom-checkbox">
                                        <input type="checkbox" class="custom-control-input" id="notificar_poder"
                                            checked>
                                        <label class="custom-control-label font-weight-bold" for="notificar_poder">
                                            <i class="fa fa-bell mr-1"></i>Notificar Registro
                                        </label>
                                        <small class="form-text text-muted">
                                            Envía notificación del nuevo poder
                                        </small>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <div class="custom-control custom-checkbox">
                                        <input type="checkbox" class="custom-control-input" id="validar_habil">
                                        <label class="custom-control-label font-weight-bold" for="validar_habil">
                                            <i class="fa fa-check-circle mr-1"></i>Validar Habil
                                        </label>
                                        <small class="form-text text-muted">
                                            Verifica estado de habilitación
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de Acción -->
                <div class="row justify-content-center mt-4">
                    <div class="col-lg-8 col-md-12">
                        <div class="d-flex justify-content-center">
                            <button type='button' class='btn btn-success btn-lg px-5 py-2 mr-3' id='btn_validar_poder'>
                                <i class="fa fa-check-circle mr-2"></i>Validar y Registrar
                            </button>
                            <button type='button' class='btn btn-warning btn-lg px-5 py-2 mr-3' id='btn_previsualizar'>
                                <i class="fa fa-eye mr-2"></i>Previsualizar
                            </button>
                            <button type='button' class='btn btn-secondary btn-lg px-5 py-2' id='btn_cancelar'>
                                <i class="fa fa-times mr-2"></i>Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>