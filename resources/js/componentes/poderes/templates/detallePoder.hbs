<div class="row">
    <div class="col-md-4">
        <span class="h4 mb-4 text-primary"> Detalles del poder</span>
    </div>
    <div class="col">
        <div id='showSubnav' class="nav justify-content-end">
            <a href='#' class="btn btn-md btn-outline-primary btn-round" id='btn_back_list'><i
                    class="fas fa-arrow-left"></i> Salir</a>
        </div>
    </div>
</div>

<div class="ml-auto mr-auto">
    <div class="card-body">
        <p class='text-center'>Los siguientes datos son informativos y no se pueden modificar. <br />Puede activar o
            inactivar el poder si lo requiere.</p>
        <div class="row justify-content-center">
            <div class="col-sm-2">
                <div class="picture-container">
                    <div class="picture text-center">
                        <img src="/images/poderes.jpg" alt="Poder" width="100px" class="picture-src" />
                    </div>
                    <h6 class="description text-center"><br />PODER</h6>
                    <p class='text-center'>Fecha registro: <br />
                        <%=poder.fecha%>
                    </p>
                </div>
            </div>

            <div class='col-sm-5'>
                <div class='form-group'>
                    <label>Número de radicado:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="radicado" value='<%=poder.radicado%>' />
                            <%=poder.radicado%>
                        </div>
                    </div>

                    <label>Poderdante nit:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="nit2" value='<%=poder.poderdante_nit%>' />
                            <%=poder.poderdante_nit%>
                        </div>
                    </div>

                    <label>Poderdante razón social:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="poderdante_razsoc"
                                value='<%=poder.poderdante_razsoc%>' />
                            <%=poder.poderdante_razsoc%>
                        </div>
                    </div>

                    <label>Representante legal:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="poderdante_repleg"
                                value='<%=poder.poderdante_repleg%>' />
                            <%=poder.poderdante_repleg%>
                        </div>
                    </div>

                    <label>Estado por subsidio:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-lightbulb"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <% if(habil_poderdante===false){ %>
                                <input type="text" class="d-none" name="estado_poderdante" value='Rechazado' readonly
                                    style='background:#fff' />Rechazado
                                <% }else{ %>
                                    <input type="text" class="d-none" name="estado_poderdante" value='Admitido' readonly
                                        style='background:#fff' />Admitido
                                    <% } %>
                        </div>
                    </div>

                    <% has_checked=(poder.estado=='A' )? 'checked' :'' %>
                        <label>Estado poder: <span id='show_estado_text'>
                                <%= (poder.estado=='A' )? 'ACTIVO' : 'RECHAZADO' %>
                            </span></label>
                        <div class='input-group'>
                            <input class="bootstrap-switch" id='estado_poder' type="checkbox" data-toggle="switch"
                                data-handle-width="300" data-on-text="ACT" data-on-color="success"
                                data-off-color="danger" data-off-text="REC" <%=has_checked%> />
                            <div class="input-group-prepend">
                                <span class="input-group-text" style='border:0px'></span>
                            </div>
                        </div>
                </div>
            </div>

            <div class="col-sm-5">
                <div class='form-group'>
                    <br />
                    <br />
                    <br />
                    <label>Apoderado nit:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="nit1" value='<%=poder.apoderado_nit%>' />
                            <%=poder.apoderado_nit%>
                        </div>
                    </div>
                    <label>Apoderado razón social:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="apoderado_razsoc"
                                value='<%=poder.apoderado_razsoc%>' />
                            <%=(poder.apoderado_razsoc)%>
                        </div>
                    </div>

                    <label>Representante legal:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <input type="text" class="d-none" name="apoderado_repleg"
                                value='<%=poder.apoderado_repleg%>' />
                            <%=(poder.apoderado_repleg)%>
                        </div>
                    </div>

                    <label>Estado por subsidio:</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text"><i class="fas fa-lightbulb"></i></span>
                        </div>
                        <div class="form-control" style='background:#fff'>
                            <% if(habil_apoderado===false){ %>
                                <input type="text" class="d-none" name="estado_apoderado" value='Rechazado' />Rechazado
                                <% }else{ %>
                                    <input type="text" class="d-none" name="estado_apoderado"
                                        value='Admitido' />Admitido
                                    <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-10">
                <div class='form-group'>
                    <label>Criterios Rechazo:</label>
                    <div class='input-group' id='show_motivo_rechazo'>
                        <% if(poder.notificacion){ %>
                            <div class='form-control' style='min-height:50px'>
                                <%=poder.notificacion%>
                            </div>
                            <% }else{ %>
                                <div class='form-control' style='min-height:50px'>NINGUNO</div>
                                <% } %>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="card-footer">
        <h6 class="card-category"><br /></h6>
    </div>
</div>