<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
    <div class="mb-4 md:mb-0">
        <h4 class="text-2xl font-bold text-blue-600">Rechazar Poder</h4>
    </div>
    <div id='showSubnav' class="flex justify-end">
        <a href='#'
            class="inline-flex items-center px-4 py-2 border border-blue-600 text-blue-600 font-medium text-sm rounded-lg hover:bg-blue-600 hover:text-white transition-colors"
            id='btn_back_list'>
            <i class="fas fa-arrow-left mr-2"></i> Salir
        </a>
    </div>
</div>

<div class="w-full max-w-6xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Formulario de Rechazo -->
            <div class="space-y-4">
                <div>
                    <label for="documento" class="block text-sm font-medium text-gray-700 mb-1">
                        <span class="text-red-500">*</span> Documento del Poder
                    </label>
                    <div toggle-error='documento' class="error text-red-500 text-sm mb-1" for="required"></div>
                    <div class="flex rounded-md shadow-sm">
                        <span
                            class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                            <i class="fas fa-file-contract"></i>
                        </span>
                        <input type="text"
                            class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            id='documento' name="documento" placeholder='Número de documento' required />
                    </div>
                </div>

                <div>
                    <label for="criterio_rechazo" class="block text-sm font-medium text-gray-700 mb-1">
                        <span class="text-red-500">*</span> Criterio de Rechazo
                    </label>
                    <div toggle-error='criterio_rechazo' class="error text-red-500 text-sm mb-1" for="required"></div>
                    <div class="flex rounded-md shadow-sm">
                        <span
                            class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                            <i class="fas fa-exclamation-triangle"></i>
                        </span>
                        <select
                            class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            id='criterio_rechazo' name="criterio_rechazo" required>
                            <option value="">Seleccione un criterio</option>
                            <% _.each(criterios, function(criterio) { %>
                                <option value="<%=criterio.criterio%>">
                                    <%=criterio.criterio%> - <%=criterio.descripcion%>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>

                <div>
                    <label for="observaciones" class="block text-sm font-medium text-gray-700 mb-1">
                        Observaciones
                    </label>
                    <div toggle-error='observaciones' class="error text-red-500 text-sm mb-1" for="required"></div>
                    <div class="flex rounded-md shadow-sm">
                        <span
                            class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                            <i class="fas fa-comment"></i>
                        </span>
                        <textarea
                            class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
                            id='observaciones' name="observaciones" rows="3"
                            placeholder='Detalles adicionales sobre el rechazo'></textarea>
                    </div>
                </div>

                <div class="text-center">
                    <button type='button'
                        class='inline-flex items-center px-6 py-2.5 bg-red-600 text-white font-medium text-sm leading-tight uppercase rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-300 transition-colors'
                        id='btn_rechazar_poder'>
                        <i class="fas fa-ban mr-2"></i> Rechazar Poder
                    </button>
                </div>
            </div>

            <!-- Búsqueda e Historial -->
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        <i class="fas fa-search text-gray-500 mr-1"></i> Buscar Poder
                    </label>
                    <div class="flex rounded-md shadow-sm">
                        <span
                            class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text"
                            class="flex-1 min-w-0 block w-full px-3 py-2 border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            id='buscar_documento' placeholder='Ingrese documento a buscar' />
                        <button type='button'
                            class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors"
                            id='btn_buscar_documento'>
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-history text-gray-500 mr-1"></i> Últimos Rechazos
                    </label>
                    <button
                        class="inline-flex items-center px-4 py-2 bg-blue-100 text-blue-700 font-medium text-sm rounded-lg hover:bg-blue-200 transition-colors"
                        id='btn_ver_historial'>
                        <i class="fas fa-history mr-2"></i> Ver Historial
                    </button>
                </div>

                <div class="mt-6" id="resultado-busqueda">
                    <!-- Resultados de búsqueda se mostrarán aquí -->
                </div>

                <div class="mt-6" id="historial-rechazos">
                    <!-- Historial de rechazos se mostrará aquí -->
                </div>
            </div>
        </div>
    </div>
</div>