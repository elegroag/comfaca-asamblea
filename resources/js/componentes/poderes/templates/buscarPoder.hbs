<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
    <div class="mb-4 md:mb-0">
        <h4 class="text-2xl font-bold text-blue-600">Buscar Poder</h4>
    </div>
    <div class="col">
        <div id='showSubnav'></div>
    </div>
</div>

<div class="w-full max-w-5xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex flex-wrap justify-center gap-6">
            <!-- Avatar Section -->
            <div class="w-full md:w-1/4 mt-4">
                <div class="text-center">
                    <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-200">
                        <!--<img src="/images/default-avatar.png" alt="Avatar" class="w-full h-full object-cover" />!-->
                    </div>
                    <h6 class="mt-2 text-sm text-gray-500">Apoderado - Poderdante</h6>
                </div>
            </div>

            <!-- Poderdante Form -->
            <div class="w-full md:w-5/12">
                <div class="space-y-4">
                    <div>
                        <label for="poderdante_nit" class="block text-sm font-medium text-gray-700 mb-1">
                            Poderdante nit
                        </label>
                        <div toggle-error='poderdante_nit' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                name="poderdante_nit" id='poderdante_nit' placeholder='poderdante nit' />
                        </div>
                    </div>

                    <div>
                        <label for="poderdante_identificacion" class="block text-sm font-medium text-gray-700 mb-1">
                            Representante identificación
                        </label>
                        <div toggle-error='poderdante_identificacion' class="error text-red-500 text-sm mb-1"
                            for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                name="poderdante_identificacion" id='poderdante_identificacion'
                                placeholder='identificacion' />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Apoderado Form -->
            <div class="w-full md:w-5/12">
                <div class="space-y-4">
                    <div>
                        <label for="apoderado_nit" class="block text-sm font-medium text-gray-700 mb-1">
                            Apoderado nit
                        </label>
                        <div toggle-error='apoderado_nit' class="error text-red-500 text-sm mb-1" for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-building"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                name="apoderado_nit" id='apoderado_nit' placeholder='apoderado nit' />
                        </div>
                    </div>

                    <div>
                        <label for="apoderado_identificacion" class="block text-sm font-medium text-gray-700 mb-1">
                            Representante identificación
                        </label>
                        <div toggle-error='apoderado_identificacion' class="error text-red-500 text-sm mb-1"
                            for="required"></div>
                        <div class="flex rounded-md shadow-sm">
                            <span
                                class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input type="text"
                                class="flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-lg border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                name="apoderado_identificacion" id='apoderado_identificacion'
                                placeholder='identificacion' />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botón Buscar -->
            <div class="w-full">
                <div class="text-center">
                    <button type='button'
                        class='inline-flex items-center px-6 py-2.5 border border-green-600 text-green-600 font-medium text-sm leading-tight uppercase rounded-lg hover:bg-green-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-green-300 transition-colors'
                        id='btn_buscar_poder'>
                        <i class="fas fa-search mr-2"></i> Buscar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>