<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fa fa-list mr-2 pb-3"></i>Listado de Carteras
            </h5>
            <div class="d-flex align-items-center">
                <button type="button" class="btn btn-outline-light btn-sm mr-2" id="bt_crear_cartera">
                    <i class="fa fa-plus mr-1"></i>Nueva Cartera
                </button>
                <button type="button" class="btn btn-outline-light btn-sm mr-2" id="bt_cargar_cartera">
                    <i class="fa fa-upload mr-1"></i>Cargar Masivo
                </button>
                <button type="button" class="btn btn-outline-light btn-sm" id="bt_exportar_lista">
                    <i class="fa fa-download mr-1"></i>Exportar
                </button>
            </div>
        </div>
        <div class="card-body">
            <!-- Filtros de Búsqueda -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">
                                <i class="fa fa-search"></i>
                            </span>
                        </div>
                        <input type="text" class="form-control" id="filtro_nit" placeholder="Buscar por NIT...">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">
                                <i class="fa fa-building"></i>
                            </span>
                        </div>
                        <input type="text" class="form-control" id="filtro_razsoc"
                            placeholder="Buscar por Razón Social...">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">
                                <i class="fa fa-user"></i>
                            </span>
                        </div>
                        <input type="text" class="form-control" id="filtro_representante"
                            placeholder="Buscar por Representante...">
                    </div>
                </div>
            </div>

            <!-- Tabla de Datos -->
            <div class="table-responsive tb-options">
                <table class="table table-striped table-bordered dataTable dtr-inline" id="tb_data_cartera"
                    width="100%">
                    <thead>
                        <tr>
                            <th>
                                <i class="fa fa-hashtag mr-1"></i>NIT
                            </th>
                            <th>
                                <i class="fa fa-building mr-1"></i>Razón Social
                            </th>
                            <th>
                                <i class="fa fa-id-card mr-1"></i>Cédula Rep.
                            </th>
                            <th>
                                <i class="fa fa-user-tie mr-1"></i>Representante Leg.
                            </th>
                            <th>
                                <i class="fa fa-file-alt mr-1"></i>Concepto
                            </th>
                            <th>
                                <i class="fa fa-cogs mr-1"></i>Acciones
                            </th>
                        </tr>
                    </thead>
                    <tbody id="tb_row_cartera"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

