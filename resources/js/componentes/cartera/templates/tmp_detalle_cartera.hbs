<div class="flex flex-col md:flex-row justify-between items-start mb-6">
    <div class="mb-4 md:mb-0">
        <h5 class="text-xl font-semibold text-blue-600">Cartera Detalle</h5>
    </div>
    <div class="w-full md:w-auto">
        <div id='showSubnav' class="flex justify-end">
            <button href='#'
                class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors inline-flex items-center"
                id='btn_back_list'>
                <i class="fas fa-arrow-left mr-2"></i>
                Volver
            </button>
        </div>
    </div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <tbody class="divide-y divide-gray-200">
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900 w-1/3">Nit</td>
                            <td class="py-3 px-4 text-gray-700">
                                <%=cartera.nit%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Razón social</td>
                            <td class="py-3 px-4 text-gray-700 capitalize">
                                <%=cartera.razsoc%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Cédula</td>
                            <td class="py-3 px-4 text-gray-700">
                                <%=cartera.cedrep%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Representante legal</td>
                            <td class="py-3 px-4 text-gray-700 capitalize">
                                <%=cartera.repleg%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Código Detalle</td>
                            <td class="py-3 px-4 text-gray-700">
                                <%=cartera.codigo_detalle%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Concepto</td>
                            <td class="py-3 px-4 text-gray-700">
                                <%=cartera.concepto%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Teléfono</td>
                            <td class="py-3 px-4 text-gray-700">
                                <%=cartera.telefono%>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-4 font-medium text-gray-900">Email</td>
                            <td class="py-3 px-4 text-gray-700 capitalize">
                                <%=cartera.email%>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>