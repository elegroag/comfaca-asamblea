<div class="flex flex-col md:flex-row justify-between items-start mb-6">
    <div class="mb-4 md:mb-0">
        <h5 class="text-xl font-semibold text-blue-600">
            <%=title%>
        </h5>
    </div>
    <div class="w-full md:w-auto">
        <div id='showSubnav'></div>
    </div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- NIT Empresa -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Nit Empresa
                    </label>
                    <div toggle-error='nit' class="error text-red-500 text-sm" for="required"></div>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-building text-gray-400"></i>
                        </div>
                        <% disabled=(isNew==false)? 'disabled' : '' %>
                            <input type="text"
                                class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 disabled:cursor-not-allowed transition-colors <%=disabled%>"
                                id='nit' name="nit" placeholder='NIT' value="<%=(cartera.nit)? cartera.nit: ''%>"
                                <%=disabled%>
                            />
                            <div class="absolute inset-y-0 right-0 pr-2 flex items-center">
                                <button type='button' id='bt_buscar_empresa'
                                    class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors <%=disabled%>"
                                    title="Buscar empresa" <%=disabled%>
                                    >
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                    </div>
                </div>

                <!-- Razón Social -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Razón Social
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-store text-gray-400"></i>
                        </div>
                        <input type="text"
                            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                            name="razsoc" id='razsoc' placeholder='Razón social' value="<%=cartera.razsoc%>" />
                    </div>
                </div>

                <!-- Representante Legal -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Representante Legal
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-400"></i>
                        </div>
                        <input type="text"
                            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                            name="repleg" id='repleg' placeholder='Nombre representante legal'
                            value="<%=cartera.repleg%>" />
                    </div>
                </div>

                <!-- Cedula Representante -->
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Cedula Representante
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-id-card text-gray-400"></i>
                        </div>
                        <input type="text"
                            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                            name="cedrep" id='cedrep' placeholder='Cédula representante' value="<%=cartera.cedrep%>" />
                    </div>
                </div>

                <!-- Código -->
                <div class="space-y-2">
                    <label for="codigo" class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Código
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-tag text-gray-400"></i>
                        </div>
                        <select
                            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 disabled:cursor-not-allowed appearance-none transition-colors <%=disabled%>"
                            name="codigo" id='codigo' <%=disabled%>
                            >
                            <%_.each(options, function(value, key){%>
                                <% selected=(cartera.codigo==key)? 'selected' :'' %>
                                    <option value="<%=key%>" <%=selected%>><%=value%>
                                    </option>
                                    <% }) %>
                        </select>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- Concepto -->
                <div class="space-y-2">
                    <label for="concepto" class="block text-sm font-medium text-gray-700">
                        <span class="text-red-500">*</span> Concepto
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-file-alt text-gray-400"></i>
                        </div>
                        <input type="text"
                            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                            name="concepto" id='concepto' placeholder='Concepto' value="<%=cartera.concepto%>" />
                    </div>
                </div>
            </div>

            <!-- Validación y acciones -->
            <div class="border-t pt-6">
                <label class="block text-sm font-medium text-gray-700 mb-3">
                    <span class="text-red-500">*</span> Validación y acciones disponibles
                </label>
                <div class="flex items-center space-x-3">
                    <div class="relative">
                        <input class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:ring-2"
                            name='cruzar_habiles' id='cruzar_habiles' type="checkbox" value="" />
                    </div>
                    <label for="cruzar_habiles" class="text-sm text-gray-700 cursor-pointer">
                        Cruzar Con Habilitados
                    </label>
                </div>
            </div>

            <!-- Botón de acción -->
            <div class="border-t pt-6">
                <div class="text-center">
                    <button type='button'
                        class='px-6 py-3 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed disabled:opacity-50'
                        id='bt_registrar' <%=(isNew==false)? '' : 'disabled' %>
                        >
                        <i class="fas fa-save mr-2"></i>
                        <%=(isNew==false)? 'Actualizar' : 'Registrar' %>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>