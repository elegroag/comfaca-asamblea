<div class="col ml-auto mr-auto">
    <div class="card-body">
        <div class='col-md-11'>
            <div class='row justify-content-center'>
                <form method="post" action="#" class='form-horizontal' id='formulario'>
                    <div class="row ">
                        <div class="col-md-6">
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Nit</label>
                                <div class='col-md-8'>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name='nit' placeholder="nit" value="<%=nit%>" readonly />
                                    </div>
                                </div>
                            </div>
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Cedula</label>
                                <div class='col-md-8'>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name='cedrep' placeholder="cedula" value="<%=cedrep%>" />
                                    </div>
                                </div>
                            </div>
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Nombre Representante</label>
                                <div class='col-md-8'>
                                    <div class='form-group'>
                                        <input type='text' class="form-control" name='repleg' id='repleg' placeholder='nombres representante' value="<%=repleg%>" />
                                    </div>
                                </div>
                            </div>
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Razón Social</label>
                                <div class='col-md-8'>
                                    <div class='form-group'>
                                        <input type='text' class="form-control" name='razsoc' id='razsoc' placeholder='razsoc' value="<%=razsoc%>" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Email</label>
                                <div class='col-md-8'>
                                    <div class='form-group'>
                                        <input type='text' class="form-control" name='email' id='email' placeholder='email' value="<%=email%>" />
                                    </div>
                                </div>
                            </div>
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Telefono</label>
                                <div class='col-md-8'>
                                    <div class='form-group'>
                                        <input type='text' class="form-control" name='telefono' id='telefono' placeholder='telefono' value="<%=telefono%>" />
                                    </div>
                                </div>
                            </div>
                            <div class='row'>
                                <label class='col-md-4 col-form-label'>Opciones disponibles</label>
                                <div class='col-md-8 checkbox-radios'>
                                    <div class="form-check">
                                        <label class="form-check-label">
                                            <input class="form-check-input" name='cruzar_cartera' type="checkbox" value="">Cruzar con cartera
                                            <span class="form-check-sign"></span>
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <label class="form-check-label">
                                            <input class="form-check-input" name='crear_pre_registro' checked type="checkbox" value="">Crear Pre registro
                                            <span class="form-check-sign"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class='col-md-12'>
                            <div class='text-center'>
                                <button type='button' class='btn btn-outline-success btn-round' id='bt_edita_registro'><i class="fa fa-search"></i> Continuar</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>