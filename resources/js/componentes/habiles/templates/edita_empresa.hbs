<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="fa fa-edit mr-2 pb-3"></i>Editar Empresa
            </h5>
        </div>
        <div class="card-body">
            <form method="post" action="#" class="needs-validation" id="formulario" novalidate>
                <div class="row">
                    <!-- Columna Izquierda -->
                    <div class="col-lg-6 col-md-12">
                        <div class="form-group row">
                            <label for="nit" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-hashtag mr-1"></i>NIT
                            </label>
                            <div class="col-md-8">
                                <input type="text" class="form-control form-control-sm" name="nit" id="nit"
                                    placeholder="Número de Identificación Tributaria" value="<%=nit%>" readonly
                                    required />
                                <div class="invalid-feedback">
                                    El NIT es requerido
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label for="cedrep" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-id-card mr-1"></i>Cédula Representante
                            </label>
                            <div class="col-md-8">
                                <input type="text" class="form-control form-control-sm" name="cedrep" id="cedrep"
                                    placeholder="Número de cédula" value="<%=cedrep%>" required />
                                <div class="invalid-feedback">
                                    La cédula del representante es requerida
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label for="repleg" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-user mr-1"></i>Nombre Representante
                            </label>
                            <div class="col-md-8">
                                <input type="text" class="form-control form-control-sm" name="repleg" id="repleg"
                                    placeholder="Nombres completos del representante" value="<%=repleg%>" required />
                                <div class="invalid-feedback">
                                    El nombre del representante es requerido
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label for="razsoc" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-building mr-1"></i>Razón Social
                            </label>
                            <div class="col-md-8">
                                <input type="text" class="form-control form-control-sm" name="razsoc" id="razsoc"
                                    placeholder="Razón social de la empresa" value="<%=razsoc%>" required />
                                <div class="invalid-feedback">
                                    La razón social es requerida
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha -->
                    <div class="col-lg-6 col-md-12">
                        <div class="form-group row">
                            <label for="email" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-envelope mr-1"></i>Correo Electrónico
                            </label>
                            <div class="col-md-8">
                                <input type="email" class="form-control form-control-sm" name="email" id="email"
                                    placeholder="correo@ejemplo.com" value="<%=email%>" />
                                <div class="invalid-feedback">
                                    Ingrese un correo electrónico válido
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label for="telefono" class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-phone mr-1"></i>Teléfono
                            </label>
                            <div class="col-md-8">
                                <input type="tel" class="form-control form-control-sm" name="telefono" id="telefono"
                                    placeholder="Número de teléfono" value="<%=telefono%>" />
                                <div class="invalid-feedback">
                                    Ingrese un número de teléfono válido
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-md-4 col-form-label font-weight-bold">
                                <i class="fa fa-cogs mr-1"></i>Opciones Disponibles
                            </label>
                            <div class="col-md-8">
                                <div class="custom-control custom-checkbox mb-2">
                                    <input type="checkbox" class="custom-control-input" name="cruzar_cartera"
                                        id="cruzar_cartera">
                                    <label class="custom-control-label" for="cruzar_cartera">
                                        <i class="fa fa-exchange-alt mr-1"></i>Cruzar con Cartera
                                    </label>
                                </div>
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" name="crear_pre_registro"
                                        id="crear_pre_registro" checked>
                                    <label class="custom-control-label" for="crear_pre_registro">
                                        <i class="fa fa-user-plus mr-1"></i>Crear Pre-registro
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de Acción -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="d-flex justify-content-center">
                            <button type="button" class="btn btn-success btn-lg px-4 py-2 mr-2" id="bt_edita_registro">
                                <i class="fa fa-save mr-2"></i>Guardar Cambios
                            </button>
                            <button type="button" class="btn btn-secondary btn-lg px-4 py-2" id="bt_cancelar">
                                <i class="fa fa-times mr-2"></i>Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>