<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6">
            <div class="w-full">
                <div class="flex justify-center">
                    <form method="post" action="#" class="w-full max-w-3xl" id='formulario'>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Columna Izquierda -->
                            <div class="space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Nit
                                    </label>
                                    <div
                                        class="flex items-center border border-gray-300 rounded-lg overflow-hidden bg-gray-50">
                                        <div class="bg-gray-200 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-id-card text-gray-500"></i>
                                        </div>
                                        <input type="text"
                                            class="flex-1 px-3 py-2 border-0 bg-gray-100 text-gray-600 cursor-not-allowed outline-none"
                                            name='nit' placeholder="nit" value="<%=nit%>" readonly />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Cédula
                                    </label>
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-id-badge text-gray-500"></i>
                                        </div>
                                        <input type="text"
                                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                            name='cedrep' placeholder="cédula" value="<%=cedrep%>" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Nombre Representante
                                    </label>
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-user text-gray-500"></i>
                                        </div>
                                        <input type='text'
                                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                            name='repleg' id='repleg' placeholder='nombres representante'
                                            value="<%=repleg%>" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Razón Social
                                    </label>
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-building text-gray-500"></i>
                                        </div>
                                        <input type='text'
                                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                            name='razsoc' id='razsoc' placeholder='razón social' value="<%=razsoc%>" />
                                    </div>
                                </div>
                            </div>

                            <!-- Columna Derecha -->
                            <div class="space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Email
                                    </label>
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-envelope text-gray-500"></i>
                                        </div>
                                        <input type='text'
                                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                            name='email' id='email' placeholder='email' value="<%=email%>" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">
                                        Teléfono
                                    </label>
                                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                            <i class="fas fa-phone text-gray-500"></i>
                                        </div>
                                        <input type='text'
                                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                            name='telefono' id='telefono' placeholder='teléfono'
                                            value="<%=telefono%>" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-3">
                                        Opciones disponibles
                                    </label>
                                    <div class="space-y-3">
                                        <div class="flex items-center">
                                            <div class="flex items-center h-5">
                                                <input
                                                    class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500"
                                                    name='cruzar_cartera' type="checkbox" value="" />
                                            </div>
                                            <div class="ml-3 text-sm">
                                                <label
                                                    class="font-medium text-gray-700 cursor-pointer hover:text-gray-900">
                                                    Cruzar con cartera
                                                </label>
                                            </div>
                                        </div>
                                        <div class="flex items-center">
                                            <div class="flex items-center h-5">
                                                <input
                                                    class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500"
                                                    name='crear_pre_registro' checked type="checkbox" value="" />
                                            </div>
                                            <div class="ml-3 text-sm">
                                                <label
                                                    class="font-medium text-gray-700 cursor-pointer hover:text-gray-900">
                                                    Crear Pre registro
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-8">
                            <div class="text-center">
                                <button type='button'
                                    class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors"
                                    id='bt_edita_registro'>
                                    <i class="fas fa-save mr-2"></i>
                                    Continuar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>