<tr class="hover:bg-gray-50 transition-colors">
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=nit%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=capitalize(razsoc)%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=cedrep%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=capitalize(repleg)%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=telefono%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
		<%=capitalize(email)%>
	</td>
	<td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
		<div class="flex justify-center space-x-1">
			<button type="button" data-cid='<%=nit%>' data-toggle='row-like'
				class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Ver detalles">
				<i class="fas fa-eye"></i>
			</button>
			<? if (Session::getData("SuperAdmin") == 1) { ?>
			<button type="button" data-cid='<%=nit%>' data-toggle='row-edit'
				class="p-2 text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors" title="Editar">
				<i class="fas fa-edit"></i>
			</button>
			<? } ?>
			<? if (Session::getData("SuperAdmin") == 1) { ?>
			<button type="button" data-cid='<%=nit%>' data-toggle='row-remove'
				class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Eliminar">
				<i class="fas fa-trash"></i>
			</button>
			<? } ?>
		</div>
	</td>
</tr>