<div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="p-6">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="text-red-500">*</i> Archivo
                    </label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                            <i class="fas fa-file-upload text-gray-500"></i>
                        </div>
                        <input style='display:none' type='file' data-event='upload' name='archivo_habiles'
                            id='archivo_habiles' onchange='handleFiles()' />
                        <div class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white cursor-pointer hover:bg-gray-50 transition-colors"
                            data-toggle-file='searchfile' id='name_archivo' name="name_archivo">
                            <span class="text-gray-500">Seleccionar archivo...</span>
                        </div>
                        <div class="bg-gray-50 px-2 py-1 border-l border-gray-300">
                            <button type='button' data-toggle-file='searchfile'
                                class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                                title="Buscar archivo">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div class="bg-gray-50 px-2 py-1 border-l border-gray-300">
                            <button type='button' disabled id='remover_archivo'
                                class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                title="Remover archivo">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mt-3 p-4 bg-blue-50 rounded-lg border border-blue-200">
                        <p class="text-sm text-blue-800 font-medium mb-2">Formato del archivo CSV:</p>
                        <p class="text-sm text-blue-700">
                            Requiere de un archivo csv separado por (;) con:<br />
                            <span class="font-medium">Columna 1:</span> Nit Empresa<br />
                            <span class="font-medium">Columna 2:</span> Razón Social<br />
                            <span class="font-medium">Columna 3:</span> Cédula Representante Legal<br />
                            <span class="font-medium">Columna 4:</span> Nombre Representante Legal<br />
                            <span class="font-medium">Columna 5:</span> Teléfono<br />
                            <span class="font-medium">Columna 6:</span> Email<br />
                            <span class="font-medium">Columna 7:</span> Tipo ingreso (V) virtual o (P) presencial
                        </p>
                    </div>
                </div>

                <div class="flex items-center">
                    <div class="flex items-center h-5">
                        <input
                            class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500"
                            name='cruzar_cartera' id='cruzar_cartera' type="checkbox" value="" />
                    </div>
                    <div class="ml-3 text-sm">
                        <label for="cruzar_cartera"
                            class="font-medium text-gray-700 cursor-pointer hover:text-gray-900">
                            Cruzar con Base de Cartera
                        </label>
                    </div>
                </div>
            </div>

            <div class="text-center mt-8">
                <button type='button' disabled
                    class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    id='bt_hacer_cargue'>
                    <i class="fas fa-upload mr-2"></i>
                    Continuar
                </button>
            </div>
        </div>
    </div>
</div>