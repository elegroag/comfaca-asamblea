<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-building text-muted mr-2"></i>
        <span class="font-weight-bold">
            <%=nit%>
        </span>
    </div>
</td>
<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-industry text-info mr-2"></i>
        <%=capitalize(razsoc)%>
    </div>
</td>
<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-id-card text-warning mr-2"></i>
        <%=cedula_representa%>
    </div>
</td>
<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-user-tie text-primary mr-2"></i>
        <%=capitalize(nombre_representa)%>
    </div>
</td>
<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-exclamation-triangle text-danger mr-2"></i>
        <span class="badge badge-warning">
            <%=criterio%>
        </span>
    </div>
</td>
<td>
    <div class="d-flex align-items-center">
        <i class="fa fa-tag text-secondary mr-2"></i>
        <span class="badge badge-info">
            <%=tipo_criterio%>
        </span>
    </div>
</td>
<td class="text-center">
    <div class="btn-group" role="group">
        <button type="button" data-cid="<%=id%>" data-toggle="row-like" class="btn btn-primary btn-sm rounded-circle"
            title="Ver detalles del rechazo">
            <i class="fa fa-eye"></i>
        </button>
        <? if (Session::getData("SuperAdmin") == 1) { ?>
        <button type="button" data-cid="<%=id%>" data-toggle="row-edit" class="btn btn-warning btn-sm rounded-circle"
            title="Editar rechazo">
            <i class="fa fa-edit"></i>
        </button>
        <? } ?>
        <? if (Session::getData("SuperAdmin") == 1) { ?>
        <button type="button" data-cid="<%=id%>" data-toggle="row-remove" class="btn btn-danger btn-sm rounded-circle"
            title="Eliminar rechazo">
            <i class="fa fa-trash"></i>
        </button>
        <? } ?>
    </div>
</td>