<div class="max-w-2xl mx-auto p-6">
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="p-6">
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Nit Empresa
                    </label>
                    <div toggle-error='nit' class="error text-red-500 text-sm mb-2" for="required"></div>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-building text-gray-600"></i>
                            </div>
                        </div>
                        <% disabled=(isNew==false)? 'disabled' : '' %>
                            <input type="number"
                                class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                id='nit' name="nit" placeholder='nit' value="<%=(nit)? nit: ''%>" <%=disabled%> />
                            <div class="flex-shrink-0">
                                <button type='button' id='bt_buscar_empresa'
                                    class="p-2 bg-blue-600 text-white rounded-r-md hover:bg-blue-700 transition-colors"
                                    title="Buscar empresa">
                                    <i class="fas fa-search text-sm"></i>
                                </button>
                            </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Razón Social
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-building text-gray-600"></i>
                            </div>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name="razsoc" id='razsoc' placeholder='razon social' value="<%=razsoc%>" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Representante Legal
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-user text-gray-600"></i>
                            </div>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name="nombre_representa" id='nombre_representa' placeholder='representante legal'
                            value="<%=nombre_representa%>" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Cedula Representante
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-id-card text-gray-600"></i>
                            </div>
                        </div>
                        <input type="number"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name="cedula_representa" id='cedula_representa' placeholder='cedula representante'
                            value="<%=cedula_representa%>" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Email Empresa</label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-envelope text-gray-600"></i>
                            </div>
                        </div>
                        <input type='text'
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name='email' id='email' placeholder='email' />
                    </div>
                    <span toggle-error='email' class="error text-red-500 text-sm mt-1"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Teléfono Empresa</label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-phone text-gray-600"></i>
                            </div>
                        </div>
                        <input type='number'
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name='telefono' id='telefono' placeholder='telefono' />
                    </div>
                    <span toggle-error='telefono' class="error text-red-500 text-sm mt-1"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Criterio
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-list text-gray-600"></i>
                            </div>
                        </div>
                        <select
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            name="criterio" id='criterio' <%=disabled%>>
                            <%_.each(criterios, function(value, key){%>
                                <option value="<%=key%>">
                                    <%=value%>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                </div>

                <div class="pt-4">
                    <label class="block text-sm font-medium text-gray-700 mb-3">
                        <i class='text-red-500'>*</i> Validación y acciones disponibles
                    </label>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 text-blue-600 focus:ring-blue-500 rounded border-gray-300"
                            name='cruzar' id='cruzar' value="">
                        <span class="text-sm text-gray-700">Cruzar Con Habiles</span>
                    </label>
                </div>
            </div>

            <div class='mt-8'>
                <div class='text-center'>
                    <button type='button'
                        class='px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 focus:ring-4 focus:ring-green-300 transition-all duration-200 transform hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100'
                        id='bt_registrar' <%=(isNew==false)? '' : 'disabled' %>>
                        <i class="fas fa-play mr-2"></i>
                        Continuar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>