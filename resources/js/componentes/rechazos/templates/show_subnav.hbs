<div class="container-fluid">
    <div class="row align-items-center">
        <!-- Título -->
        <div class="col-md-6">
            <h3 class="text-danger font-weight-bold mb-0">
                <i class="fa fa-times-circle mr-2"></i>
                <%=titulo%>
            </h3>
            <p class="text-muted mb-0">Gestión de rechazos del sistema</p>
        </div>

        <!-- Botones de Navegación -->
        <div class="col-md-6">
            <div class="d-flex justify-content-end flex-wrap gap-2">
                <button class="btn btn-primary rounded-pill" id="bt_listar" type="button" <%=(!listar)? 'disabled' : ''
                    %>>
                    <i class="fa fa-list mr-2"></i>
                    Listar
                </button>
                <button class="btn btn-warning rounded-pill" id="bt_masivo_registro" type="button"
                    <%=(!masivo)? 'disabled' : '' %>>
                    <i class="fa fa-upload mr-2"></i>
                    Cargar Masivo
                </button>
                <button class="btn btn-success rounded-pill" id="bt_export_data" type="button"
                    <%=(!exportar)? 'disabled' : '' %>>
                    <i class="fa fa-download mr-2"></i>
                    Exportar
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .btn {
        transition: all 0.2s ease-in-out;
    }

    .btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @media (max-width: 768px) {
        .d-flex {
            flex-direction: column;
            align-items: stretch;
        }

        .btn {
            margin-bottom: 0.5rem;
        }
    }
</style>