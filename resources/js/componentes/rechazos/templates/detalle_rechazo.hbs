<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-danger font-weight-bold mb-0">
                <i class="fa fa-times-circle mr-2"></i>
                Detalle de Rechazo
            </h3>
            <p class="text-muted mb-0">Información completa del rechazo</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="btn_back_list" class="btn btn-outline-danger rounded-pill">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Volver
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-info-circle mr-2"></i>
                Información del Rechazo
            </h5>
        </div>
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">
                    <!-- Card de Información Principal -->
                    <div class="card border-0 bg-light mb-4">
                        <div class="card-body">
                            <div class="row">
                                <!-- Columna Izquierda -->
                                <div class="col-md-6">
                                    <!-- NIT -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-building mr-1"></i>
                                            NIT
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="badge badge-primary mr-2">
                                                <%=nit%>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Razón Social -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-industry mr-1"></i>
                                            Razón Social
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="font-weight-bold">
                                                <%=capitalize(razsoc)%>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Cédula Representante -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-id-card mr-1"></i>
                                            Cédula Representante
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="font-weight-bold">
                                                <%=cedula_representa%>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Nombre Representante -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-user-tie mr-1"></i>
                                            Nombre Representante
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="font-weight-bold">
                                                <%=capitalize(nombre_representa)%>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna Derecha -->
                                <div class="col-md-6">
                                    <!-- Criterio -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-exclamation-triangle mr-1"></i>
                                            Criterio
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="badge badge-warning">
                                                <%=capitalize(criterio)%>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Tipo Criterio -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-tag mr-1"></i>
                                            Tipo Criterio
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="badge badge-info">
                                                <%=capitalize(tipo_criterio)%>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Estado -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-toggle-on mr-1"></i>
                                            Estado
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <% if(estado=='R' ){ %>
                                                <span class="badge badge-danger">
                                                    <i class="fa fa-times-circle mr-1"></i>
                                                    Rechazado
                                                </span>
                                                <% }else{ %>
                                                    <span class="badge badge-success">
                                                        <i class="fa fa-check-circle mr-1"></i>
                                                        Aceptado
                                                    </span>
                                                    <% } %>
                                        </div>
                                    </div>

                                    <!-- Fecha -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-calendar mr-1"></i>
                                            Fecha
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="font-weight-bold">
                                                <%=dia%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Información Adicional -->
                            <div class="row mt-4 pt-3 border-top">
                                <div class="col-md-6">
                                    <!-- Reg. Ingreso -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-hashtag mr-1"></i>
                                            Reg. Ingreso
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="badge badge-secondary">
                                                <%=regingre_id%>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <!-- Hora -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-clock-o mr-1"></i>
                                            Hora
                                        </label>
                                        <div class="d-flex align-items-center">
                                            <span class="font-weight-bold">
                                                <%=hora%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Alerta de Rechazo -->
                    <div class="alert alert-danger border-0 bg-light mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-exclamation-triangle fa-2x mr-3"></i>
                            <div>
                                <h6 class="alert-heading mb-1">Información de Rechazo</h6>
                                <p class="mb-0">
                                    Este registro ha sido marcado como rechazo y requiere atención especial.
                                    Por favor revise los detalles y tome las acciones necesarias.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div class="text-center">
                        <button type="button" data-cid="<%=id%>" class="btn btn-warning rounded-pill btn-lg"
                            id="bt_procesar">
                            <i class="fa fa-cogs mr-2"></i>
                            Procesar Rechazo
                        </button>
                        <button type="button" class="btn btn-secondary rounded-pill btn-lg ml-2" id="bt_cancelar">
                            <i class="fa fa-times mr-2"></i>
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede procesar el rechazo para corregir los problemas detectados.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }
</style>