<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6">
            <h4 class="text-xl font-semibold text-gray-800 text-center mb-6">Crear Registro Mesas</h4>

            <div class="flex justify-center">
                <div class="w-full max-w-lg">
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Nit Empresa
                        </label>
                        <div toggle-error='apoderado_nit' class="error text-red-500 text-sm mt-1" for="required"></div>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-building text-gray-500"></i>
                            </div>
                            <input type="text"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                name="nit" placeholder="nit" />
                            <button type='button' id='bt_buscar_apoderado'
                                class="p-2 text-blue-600 hover:bg-blue-50 transition-colors border-l border-gray-300"
                                title="Buscar empresa">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Razón Social
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-building text-gray-500"></i>
                            </div>
                            <input type="text"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                name="razsoc" placeholder="razón social" />
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Representante Legal
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-user text-gray-500"></i>
                            </div>
                            <input type="text"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                name="repleg" placeholder="representante legal" />
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Concepto
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-tag text-gray-500"></i>
                            </div>
                            <select
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                name="concepto">
                                <option value="">Selecciona aquí</option>
                                <option value="A">APORTES</option>
                                <option value="S">SERVICIOS</option>
                                <option value="L">LIBRANZA</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Código
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-hashtag text-gray-500"></i>
                            </div>
                            <input type="text"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                name="codigo" placeholder="código" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-8">
                <button type='button' disabled
                    class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                    id='bt_hacer_cargue'>
                    <i class="fas fa-check mr-2"></i> Continuar
                </button>
            </div>
        </div>

        <div class="bg-gray-50 px-6 py-3 border-t border-gray-200">
            <!-- Footer content if needed -->
        </div>
    </div>
</div>