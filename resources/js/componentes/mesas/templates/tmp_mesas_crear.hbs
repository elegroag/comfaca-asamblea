<div class="container-fluid">
    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-plus-circle mr-2"></i>
                Crear Registro de Mesas
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Complete los datos para crear una nueva mesa de votación.
                            Todos los campos marcados con * son obligatorios.
                        </p>
                    </div>
                </div>
            </div>

            <form id="formulario_mesa">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo Código -->
                        <div class="form-group">
                            <label for="codigo" class="font-weight-bold">
                                <i class="text-danger">*</i> Código de Mesa
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-hashtag"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="codigo" name="codigo"
                                    placeholder="Código único de la mesa" required>
                            </div>
                            <div class="invalid-feedback" id="codigo-error">
                                El código es obligatorio
                            </div>
                        </div>

                        <!-- Campo Cédula Responsable -->
                        <div class="form-group">
                            <label for="cedtra_responsable" class="font-weight-bold">
                                <i class="text-danger">*</i> Cédula Responsable
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-id-card"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="cedtra_responsable"
                                    name="cedtra_responsable" placeholder="Número de cédula del responsable" required>
                                <div class="input-group-append">
                                    <button type="button" id="bt_buscar_funcionario" class="btn btn-outline-primary"
                                        title="Buscar funcionario">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="invalid-feedback" id="cedtra_responsable-error">
                                La cédula es obligatoria
                            </div>
                        </div>

                        <!-- Campo Nombre Funcionario -->
                        <div class="form-group">
                            <label for="nombre" class="font-weight-bold">
                                <i class="text-danger">*</i> Nombre del Funcionario
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user-tie"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="nombre" name="nombre"
                                    placeholder="Nombre completo del funcionario" required>
                            </div>
                            <div class="invalid-feedback" id="nombre-error">
                                El nombre es obligatorio
                            </div>
                        </div>

                        <!-- Campo Usuario -->
                        <div class="form-group">
                            <label for="usuario" class="font-weight-bold">
                                <i class="text-danger">*</i> Usuario
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="usuario" name="usuario"
                                    placeholder="Usuario del sistema" required>
                            </div>
                            <div class="invalid-feedback" id="usuario-error">
                                El usuario es obligatorio
                            </div>
                        </div>

                        <!-- Campo Cantidad Votantes -->
                        <div class="form-group">
                            <label for="cantidad_votantes" class="font-weight-bold">
                                <i class="text-danger">*</i> Cantidad de Votantes
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-users"></i>
                                    </span>
                                </div>
                                <input type="number" class="form-control" id="cantidad_votantes"
                                    name="cantidad_votantes" placeholder="Número de votantes asignados" min="1"
                                    required>
                            </div>
                            <div class="invalid-feedback" id="cantidad_votantes-error">
                                La cantidad de votantes es obligatoria
                            </div>
                        </div>

                        <!-- Campo Estado -->
                        <div class="form-group">
                            <label for="estado" class="font-weight-bold">
                                <i class="text-danger">*</i> Estado
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-toggle-on"></i>
                                    </span>
                                </div>
                                <select class="form-control" id="estado" name="estado" required>
                                    <option value="">Seleccione un estado...</option>
                                    <option value="A">Activo</option>
                                    <option value="I">Inactivo</option>
                                </select>
                            </div>
                            <div class="invalid-feedback" id="estado-error">
                                El estado es obligatorio
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="text-center mt-4">
                            <button type="button" id="bt_hacer_cargue" class="btn btn-success rounded-pill" disabled>
                                <i class="fa fa-save mr-2"></i>
                                Crear Mesa
                            </button>
                            <button type="button" id="bt_cancelar" class="btn btn-secondary rounded-pill ml-2">
                                <i class="fa fa-times mr-2"></i>
                                Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Los datos serán validados antes de crear la mesa.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }
</style>