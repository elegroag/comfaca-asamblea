<div class="container-fluid">
    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-plus-circle mr-2"></i>
                Crear Registro de Consensos
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Complete los datos para crear un nuevo registro de consensos.
                            Todos los campos marcados con * son obligatorios.
                        </p>
                    </div>
                </div>
            </div>

            <form id="formulario_consenso">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo NIT Empresa -->
                        <div class="form-group">
                            <label for="nit" class="font-weight-bold">
                                <i class="text-danger">*</i> NIT Empresa
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-hashtag"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="nit" name="nit"
                                    placeholder="Número de Identificación Tributaria" required>
                                <div class="input-group-append">
                                    <button type="button" id="bt_buscar_apoderado" class="btn btn-outline-primary"
                                        title="Buscar apoderado">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="invalid-feedback" id="nit-error">
                                El NIT es obligatorio
                            </div>
                        </div>

                        <!-- Campo Razón Social -->
                        <div class="form-group">
                            <label for="razsoc" class="font-weight-bold">
                                <i class="text-danger">*</i> Razón Social
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-building"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="razsoc" name="razsoc"
                                    placeholder="Razón social de la empresa" required>
                            </div>
                            <div class="invalid-feedback" id="razsoc-error">
                                La razón social es obligatoria
                            </div>
                        </div>

                        <!-- Campo Representante Legal -->
                        <div class="form-group">
                            <label for="repleg" class="font-weight-bold">
                                <i class="text-danger">*</i> Representante Legal
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user-tie"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="repleg" name="repleg"
                                    placeholder="Nombre del representante legal" required>
                            </div>
                            <div class="invalid-feedback" id="repleg-error">
                                El representante legal es obligatorio
                            </div>
                        </div>

                        <!-- Campo Concepto -->
                        <div class="form-group">
                            <label for="concepto" class="font-weight-bold">
                                <i class="text-danger">*</i> Concepto
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-file-text-o"></i>
                                    </span>
                                </div>
                                <select class="form-control" id="concepto" name="concepto" required>
                                    <option value="">Seleccione un concepto...</option>
                                    <option value="A">APORTES</option>
                                    <option value="S">SERVICIOS</option>
                                    <option value="L">LIBRANZA</option>
                                </select>
                            </div>
                            <div class="invalid-feedback" id="concepto-error">
                                El concepto es obligatorio
                            </div>
                        </div>

                        <!-- Campo Código -->
                        <div class="form-group">
                            <label for="codigo" class="font-weight-bold">
                                <i class="text-danger">*</i> Código
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-barcode"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" id="codigo" name="codigo"
                                    placeholder="Código del registro" required>
                            </div>
                            <div class="invalid-feedback" id="codigo-error">
                                El código es obligatorio
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="text-center mt-4">
                            <button type="button" id="bt_hacer_cargue" class="btn btn-success rounded-pill" disabled>
                                <i class="fa fa-save mr-2"></i>
                                Crear Registro
                            </button>
                            <button type="button" id="bt_cancelar" class="btn btn-secondary rounded-pill ml-2">
                                <i class="fa fa-times mr-2"></i>
                                Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Los datos serán validados antes de crear el registro.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }
</style>