<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6">
            <h4 class="text-xl font-semibold text-gray-800 text-center mb-6">
                <%=(isNew==true)? 'Crear Registro Consensos' : 'Editar Registro Consensos' %>
            </h4>

            <div class="flex justify-center">
                <div class="w-full max-w-lg space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Título
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-heading text-gray-500"></i>
                            </div>
                            <input type="text"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                name="titulo" placeholder='Título del consenso' />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Descripción
                        </label>
                        <div class="flex items-start border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-align-left text-gray-500"></i>
                            </div>
                            <textarea
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white resize-none"
                                name="descripcion" placeholder='Descripción del consenso' rows="3"></textarea>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Fecha de inicio
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-calendar-alt text-gray-500"></i>
                            </div>
                            <input type="date"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                name="fecha_inicio" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Fecha de fin
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-calendar-check text-gray-500"></i>
                            </div>
                            <input type="date"
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                name="fecha_fin" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Estado
                        </label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-info-circle text-gray-500"></i>
                            </div>
                            <select
                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
                                name="estado">
                                <option value="A">Activo</option>
                                <option value="I">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-8">
                    <button type='button'
                        class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        id='bt_guardar'>
                        <i class="fas fa-save mr-2"></i>
                        <%=(isNew==true)? 'Crear' : 'Guardar' %>
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-gray-50 px-6 py-3 border-t border-gray-200">
            <button type='button' id='btn_back_list'
                class="px-4 py-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>
                Volver al listado
            </button>
        </div>
    </div>
</div>