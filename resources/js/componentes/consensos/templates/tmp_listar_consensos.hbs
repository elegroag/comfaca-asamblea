<div class="container-fluid">
    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fa fa-handshake-o mr-2"></i>
                Lista de Consensos
            </h5>
            <button type="button" id="bt_crear_consenso" class="btn btn-light btn-sm rounded-pill">
                <i class="fa fa-plus mr-2"></i>
                Nuevo Consenso
            </button>
        </div>
        <div class="card-body">
            <!-- Tabla de Consensos -->
            <div class="table-responsive">
                <table class="table table-hover table-striped" id="tb_data_consensos">
                    <thead class="thead-light">
                        <tr>
                            <th>
                                <i class="fa fa-hashtag mr-1"></i>
                                ID
                            </th>
                            <th>
                                <i class="fa fa-clock-o mr-1"></i>
                                Hora Inicio
                            </th>
                            <th>
                                <i class="fa fa-hourglass-end mr-1"></i>
                                Hora Cierre
                            </th>
                            <th>
                                <i class="fa fa-info-circle mr-1"></i>
                                Detalle
                            </th>
                            <th>
                                <i class="fa fa-toggle-on mr-1"></i>
                                Estado
                            </th>
                            <th class="text-center">
                                <i class="fa fa-cogs mr-1"></i>
                                Acciones
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% _.each(consensos, function(consenso){ %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="badge badge-info mr-2">#<%=consenso.id%></span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-play-circle text-success mr-2"></i>
                                        <%=consenso.hora_inicia%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-stop-circle text-danger mr-2"></i>
                                        <%=consenso.hora_cierre_votaciones%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-file-text-o text-muted mr-2"></i>
                                        <%=consenso.detalle%>
                                    </div>
                                </td>
                                <td>
                                    <% if(consenso.estado=='A' ){ %>
                                        <span class="badge badge-success">
                                            <i class="fa fa-check-circle mr-1"></i>
                                            Activo
                                        </span>
                                        <% }else{ %>
                                            <span class="badge badge-secondary">
                                                <i class="fa fa-pause-circle mr-1"></i>
                                                Inactivo
                                            </span>
                                            <% } %>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <button type="button" data-toggle="mostrar_consenso"
                                            data-code="<%=consenso.id%>" class="btn btn-primary btn-sm rounded-circle"
                                            title="Ver detalles del consenso">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                        <button type="button" data-toggle="borrar_consenso" data-code="<%=consenso.id%>"
                                            class="btn btn-danger btn-sm rounded-circle" title="Eliminar consenso">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    #tb_data_consensos_wrapper {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        color: #111827;
    }

    #tb_data_consensos_wrapper .row {
        margin: 0;
        gap: 10px;
    }

    #tb_data_consensos_wrapper .dt-length,
    #tb_data_consensos_wrapper .dt-search {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #374151;
    }

    #tb_data_consensos_wrapper .form-select,
    #tb_data_consensos_wrapper .form-control {
        border: 1px solid #d1d5db;
        border-radius: 8px;
        min-height: 34px;
        padding: 0.35rem 0.6rem;
        font-size: 0.875rem;
        box-shadow: none;
        background: #fff;
    }

    #tb_data_consensos_wrapper .form-control:focus {
        border-color: #17a2b8;
        box-shadow: 0 0 0 3px rgba(23, 162, 184, 0.1);
    }

    #tb_data_consensos_wrapper .dataTables_paginate .paginate_button {
        border-radius: 6px;
        margin: 0 2px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
    }

    #tb_data_consensos_wrapper .dataTables_paginate .paginate_button:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    #tb_data_consensos_wrapper .dataTables_paginate .paginate_button.current {
        background: #17a2b8 !important;
        border-color: #17a2b8 !important;
        color: #fff !important;
    }

    #tb_data_consensos_wrapper .dataTables_paginate .paginate_button.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @media (max-width: 768px) {
        #tb_data_consensos_wrapper .row {
            flex-direction: column;
        }

        #tb_data_consensos_wrapper .dt-length,
        #tb_data_consensos_wrapper .dt-search {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>