<div class="container-fluid">
    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fa fa-eye mr-2"></i>
                Detalle del Consenso
            </h5>
            <button type="button" id="btn_back_list" class="btn btn-light btn-sm rounded-pill">
                <i class="fa fa-arrow-left mr-2"></i>
                Volver
            </button>
        </div>
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">
                    <!-- Card de Información del Consenso -->
                    <div class="card border-0 bg-light">
                        <div class="card-body text-center">
                            <!-- ID y Estado -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-center align-items-center gap-3">
                                    <span class="badge badge-info badge-pill">
                                        <i class="fa fa-hashtag mr-1"></i>
                                        ID: <%=consenso.id%>
                                    </span>
                                    <% if(consenso.estado=='A' ){ %>
                                        <span class="badge badge-success badge-pill">
                                            <i class="fa fa-check-circle mr-1"></i>
                                            Activo
                                        </span>
                                        <% }else{ %>
                                            <span class="badge badge-secondary badge-pill">
                                                <i class="fa fa-pause-circle mr-1"></i>
                                                Inactivo
                                            </span>
                                            <% } %>
                                </div>
                            </div>

                            <!-- Detalle Principal -->
                            <h4 class="card-title font-weight-bold text-primary mb-3">
                                <i class="fa fa-handshake-o mr-2"></i>
                                <%=consenso.detalle%>
                            </h4>

                            <!-- Información de Tiempos -->
                            <div class="row text-center mb-4">
                                <div class="col-md-6 mb-3">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <i class="fa fa-play-circle fa-2x text-success mr-3"></i>
                                        <div>
                                            <h6 class="font-weight-bold text-dark mb-1">Hora Inicio</h6>
                                            <span class="text-muted">
                                                <%=consenso.hora_inicia%>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <i class="fa fa-stop-circle fa-2x text-danger mr-3"></i>
                                        <div>
                                            <h6 class="font-weight-bold text-dark mb-1">Hora Cierre</h6>
                                            <span class="text-muted">
                                                <%=consenso.hora_cierre_votaciones%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Información Adicional -->
                            <div class="row text-center mb-4">
                                <div class="col-md-6 mb-3">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <i class="fa fa-calendar fa-2x text-muted mr-3"></i>
                                        <div>
                                            <h6 class="font-weight-bold text-dark mb-1">Fecha Creación</h6>
                                            <span class="text-muted">
                                                <% if(consenso.created_at){ %>
                                                    <%=moment(consenso.created_at).format('DD-MM-YYYY')%>
                                                        <% }else{ %>
                                                            No disponible
                                                            <% } %>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <i class="fa fa-clock-o fa-2x text-muted mr-3"></i>
                                        <div>
                                            <h6 class="font-weight-bold text-dark mb-1">Última Actualización</h6>
                                            <span class="text-muted">
                                                <% if(consenso.updated_at){ %>
                                                    <%=moment(consenso.updated_at).format('DD-MM-YYYY HH:mm')%>
                                                        <% }else{ %>
                                                            No disponible
                                                            <% } %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Switch de Estado -->
                            <div class="row justify-content-center mb-4">
                                <div class="col-auto">
                                    <div class="d-flex align-items-center">
                                        <label class="mr-3 font-weight-bold">Cambiar Estado:</label>
                                        <div class="custom-control custom-switch">
                                            <% has_checked=(consenso.estado=='A' )? 'checked' :'' %>
                                                <input type="checkbox" class="custom-control-input" id="estado_consenso"
                                                    <%=has_checked%>>
                                                <label class="custom-control-label" for="estado_consenso">
                                                    <span class="switch-label">
                                                        <% if(consenso.estado=='A' ){ %>
                                                            <i class="fa fa-check-circle text-success"></i> Activo
                                                            <% }else{ %>
                                                                <i class="fa fa-pause-circle text-secondary"></i>
                                                                Inactivo
                                                                <% } %>
                                                    </span>
                                                </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones de Acción -->
                            <div class="mt-4 pt-3 border-top">
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" id="bt_editar_consenso" class="btn btn-primary rounded-pill">
                                        <i class="fa fa-edit mr-2"></i>
                                        Editar
                                    </button>
                                    <button type="button" id="bt_borrar_consenso" class="btn btn-danger rounded-pill">
                                        <i class="fa fa-trash mr-2"></i>
                                        Eliminar
                                    </button>
                                    <button type="button" id="bt_ver_mesas" class="btn btn-info rounded-pill">
                                        <i class="fa fa-th-large mr-2"></i>
                                        Ver Mesas
                                    </button>
                                    <button type="button" id="bt_exportar" class="btn btn-success rounded-pill">
                                        <i class="fa fa-download mr-2"></i>
                                        Exportar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede cambiar el estado del consenso usando el interruptor.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-switch .custom-control-input:checked~.custom-control-label::before {
        background-color: #28a745;
        border-color: #28a745;
    }

    .custom-switch .custom-control-input:focus~.custom-control-label::before {
        box-shadow: 0 0 0 1px #fff, 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .custom-control-label {
        cursor: pointer;
    }

    .switch-label {
        font-size: 0.875rem;
        font-weight: 500;
    }

    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge-pill {
        padding-right: 0.6em;
        padding-left: 0.6em;
    }
</style>