<div class="w-full">
	<h5 class="text-xl font-semibold text-gray-800 pb-4">Detalle Usuario Asamblea</h5>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
	<!-- Columna izquierda - Información de la asamblea -->
	<div class="lg:col-span-1">
		<h6 class="text-center font-semibold text-gray-700 mb-4">
			<%=asamblea.detalle%>
		</h6>
		<div class="text-center">
			<div class="mb-4">
				<div class="inline-block">
					<img src="/images/asamblea-logo.png" alt="Logo Asamblea"
						class="w-24 h-24 rounded-full mx-auto object-cover" />
				</div>
			</div>
			<h6 class="text-center text-gray-600 mb-4">
				<%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
			</h6>

			<% if(asa_usuario==false){ %>
				<div class="text-center">
					<button
						class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors"
						id='vincular_asamblea' data-id='<%=asamblea.id%>'>
						Vincular
					</button>
				</div>
				<% }else{ %>
					<div class="text-center">
						<p class="text-gray-500 bg-gray-50 rounded-lg p-3">El usuario ya se encuentra vinculado a una
							asamblea.</p>
					</div>
					<% } %>
		</div>
	</div>

	<!-- Columna derecha - Información del usuario -->
	<div class="lg:col-span-2">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<div class="space-y-4">
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
					<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
						<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
							<i class="fas fa-user text-gray-500"></i>
						</div>
						<span class="flex-1 px-3 py-2 bg-gray-50" id='nombre'>
							<%=capitalize(usuario.nombre)%>
						</span>
					</div>
				</div>

				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Identificación</label>
					<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
						<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
							<i class="fas fa-id-card text-gray-500"></i>
						</div>
						<span class="flex-1 px-3 py-2 bg-gray-50" id='cedula'>
							<%=usuario.cedtra%>
						</span>
					</div>
				</div>
			</div>

			<div class="space-y-4">
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Estado usuario SisuWeb</label>
					<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
						<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
							<i class="fas fa-info-circle text-gray-500"></i>
						</div>
						<span class="flex-1 px-3 py-2 bg-gray-50" id='estado'>
							<%=(usuario.estado=='A' )? 'Activo' : 'Inactivo' %>
						</span>
					</div>
				</div>

				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Roles</label>
					<select
						class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
						id='userrol' name='userrol'>
						<% n=0 while (n < _.size(roles)){ if(asa_usuario.rol==n){%>
							<option selected value='<%=n%>'>
								<%=roles[n]%>
							</option>
							<% }else{%>
								<option value='<%=n%>'>
									<%=roles[n]%>
								</option>
								<%}%>
									<% n++ } %>
					</select>
				</div>
			</div>
		</div>

		<hr class="my-6 border-gray-200" />

		<h6 class="font-semibold text-gray-700 mb-4">Mesa de trabajo</h6>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<% if(mesa !==false){ %>
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Mesa detalle</label>
					<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
						<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
							<i class="fas fa-hashtag text-gray-500"></i>
						</div>
						<span class="flex-1 px-3 py-2 bg-gray-50" id='mesa_codigo'>
							<%=mesa.codigo%>
						</span>
					</div>
				</div>
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">Estado mesa</label>
					<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
						<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
							<i class="fas fa-info-circle text-gray-500"></i>
						</div>
						<span class="flex-1 px-3 py-2 bg-gray-50" id='mesa_estado'>
							<%=mesa.estado%>
						</span>
					</div>
				</div>
				<% } else { %>
					<% if(mesas_disponibles){ %>
						<div class="md:col-span-2">
							<div class="flex items-center space-x-4">
								<div class="relative">
									<input id='check_buscar_mesa' class="sr-only" type="checkbox"
										data-toggle="switch" />
									<div
										class="w-14 h-7 bg-gray-200 rounded-full relative cursor-pointer transition-colors duration-200 ease-in-out peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 peer-checked:bg-green-600">
										<div
											class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-200 ease-in-out peer-checked:translate-x-7">
										</div>
									</div>
									<span class="ml-3 text-sm text-gray-600">
										<span class="peer-checked:hidden">NO</span>
										<span class="hidden peer-checked:inline">SI</span>
									</span>
								</div>
								<div class="flex-1 px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg">
									<span class="text-sm">¿Desea ocupar mesa disponible?</span>
								</div>
							</div>
						</div>
						<% } %>
							<div class="space-y-4" data-toggle='input-crear-mesa'>
								<div>
									<label class="block text-sm font-medium text-gray-700 mb-2">Mesa detalle</label>
									<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
										<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
											<i class="fas fa-hashtag text-gray-500"></i>
										</div>
										<input
											class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
											name='mesa_codigo' id='mesa_codigo' />
									</div>
								</div>
								<div>
									<label class="block text-sm font-medium text-gray-700 mb-2">Estado mesa</label>
									<div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
										<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
											<i class="fas fa-info-circle text-gray-500"></i>
										</div>
										<select
											class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
											name='mesa_estado' id='mesa_estado'>
											<option value='A'>Activo</option>
											<option value='P'>Pendiente</option>
										</select>
									</div>
								</div>
							</div>
							<% if(mesas_disponibles){ %>
								<div class="space-y-4 hidden" data-toggle='input-selector-mesa'>
									<div>
										<label class="block text-sm font-medium text-gray-700 mb-2">Mesa detalle</label>
										<div
											class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
											<div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
												<i class="fas fa-hashtag text-gray-500"></i>
											</div>
											<select
												class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white"
												name='mesa_select_codigo' id='mesa_select_codigo'>
												<% _.each(mesas_disponibles, function(mesa_dispo){ %>
													<option value='<%=mesa_dispo.id%>'>
														<%=mesa_dispo.codigo%>
													</option>
													<% }) %>
											</select>
										</div>
									</div>
								</div>
								<% } %>
									<div class="md:col-span-2">
										<% if(asa_usuario){ %>
											<div class="text-center">
												<button
													class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors"
													id='vincular_mesa' data-id='<%=asamblea.id%>'>
													Aplicar Mesa
												</button>
											</div>
											<% } %>
									</div>
									<% } %>
										<% } %>
		</div>
	</div>
</div>