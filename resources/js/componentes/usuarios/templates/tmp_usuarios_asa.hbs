<h5 class="text-xl font-semibold text-gray-800 text-center mt-2 mb-6">Usuarios Asamblea</h5>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Columna izquierda - Información de la asamblea -->
    <div class="lg:col-span-1">
        <h6 class="text-center font-semibold text-gray-700 mb-4">
            <%=asamblea.detalle%>
        </h6>
        <div class="text-center">
            <div class="mb-4">
                <div class="inline-block">
                    <img src="/images/asamblea-logo.png" alt="Logo Asamblea"
                        class="w-24 h-24 rounded-full mx-auto object-cover" />
                </div>
            </div>
            <h6 class="text-center text-gray-600 mb-4">
                <%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
            </h6>
            <div class="text-center">
                <a href="/admin/config#asamblea"
                    class="inline-block px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                    Asamblea
                </a>
            </div>
        </div>
    </div>

    <!-- Columna derecha - Tabla de usuarios -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200" id='tb_data_usuarios_asa'>
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Identificación
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Nombre
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Estado
                            </th>
                            <th
                                class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <i class="fas fa-trash-alt text-gray-400"></i>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% _.each(usuarios, function(usuario){ %>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <%=usuario.cedtra%>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <%=capitalize(usuario.nombre)%>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if(usuario.estado=='A' ){ %>
                                        <span
                                            class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                            Activo
                                        </span>
                                        <% } else { %>
                                            <span
                                                class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                                                Inactivo
                                            </span>
                                            <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                    <button title='borrar registro' type='button' data-toggle='remove_usuario'
                                        data-code='<%=usuario.id%>'
                                        class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>