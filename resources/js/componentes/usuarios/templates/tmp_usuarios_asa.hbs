<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-warning font-weight-bold mb-0">
                <i class="fa fa-users mr-2"></i>
                Usuarios de Asamblea
            </h3>
            <p class="text-muted mb-0">Gestión de usuarios vinculados a la asamblea</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <a href="admin/config#asamblea" class="btn btn-outline-warning rounded-pill">
                    <i class="fa fa-cog mr-2"></i>
                    Configurar Asamblea
                </a>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-list mr-2"></i>
                Usuarios Vinculados
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Columna Izquierda - Información de Asamblea -->
                <div class="col-md-4">
                    <div class="card border-0 bg-light mb-4">
                        <div class="card-body text-center">
                            <!-- Imagen y Asamblea -->
                            <div class="picture-container mb-3">
                                <div class="picture text-center">
                                    <img src="asamblea-logo.png" alt="Asamblea" class="img-fluid rounded-circle"
                                        style="width: 100px; height: 100px; object-fit: cover;">
                                </div>
                                <h6 class="description text-center mt-2">
                                    <strong>
                                        <%=asamblea.detalle%>
                                    </strong>
                                </h6>
                                <p class="text-muted mb-0">
                                    <%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
                                </p>
                            </div>

                            <!-- Botón de Configuración -->
                            <div class="text-center">
                                <a href="admin/config#asamblea" class="btn btn-primary rounded-pill">
                                    <i class="fa fa-cog mr-2"></i>
                                    Asamblea
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Columna Derecha - Tabla de Usuarios -->
                <div class="col-md-8">
                    <!-- Información de la Tabla -->
                    <div class="alert alert-info border-0 bg-light mb-3">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-info-circle fa-2x mr-3"></i>
                            <div>
                                <h6 class="alert-heading mb-1">Usuarios Vinculados</h6>
                                <p class="mb-0">
                                    Lista de usuarios que están actualmente vinculados a esta asamblea.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla de Usuarios -->
                    <div class="table-responsive">
                        <table class="table table-hover table-striped" id="tb_data_usuarios_asa">
                            <thead class="thead-light">
                                <tr>
                                    <th>
                                        <i class="fa fa-id-card mr-1"></i>
                                        Identificación
                                    </th>
                                    <th>
                                        <i class="fa fa-user mr-1"></i>
                                        Nombre
                                    </th>
                                    <th>
                                        <i class="fa fa-toggle-on mr-1"></i>
                                        Estado
                                    </th>
                                    <th class="text-center">
                                        <i class="fa fa-cogs mr-1"></i>
                                        Acciones
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% _.each(usuarios, function(usuario){ %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-id-card text-muted mr-2"></i>
                                                <span class="font-weight-bold">
                                                    <%=usuario.cedtra%>
                                                </span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-user text-info mr-2"></i>
                                                <%=capitalize(usuario.nombre)%>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <% if(usuario.estado=='A' ){ %>
                                                    <span class="badge badge-success">
                                                        <i class="fa fa-check-circle mr-1"></i>
                                                        Activo
                                                    </span>
                                                    <% }else{ %>
                                                        <span class="badge badge-danger">
                                                            <i class="fa fa-times-circle mr-1"></i>
                                                            Inactivo
                                                        </span>
                                                        <% } %>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" data-toggle="remove_usuario"
                                                data-code="<%=usuario.id%>" class="btn btn-danger btn-sm rounded-circle"
                                                title="Eliminar usuario de la asamblea">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede eliminar usuarios de la asamblea haciendo clic en el botón de eliminar.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-users mr-1"></i>
                        Total de usuarios: <span class="font-weight-bold">
                            <%=usuarios.length%>
                        </span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .thead-light th {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        font-weight: 600;
        color: #495057;
    }

    .picture-container {
        position: relative;
    }

    .picture {
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #ffc107;
        margin-bottom: 1rem;
    }
</style>