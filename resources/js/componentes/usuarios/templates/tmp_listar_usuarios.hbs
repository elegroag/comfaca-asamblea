<div class="container-fluid">
	<!-- Header Principal -->
	<div class="row mb-4">
		<div class="col-md-6">
			<h3 class="text-primary font-weight-bold mb-0">
				<i class="fa fa-users mr-2"></i>
				Lista de Funcionarios
			</h3>
			<p class="text-muted mb-0">Gestión de funcionarios del sistema</p>
		</div>
		<div class="col-md-6">
			<div id="showSubnav"></div>
		</div>
	</div>

	<!-- Card Principal -->
	<div class="card shadow-sm">
		<div class="card-header bg-primary text-white">
			<h5 class="card-title mb-0">
				<i class="fa fa-list mr-2"></i>
				Funcionarios Registrados
			</h5>
		</div>
		<div class="card-body">
			<!-- Tabla de Usuarios -->
			<div class="table-responsive">
				<table class="table table-hover table-striped" id="tb_data_usuarios">
					<thead class="thead-light">
						<tr>
							<th>
								<i class="fa fa-id-card mr-1"></i>
								Cédula
							</th>
							<th>
								<i class="fa fa-user mr-1"></i>
								Nombre
							</th>
							<th>
								<i class="fa fa-key mr-1"></i>
								Código Usuario
							</th>
							<th>
								<i class="fa fa-user-tag mr-1"></i>
								Rol
							</th>
							<th class="text-center">
								<i class="fa fa-cogs mr-1"></i>
								Acciones
							</th>
						</tr>
					</thead>
					<tbody>
						<% _.each(usuarios, function(usuario){ roles={0:"Ninguno", 1:"SuperAdmin", 2:"Recepción",
							3:"Cartera", 4:"Votación", 5:"Poderes","":"Apoyo"}; %>
							<tr>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-id-card text-muted mr-2"></i>
										<span class="font-weight-bold">
											<%=usuario.cedtra%>
										</span>
									</div>
								</td>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-user text-info mr-2"></i>
										<%=capitalize(usuario.nombre)%>
									</div>
								</td>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-key text-warning mr-2"></i>
										<span class="badge badge-secondary">
											<%=usuario.usuario%>
										</span>
									</div>
								</td>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-user-tag text-primary mr-2"></i>
										<% if(usuario.rol){ %>
											<% if(usuario.rol==1){ %>
												<span class="badge badge-danger">
													<i class="fa fa-crown mr-1"></i>
													<%=roles[usuario.rol]%>
												</span>
												<% }else if(usuario.rol==2){ %>
													<span class="badge badge-info">
														<i class="fa fa-phone mr-1"></i>
														<%=roles[usuario.rol]%>
													</span>
													<% }else if(usuario.rol==3){ %>
														<span class="badge badge-success">
															<i class="fa fa-money-bill mr-1"></i>
															<%=roles[usuario.rol]%>
														</span>
														<% }else if(usuario.rol==4){ %>
															<span class="badge badge-primary">
																<i class="fa fa-vote-yea mr-1"></i>
																<%=roles[usuario.rol]%>
															</span>
															<% }else if(usuario.rol==5){ %>
																<span class="badge badge-warning">
																	<i class="fa fa-file-signature mr-1"></i>
																	<%=roles[usuario.rol]%>
																</span>
																<% }else{ %>
																	<span class="badge badge-secondary">
																		<%=roles[usuario.rol]%>
																	</span>
																	<% } %>
																		<% }else{ %>
																			<span class="badge badge-light text-dark">
																				N/A
																			</span>
																			<% } %>
									</div>
								</td>
								<td class="text-center">
									<div class="btn-group" role="group">
										<button type="button" data-toggle="editar_usuario"
											data-code="<%=usuario.usuario%>"
											class="btn btn-warning btn-sm rounded-circle" title="Editar usuario">
											<i class="fa fa-edit"></i>
										</button>
										<button type="button" data-toggle="mostrar_usuario"
											data-code="<%=usuario.usuario%>"
											class="btn btn-primary btn-sm rounded-circle"
											title="Ver detalles del usuario">
											<i class="fa fa-eye"></i>
										</button>
									</div>
								</td>
							</tr>
							<% }) %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<style>
	#tb_data_usuarios_wrapper {
		background: #ffffff;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		padding: 12px;
		color: #111827;
	}

	#tb_data_usuarios_wrapper .row {
		margin: 0;
		gap: 10px;
	}

	#tb_data_usuarios_wrapper .dt-length,
	#tb_data_usuarios_wrapper .dt-search {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 0.9rem;
		color: #374151;
	}

	#tb_data_usuarios_wrapper .form-select,
	#tb_data_usuarios_wrapper .form-control {
		border: 1px solid #d1d5db;
		border-radius: 8px;
		min-height: 34px;
		padding: 0.35rem 0.6rem;
		font-size: 0.875rem;
		box-shadow: none;
		background: #fff;
	}

	#tb_data_usuarios_wrapper .form-control:focus {
		border-color: #007bff;
		box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button {
		border-radius: 6px;
		margin: 0 2px;
		border: 1px solid #d1d5db;
		background: #fff;
		color: #374151;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button:hover {
		background: #f9fafb;
		border-color: #9ca3af;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button.current {
		background: #007bff !important;
		border-color: #007bff !important;
		color: #fff !important;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button.disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	@media (max-width: 768px) {
		#tb_data_usuarios_wrapper .row {
			flex-direction: column;
		}

		#tb_data_usuarios_wrapper .dt-length,
		#tb_data_usuarios_wrapper .dt-search {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>