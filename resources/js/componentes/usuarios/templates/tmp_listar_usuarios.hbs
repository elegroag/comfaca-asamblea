<div class="flex flex-col lg:flex-row gap-4 mb-6">
	<div class="lg:w-1/4">
		<span class="text-xl font-semibold text-blue-600">Funcionarios</span>
	</div>
	<div class="lg:w-3/4">
		<div id='showSubnav'></div>
	</div>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden">
	<div class="overflow-x-auto">
		<table class="min-w-full divide-y divide-gray-200" id='tb_data_usuarios'>
			<thead class="bg-gray-50">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Cedula
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Nombre
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Código usuario
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Rol
					</th>
					<th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
						<i class="fas fa-cog text-gray-400"></i>
					</th>
				</tr>
			</thead>
			<tbody class="bg-white divide-y divide-gray-200">
				<% _.each(usuarios, function(usuario){ roles={0:"Ninguno", 1:"SuperAdmin", 2:"Recepción", 3:"Cartera",
					4:"Votación", 5:"Poderes",'':"Apoyo"}; %>
					<tr class="hover:bg-gray-50 transition-colors">
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
							<%=usuario.cedtra%>
						</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
							<%=capitalize(usuario.nombre)%>
						</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
							<%=usuario.usuario%>
						</td>
						<td class="px-6 py-4 whitespace-nowrap">
							<% if(usuario.rol){ %>
								<% if(usuario.rol==1){ %>
									<span
										class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">
										<%=roles[usuario.rol]%>
									</span>
									<% } else if(usuario.rol==2){ %>
										<span
											class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
											<%=roles[usuario.rol]%>
										</span>
										<% } else if(usuario.rol==3){ %>
											<span
												class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
												<%=roles[usuario.rol]%>
											</span>
											<% } else if(usuario.rol==4){ %>
												<span
													class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
													<%=roles[usuario.rol]%>
												</span>
												<% } else if(usuario.rol==5){ %>
													<span
														class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
														<%=roles[usuario.rol]%>
													</span>
													<% } else { %>
														<span
															class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
															<%=roles[usuario.rol]%>
														</span>
														<% } %>
															<% } else { %>
																<span
																	class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-500">
																	N/A
																</span>
																<% } %>
						</td>
						<td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
							<div class="flex justify-center space-x-2">
								<button type='button' data-toggle='editar_usuario' data-code='<%=usuario.usuario%>'
									class="p-2 text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors"
									title="Editar usuario">
									<i class="fas fa-edit"></i>
								</button>
								<button type='button' data-toggle='mostrar_usuario' data-code='<%=usuario.usuario%>'
									class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
									title="Ver detalles">
									<i class="fas fa-eye"></i>
								</button>
							</div>
						</td>
					</tr>
					<% }) %>
			</tbody>
		</table>
	</div>
</div>