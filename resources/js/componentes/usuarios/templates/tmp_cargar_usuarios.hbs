<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="p-6">
            <h4 class="text-xl font-semibold text-gray-800 text-center mb-6">Cargue De Usuarios</h4>

            <div class="flex justify-center">
                <div class="w-full max-w-lg">
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="text-red-500">*</i> Archivo
                        </label>
                        <div toggle-error='archivo' class="error text-red-500 text-sm mt-1" for="required"></div>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                <i class="fas fa-file-alt text-gray-500"></i>
                            </div>
                            <input style='display:none' type='file' data-event='upload' name='archivo_cargar'
                                id='archivo_cargar' onchange='handleFiles()' />
                            <div class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none bg-white cursor-pointer hover:bg-gray-50 transition-colors"
                                data-toggle-file='searchfile' id='name_archivo' name="name_archivo">
                                nombre archivo
                            </div>
                            <button type='button' data-toggle-file='searchfile'
                                class="p-2 text-blue-600 hover:bg-blue-50 transition-colors border-l border-gray-300"
                                title="Buscar archivo">
                                <i class="fas fa-search"></i>
                            </button>
                            <button type='button' disabled id='remover_archivo'
                                class="p-2 text-gray-400 hover:bg-gray-50 transition-colors border-l border-gray-300 disabled:opacity-50 disabled:cursor-not-allowed"
                                title="Remover archivo">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-8">
                    <button type='button' disabled
                        class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        id='bt_hacer_cargue'>
                        <i class="fas fa-upload mr-2"></i> Continuar
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-gray-50 px-6 py-3 border-t border-gray-200">
            <!-- Footer content if needed -->
        </div>
    </div>
</div>
</div>