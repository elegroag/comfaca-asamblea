<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-success font-weight-bold mb-0">
                <i class="fa fa-user-plus mr-2"></i>
                <% if(isNew==true){ %>
                    Crear Nuevo Usuario
                    <% }else{ %>
                        Editar Usuario
                        <% } %>
            </h3>
            <p class="text-muted mb-0">Gestión de usuarios del sistema</p>
        </div>
        <div class="col-md-6">
            <div id="showSubnav"></div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-user-cog mr-2"></i>
                <% if(isNew==true){ %>
                    Crear Nuevo Usuario
                    <% }else{ %>
                        Editar Usuario
                        <% } %>
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Complete los datos para <% if(isNew==true){ %>crear un nuevo<% }else{ %>editar el<% } %>
                                        usuario.
                                        Los campos marcados con * son obligatorios.
                        </p>
                    </div>
                </div>
            </div>

            <form id="formulario_usuario">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo Usuario -->
                        <div class="form-group">
                            <label for="usuario" class="font-weight-bold">
                                <i class="text-danger">*</i> Número Usuario
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-hashtag"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="usuario" id="usuario"
                                    placeholder="Número de usuario" value="<%=usuario%>" required>
                            </div>
                            <div class="invalid-feedback" id="usuario-error">
                                El número de usuario es obligatorio
                            </div>
                        </div>

                        <!-- Campo Cédula -->
                        <div class="form-group">
                            <label for="cedtra" class="font-weight-bold">
                                <i class="text-danger">*</i> Cédula Usuario
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-id-card"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="cedtra" id="cedtra"
                                    placeholder="Número de cédula" value="<%=cedtra%>" required>
                            </div>
                            <div class="invalid-feedback" id="cedtra-error">
                                La cédula es obligatoria
                            </div>
                        </div>

                        <!-- Campo Nombre -->
                        <div class="form-group">
                            <label for="nombre" class="font-weight-bold">
                                <i class="text-danger">*</i> Nombre Usuario
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="nombre" id="nombre"
                                    placeholder="Nombre completo del usuario" value="<%=nombre%>" required>
                            </div>
                            <div class="invalid-feedback" id="nombre-error">
                                El nombre es obligatorio
                            </div>
                        </div>

                        <!-- Opción de Cambiar Clave (solo para edición) -->
                        <% if (isNew !=true){ %>
                            <div class="form-group">
                                <div class="card border-0 bg-light">
                                    <div class="card-body">
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="cambiar_clave">
                                            <label class="custom-control-label" for="cambiar_clave">
                                                <i class="fa fa-key mr-2"></i>
                                                Desea cambiar la clave del usuario
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% } %>

                                <!-- Sección de Cambio de Clave -->
                                <div id="showChangeClave" style="display: none;">
                                    <% } %>

                                        <!-- Campo Clave -->
                                        <div class="form-group">
                                            <label for="clave" class="font-weight-bold">
                                                <i class="text-danger">*</i> Clave
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-key"></i>
                                                    </span>
                                                </div>
                                                <input type="password" class="form-control" name="clave" id="clave"
                                                    placeholder="Ingrese la clave" <% if(isNew==true){ %>required<% } %>
                                                    >
                                            </div>
                                            <div class="invalid-feedback" id="clave-error">
                                                La clave es obligatoria
                                            </div>
                                        </div>

                                        <% if (isNew !=true){ %>
                                            <!-- Campo Confirmar Clave -->
                                            <div class="form-group">
                                                <label for="confirma_clave" class="font-weight-bold">
                                                    <i class="text-danger">*</i> Confirmar Clave
                                                </label>
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text">
                                                            <i class="fa fa-lock"></i>
                                                        </span>
                                                    </div>
                                                    <input type="password" class="form-control" name="confirma_clave"
                                                        id="confirma_clave" placeholder="Confirme la clave">
                                                </div>
                                                <div class="invalid-feedback" id="confirma_clave-error">
                                                    Las claves no coinciden
                                                </div>
                                            </div>

                                            <% } %>
                                </div>

                                <!-- Botones de Acción -->
                                <div class="text-center mt-4">
                                    <button type="button" class="btn btn-success rounded-pill" id="bt_guardar">
                                        <i class="fa fa-save mr-2"></i>
                                        <% if(isNew==true){ %>Crear Usuario<% }else{ %>Actualizar Usuario<% } %>
                                    </button>
                                    <button type="button" class="btn btn-secondary rounded-pill ml-2" id="bt_cancelar">
                                        <i class="fa fa-times mr-2"></i>
                                        Cancelar
                                    </button>
                                </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Los datos serán validados antes de <% if(isNew==true){ %>crear<% }else{ %>actualizar<% } %> el
                                    usuario.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }

    .custom-control-input:checked~.custom-control-label::before {
        background-color: #28a745;
        border-color: #28a745;
    }

    .custom-control-input:focus~.custom-control-label::before {
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }
</style>