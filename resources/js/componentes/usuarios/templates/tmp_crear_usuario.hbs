<div class="flex flex-col lg:flex-row gap-4 mb-6">
    <div class="lg:w-1/4">
        <h5 class="mb-4 text-lg font-semibold text-blue-600 text-center">
            <%=(isNew==true)? 'Crear Registro Usuario' : 'Editar Registro Usuario' %>
        </h5>
    </div>
    <div class="lg:w-3/4">
        <div id='showSubnav'></div>
    </div>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="p-6">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl">
                <div class="mb-6">
                    <label for="usuario" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="text-red-500">*</i> Número usuario
                    </label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                            <i class="fas fa-user text-gray-500"></i>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                            name="usuario" id='usuario' placeholder='número' value='<%=usuario%>' />
                    </div>
                </div>

                <div class="mb-6">
                    <label for="cedtra" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="text-red-500">*</i> Cedula usuario
                    </label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                            <i class="fas fa-id-card text-gray-500"></i>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                            name="cedtra" id='cedtra' placeholder='cedtra' value='<%=cedtra%>' />
                    </div>
                </div>

                <div class="mb-6">
                    <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="text-red-500">*</i> Nombre usuario
                    </label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                            <i class="fas fa-user text-gray-500"></i>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                            name="nombre" id='nombre' placeholder='nombre' value='<%=nombre%>' />
                    </div>
                </div>

                <% if (isNew !=true){%>
                    <div class="mb-6 flex items-center justify-between">
                        <label class="text-sm font-medium text-gray-700">Para cambiar clave</label>
                        <div class="relative">
                            <input type="checkbox" id='estado_poder' class="sr-only" data-toggle="switch" />
                            <div
                                class="w-14 h-7 bg-gray-200 rounded-full relative cursor-pointer transition-colors duration-200 ease-in-out peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 peer-checked:bg-blue-600">
                                <div
                                    class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-200 ease-in-out peer-checked:translate-x-7">
                                </div>
                            </div>
                            <span class="ml-3 text-sm text-gray-600">
                                <span class="peer-checked:hidden">REC</span>
                                <span class="hidden peer-checked:inline">ACT</span>
                            </span>
                        </div>
                    </div>
                    <%}%>

                        <% if (isNew !=true){%>
                            <div id='showChangeClave' class="hidden">
                                <div class="space-y-6">
                                    <div>
                                        <label for="clave" class="block text-sm font-medium text-gray-700 mb-2">
                                            <i class="text-red-500">*</i> Clave
                                        </label>
                                        <div
                                            class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                                <i class="fas fa-lock text-gray-500"></i>
                                            </div>
                                            <input type="password"
                                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                                name="clave" id='clave' placeholder='' />
                                        </div>
                                    </div>

                                    <div>
                                        <label for="confirma_clave"
                                            class="block text-sm font-medium text-gray-700 mb-2">
                                            <i class="text-red-500">*</i> Confirmar la clave
                                        </label>
                                        <div
                                            class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                            <div class="bg-gray-50 px-3 py-2 border-r border-gray-300">
                                                <i class="fas fa-lock text-gray-500"></i>
                                            </div>
                                            <input type="password"
                                                class="flex-1 px-3 py-2 border-0 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
                                                name="confirma_clave" id='confirma_clave' placeholder='' />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <%}%>
            </div>

            <div class="text-center mt-8">
                <button type='button'
                    class="px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors"
                    id='bt_guardar'>
                    <i class="fas fa-save mr-2"></i> Continuar
                </button>
            </div>
        </div>
    </div>
</div>