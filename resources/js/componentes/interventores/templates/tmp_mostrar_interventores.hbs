<!-- Título principal -->
<h5 class='text-2xl font-bold text-center text-gray-800 mt-4 mb-6'>Detalle de Interventores</h5>

<!-- Contenido principal -->
<div class='flex flex-col lg:flex-row gap-6'>
    <!-- Columna izquierda - Información de la asamblea -->
    <div class='lg:w-1/3'>
        <div class="flex flex-col items-center space-y-4">
            <!-- Título de la asamblea -->
            <h6 class='text-lg font-semibold text-center text-gray-700'>
                <span class="font-bold">
                    <%=asamblea.detalle%>
                </span>
            </h6>

            <!-- Imagen de la asamblea -->
            <div class="relative">
                <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-gray-200 shadow-lg">
                    <?= Tag::image("asamblea-logo.png", "width: 100px", "class: w-full h-full object-cover") ?>
                </div>
            </div>

            <!-- Fecha y botón de vinculación -->
            <div class="text-center space-y-3">
                <p class="text-gray-600 font-medium">
                    <%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
                </p>

                <% if(asa_usuario==false){ %>
                    <button
                        class='bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 shadow'
                        id='vincular_asamblea' data-id='<%=asamblea.id%>'>
                        Vincular
                    </button>
                    <% }else{ %>
                        <div class='bg-blue-50 px-4 py-2 rounded-lg border border-blue-200'>
                            <p class='text-blue-700 text-sm'>El usuario ya se encuentra vinculado a una asamblea.</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <!-- Columna derecha - Información del usuario y mesas -->
    <div class='lg:w-2/3'>
        <!-- Información del usuario -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <!-- Columna izquierda - Datos básicos -->
            <div class="space-y-4">
                <!-- Nombre -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                            <i class="nc-icon nc-badge text-gray-500"></i>
                        </div>
                        <span class="flex-1 px-3 py-2 bg-white text-gray-900" id='nombre'>
                            <%=capitalize(usuario.nombre)%>
                        </span>
                    </div>
                </div>

                <!-- Identificación -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Identificación</label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                            <i class="nc-icon nc-single-02 text-gray-500"></i>
                        </div>
                        <span class="flex-1 px-3 py-2 bg-white text-gray-900" id='cedula'>
                            <%=usuario.cedtra%>
                        </span>
                    </div>
                </div>

                <!-- Tipo funcionario -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tipo funcionario</label>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                            <i class="nc-icon nc-single-02 text-gray-500"></i>
                        </div>
                        <span class="flex-1 px-3 py-2 bg-white text-gray-900" id='cedula'>
                            <%=capitalize(usuario.tipo_funcionario)%>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Columna derecha - Estado y roles -->
            <div class="space-y-4">
                <!-- Estado usuario -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Estado usuario SisuWeb</label>
                    <div class="px-3 py-2 bg-white border border-gray-300 rounded-lg">
                        <% if(usuario.estado=='A' ) { %>
                            <span
                                class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                                Activo
                            </span>
                            <% } else { %>
                                <span
                                    class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                                    Inactivo
                                </span>
                                <% } %>
                    </div>
                </div>

                <!-- Roles -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Roles</label>
                    <select
                        class='w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white'
                        id='userrol' name='userrol'>
                        <% n=0 while (n < _.size(roles)){ if(asa_usuario.rol==n){%>
                            <option selected value='<%=n%>'>
                                <%=roles[n]%>
                            </option>
                            <% }else{%>
                                <option value='<%=n%>'>
                                    <%=roles[n]%>
                                </option>
                                <%}%>
                                    <% n++ } %>
                    </select>
                </div>
            </div>
        </div>

        <!-- Separador -->
        <hr class="border-gray-300 my-6" />

        <!-- Mesa de trabajo -->
        <div class="space-y-4">
            <h6 class='text-lg font-semibold text-gray-700'>
                <span class="font-bold">Mesa de trabajo</span>
            </h6>

            <% if(mesa !=false){ %>
                <!-- Mesa existente -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Mesa detalle</label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                                <i class="nc-icon nc-badge text-gray-500"></i>
                            </div>
                            <span class="flex-1 px-3 py-2 bg-white text-gray-900" id='mesa_codigo'>
                                <%=mesa.codigo%>
                            </span>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estado mesa</label>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                                <i class="nc-icon nc-single-02 text-gray-500"></i>
                            </div>
                            <span class="flex-1 px-3 py-2 bg-white text-gray-900" id='mesa_estado'>
                                <%=mesa.estado%>
                            </span>
                        </div>
                    </div>
                </div>

                <% }else{ if(mesas_disponibles){ %>
                    <!-- Opción de ocupar mesa disponible -->
                    <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
                        <div class="flex items-center space-x-3">
                            <input class="bootstrap-switch" id='check_buscar_mesa' data-handle-width="120"
                                type="checkbox" data-toggle="switch" data-on-text="SI" data-on-color="success"
                                data-off-color="danger" data-off-text="NO" />
                            <span class="text-gray-700 font-medium">¿Desea ocupar mesa disponible?</span>
                        </div>
                    </div>
                    <% } %>

                        <!-- Formulario de crear mesa -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-toggle='input-crear-mesa'>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Mesa detalle</label>
                                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                    <div
                                        class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                                        <i class="nc-icon nc-badge text-gray-500"></i>
                                    </div>
                                    <input class="flex-1 px-3 py-2 bg-white border-0 focus:ring-0" name='mesa_codigo'
                                        id='mesa_codigo' placeholder="Código de mesa" />
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Estado mesa</label>
                                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                    <div
                                        class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                                        <i class="nc-icon nc-single-02 text-gray-500"></i>
                                    </div>
                                    <select class="flex-1 px-3 py-2 bg-white border-0 focus:ring-0" name='mesa_estado'
                                        id='mesa_estado'>
                                        <option value='A'>Activo</option>
                                        <option value='P'>Pendiente</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <% if(mesas_disponibles){ %>
                            <!-- Selector de mesa disponible -->
                            <div class="md:col-span-2" data-toggle='input-selector-mesa' style='display:none'>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Seleccionar mesa
                                    disponible</label>
                                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                                    <div
                                        class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                                        <i class="nc-icon nc-badge text-gray-500"></i>
                                    </div>
                                    <select class="flex-1 px-3 py-2 bg-white border-0 focus:ring-0"
                                        name='mesa_select_codigo' id='mesa_select_codigo'>
                                        <% _.each(mesas_disponibles, function(mesa_dispo){ %>
                                            <option value='<%=mesa_dispo.id%>'>
                                                <%=mesa_dispo.codigo%>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>
                            </div>

                            <!-- Botón de aplicar mesa -->
                            <div class="flex justify-center">
                                <% if(asa_usuario){ %>
                                    <button
                                        class='bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors duration-200 shadow'
                                        id='vincular_mesa' data-id='<%=asamblea.id%>'>
                                        Aplicar Mesa
                                    </button>
                                    <% } %>
                            </div>
                            <% } %>
                                <% } %>
        </div>
    </div>
</div>