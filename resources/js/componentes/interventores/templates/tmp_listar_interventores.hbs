<!-- Contenedor de tabla -->
<div class="overflow-x-auto shadow-lg rounded-lg">
    <table class="min-w-full bg-white border border-gray-200" id='tb_data_usuarios'>
        <!-- Header de la tabla -->
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Cedula
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Nit
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Email
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Puede votar
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Representante legal
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Tipo
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Fecha
                </th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Acciones
                </th>
            </tr>
        </thead>

        <!-- Cuerpo de la tabla -->
        <tbody class="bg-white divide-y divide-gray-200">
            <% _.each(interventores, function(interventor){ %>
                <tr class="hover:bg-gray-50 transition-colors duration-150">
                    <!-- Cedula -->
                    <td class="px-4 py-3 text-sm text-gray-900 font-medium">
                        <%=interventor.cedrep%>
                    </td>

                    <!-- Nit -->
                    <td class="px-4 py-3 text-sm text-gray-900">
                        <%=interventor.nit%>
                    </td>

                    <!-- Email -->
                    <td class="px-4 py-3 text-sm text-gray-600">
                        <%=capitalize(interventor.correo)%>
                    </td>

                    <!-- Puede votar -->
                    <td class="px-4 py-3 text-sm">
                        <% if(interventor.puedevotar==='S' || interventor.puedevotar==='SI' ) { %>
                            <span
                                class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                                Sí
                            </span>
                            <% } else { %>
                                <span
                                    class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                                    No
                                </span>
                                <% } %>
                    </td>

                    <!-- Representante legal -->
                    <td class="px-4 py-3 text-sm text-gray-600">
                        <%=capitalize(interventor.repleg)%>
                    </td>

                    <!-- Tipo -->
                    <td class="px-4 py-3 text-sm">
                        <span
                            class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
                        <% if(interventor.tipo === 'INTERVENTOR') { %>bg-blue-100 text-blue-800<% } else if(interventor.tipo === 'APODERADO') { %>bg-purple-100 text-purple-800<% } else { %>bg-gray-100 text-gray-800<% } %>">
                            <%=interventor.tipo%>
                        </span>
                    </td>

                    <!-- Fecha -->
                    <td class="px-4 py-3 text-sm text-gray-600">
                        <%=interventor.create_at%>
                    </td>

                    <!-- Acciones -->
                    <td class="px-4 py-3 text-sm text-center">
                        <button data-code='<%=interventor.id%>'
                            class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded text-xs font-medium transition-colors duration-200"
                            type='button' data-toggle='mostrar_usuario'>
                            <i class="nc-icon nc-tap-01 mr-1"></i>
                            Ver
                        </button>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>
</div>