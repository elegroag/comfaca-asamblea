<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card shadow-sm" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h2 class="h3 mb-3 font-weight-bold text-dark">
                    Iniciar Sesión
                </h2>
                <p class="text-muted small">
                    O
                    <a href="#" id="register-link" class="font-weight-bold text-primary">
                        regístrate
                    </a>
                </p>
            </div>
            <form id="login-form">
                <div class="form-group">
                    <label for="email" class="sr-only">Email</label>
                    <input id="email" name="email" type="email" autocomplete="email" required
                        class="form-control form-control-top" placeholder="Email">
                    <div id="email-error" class="invalid-feedback d-none"></div>
                </div>
                <div class="form-group">
                    <label for="password" class="sr-only">Contraseña</label>
                    <input id="password" name="password" type="password" autocomplete="current-password" required
                        class="form-control form-control-bottom" placeholder="Contraseña">
                    <div id="password-error" class="invalid-feedback d-none"></div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input id="remember" name="remember" type="checkbox"
                            class="form-check-input">
                        <label for="remember" class="form-check-label small">
                            Recordarme
                        </label>
                    </div>

                    <div class="small">
                        <a href="#" id="forgot-password-link" class="font-weight-bold text-primary">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" id="login-btn"
                        class="btn btn-primary btn-block">
                        <i class="fas fa-lock mr-2"></i>
                        Iniciar Sesión
                    </button>
                </div>

                <div class="text-center">
                    <button type="button" id="toggle-password" class="btn btn-link text-muted small">
                        <i class="fas fa-eye mr-1"></i> Mostrar contraseña
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>