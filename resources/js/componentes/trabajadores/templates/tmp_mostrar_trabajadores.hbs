<div class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-6">
        <h5 class='text-xl font-bold text-center text-gray-800 mb-6'>Detalle de Trabajadores</h5>

        <div class='grid grid-cols-1 lg:grid-cols-3 gap-6'>
            <div class='lg:col-span-1'>
                <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                    <div class="p-6 text-center">
                        <h6 class='text-lg font-semibold text-gray-800 mb-4'><b>
                                <%=asamblea.detalle%>
                            </b></h6>
                        <div class="mb-6">
                            <div class="flex justify-center">
                                <?= Tag::image("asamblea-logo.png", "width: 100px", "class: picture-src") ?>
                            </div>
                        </div>
                        <h6 class="text-sm text-gray-600 mb-6">
                            <%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
                        </h6>
                        <% if(asa_usuario==false){ %>
                            <div class='text-center'>
                                <button
                                    class='px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-all duration-200 transform hover:scale-105'
                                    id='vincular_asamblea' data-id='<%=asamblea.id%>'>
                                    Vincular
                                </button>
                            </div>
                            <% }else{ %>
                                <div class='text-center'>
                                    <p class='text-blue-600 text-sm'>El usuario ya se encuentra vinculado a una
                                        asamblea.</p>
                                </div>
                                <% } %>
                    </div>
                </div>
            </div>

            <div class='lg:col-span-2'>
                <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <div class='space-y-4'>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
                                        <div class="flex">
                                            <div class="flex-shrink-0">
                                                <div
                                                    class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                    <i class="fas fa-user text-gray-600"></i>
                                                </div>
                                            </div>
                                            <span
                                                class="flex-1 px-3 py-2 border border-gray-300 bg-gray-50 rounded-r-md"
                                                id='nombre'>
                                                <%=capitalize(usuario.nombre)%>
                                            </span>
                                        </div>
                                    </div>

                                    <div>
                                        <label
                                            class="block text-sm font-medium text-gray-700 mb-2">Identificación</label>
                                        <div class="flex">
                                            <div class="flex-shrink-0">
                                                <div
                                                    class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                    <i class="fas fa-id-card text-gray-600"></i>
                                                </div>
                                            </div>
                                            <span
                                                class="flex-1 px-3 py-2 border border-gray-300 bg-gray-50 rounded-r-md font-mono"
                                                id='cedula'>
                                                <%=usuario.cedtra%>
                                            </span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Tipo
                                            funcionario</label>
                                        <div class="flex">
                                            <div class="flex-shrink-0">
                                                <div
                                                    class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                    <i class="fas fa-briefcase text-gray-600"></i>
                                                </div>
                                            </div>
                                            <span
                                                class="flex-1 px-3 py-2 border border-gray-300 bg-gray-50 rounded-r-md"
                                                id='cedula'>
                                                <%=capitalize(usuario.tipo_funcionario)%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class='space-y-4'>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Estado usuario
                                            SisuWeb</label>
                                        <span class="block px-3 py-2 border border-gray-300 bg-gray-50 rounded-md"
                                            id='estado'>
                                            <% if(usuario.estado=='A' ){ %>
                                                <span
                                                    class="inline-flex px-2 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full">Activo</span>
                                                <% } else { %>
                                                    <span
                                                        class="inline-flex px-2 py-1 text-xs font-semibold text-red-800 bg-red-100 rounded-full">Inactivo</span>
                                                    <% } %>
                                        </span>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Roles</label>
                                        <select
                                            class='w-full px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-md'
                                            id='userrol' name='userrol'>
                                            <% n=0 while (n < _.size(roles)){ if(asa_usuario.rol==n){%>
                                                <option selected value='<%=n%>'>
                                                    <%=roles[n]%>
                                                </option>
                                                <% }else{%>
                                                    <option value='<%=n%>'>
                                                        <%=roles[n]%>
                                                    </option>
                                                    <%}%>
                                                        <% n++ } %>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-6 border-gray-200" />

                        <h6 class='text-lg font-semibold text-gray-800 mb-4'><b>Mesa de trabajo</b></h6>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% if(mesa !=false){ %>
                                <div>
                                    <div class='space-y-4'>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-2">Mesa
                                                detalle</label>
                                            <div class="flex">
                                                <div class="flex-shrink-0">
                                                    <div
                                                        class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                        <i class="fas fa-table text-gray-600"></i>
                                                    </div>
                                                </div>
                                                <span
                                                    class="flex-1 px-3 py-2 border border-gray-300 bg-gray-50 rounded-r-md"
                                                    id='mesa_codigo'>
                                                    <%=mesa.codigo%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Estado mesa</label>
                                        <div class="flex">
                                            <div class="flex-shrink-0">
                                                <div
                                                    class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                    <i class="fas fa-info-circle text-gray-600"></i>
                                                </div>
                                            </div>
                                            <span
                                                class="flex-1 px-3 py-2 border border-gray-300 bg-gray-50 rounded-r-md"
                                                id='mesa_estado'>
                                                <%=mesa.estado%>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <% }else{ if(mesas_disponibles){%>
                                    <div class="md:col-span-2">
                                        <div class="flex items-center space-x-3 mb-4">
                                            <input
                                                class="w-4 h-4 text-blue-600 focus:ring-blue-500 rounded border-gray-300"
                                                id='check_buscar_mesa' type="checkbox" />
                                            <label for="check_buscar_mesa" class="text-sm text-gray-700">¿Desea ocupar
                                                mesa disponible?</label>
                                        </div>
                                    </div>
                                    <% } %>
                                        <div class="space-y-4" data-toggle='input-crear-mesa'>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-2">Mesa
                                                    detalle</label>
                                                <div class="flex">
                                                    <div class="flex-shrink-0">
                                                        <div
                                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                            <i class="fas fa-table text-gray-600"></i>
                                                        </div>
                                                    </div>
                                                    <input
                                                        class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-md"
                                                        name='mesa_codigo' id='mesa_codigo' />
                                                </div>
                                            </div>
                                        </div>
                                        <div data-toggle='input-crear-mesa'>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-2">Estado
                                                    mesa</label>
                                                <div class="flex">
                                                    <div class="flex-shrink-0">
                                                        <div
                                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                            <i class="fas fa-info-circle text-gray-600"></i>
                                                        </div>
                                                    </div>
                                                    <select
                                                        class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-md"
                                                        name='mesa_estado' id='mesa_estado'>
                                                        <option value='A'>Activo</option>
                                                        <option value='P'>Pendiente</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <% if(mesas_disponibles){ %>
                                            <div class="md:col-span-2 hidden" data-toggle='input-selector-mesa'>
                                                <div>
                                                    <label class="block text-sm font-medium text-gray-700 mb-2">Mesa
                                                        detalle</label>
                                                    <div class="flex">
                                                        <div class="flex-shrink-0">
                                                            <div
                                                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                                <i class="fas fa-table text-gray-600"></i>
                                                            </div>
                                                        </div>
                                                        <select
                                                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-md"
                                                            name='mesa_select_codigo' id='mesa_select_codigo'>
                                                            <% _.each(mesas_disponibles, function(mesa_dispo){ %>
                                                                <option value='<%=mesa_dispo.id%>'>
                                                                    <%=mesa_dispo.codigo%>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="md:col-span-2">
                                                <% if(asa_usuario){ %>
                                                    <div class='text-center mt-4'>
                                                        <button
                                                            class='px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-all duration-200 transform hover:scale-105'
                                                            id='vincular_mesa' data-id='<%=asamblea.id%>'>
                                                            Aplicar Mesa
                                                        </button>
                                                    </div>
                                                    <% } %>
                                            </div>
                                            <% } %>
                                                <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>