<div class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-6">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl space-y-4">
                <div class='form-group hidden'>
                    <label for="id" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> ID
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-hashtag text-gray-600"></i>
                            </div>
                        </div>
                        <input type="number"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-md"
                            name="id" id='id' placeholder='número' value='<%=id%>' />
                    </div>
                </div>

                <div class='form-group'>
                    <label for="cedula" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Cedula trabajador
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-id-card text-gray-600"></i>
                            </div>
                        </div>
                        <input type="number"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-md"
                            name="cedula" id='cedula' placeholder='cedula' value='<%=cedula%>' />
                    </div>
                </div>

                <div class='form-group'>
                    <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Nombre trabajador
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-user text-gray-600"></i>
                            </div>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-md"
                            name="nombre" id='nombre' placeholder='nombre' value='<%=nombre%>' />
                    </div>
                </div>

                <div class='form-group'>
                    <label for="nittra" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> NIT
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-building text-gray-600"></i>
                            </div>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-md"
                            name="nittra" id='nittra' placeholder='nit' value='<%=nittra%>' />
                    </div>
                </div>

                <div class='form-group'>
                    <label for="razontra" class="block text-sm font-medium text-gray-700 mb-2">
                        <i class='text-red-500'>*</i> Razon social
                    </label>
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <div
                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                <i class="fas fa-building text-gray-600"></i>
                            </div>
                        </div>
                        <input type="text"
                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-md"
                            name="razontra" id='razontra' placeholder='razontra' value='<%=razontra%>' />
                    </div>
                </div>
            </div>
        </div>

        <div class='mt-8'>
            <div class='text-center'>
                <button type='button'
                    class='px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 focus:ring-4 focus:ring-green-300 transition-all duration-200 transform hover:scale-105'
                    id='bt_guardar'>
                    <i class="fas fa-play mr-2"></i>
                    Continuar
                </button>
            </div>
        </div>
    </div>
</div>