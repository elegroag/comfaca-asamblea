<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-success font-weight-bold mb-0">
                <i class="fa fa-plus-circle mr-2"></i>
                <% if(id && id> 0){ %>
                    Editar Trabajador
                    <% }else{ %>
                        Crear Nuevo Trabajador
                        <% } %>
            </h3>
            <p class="text-muted mb-0">Gestión de trabajadores del sistema</p>
        </div>
        <div class="col-md-6">
            <div id="showSubnav"></div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-user-plus mr-2"></i>
                <% if(id && id> 0){ %>
                    Editar Trabajador
                    <% }else{ %>
                        Crear Nuevo Trabajador
                        <% } %>
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Complete los datos para <% if(id && id> 0){ %>editar el<% }else{ %>crear un nuevo<% } %>
                                        trabajador.
                                        Los campos marcados con * son obligatorios.
                        </p>
                    </div>
                </div>
            </div>

            <form id="formulario_trabajador">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo ID (oculto) -->
                        <div class="form-group" style="display: none;">
                            <label for="id" class="font-weight-bold">
                                <i class="text-danger">*</i> ID
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-hashtag"></i>
                                    </span>
                                </div>
                                <input type="number" class="form-control" name="id" id="id" placeholder="Número"
                                    value="<%=id%>">
                            </div>
                        </div>

                        <!-- Campo Cédula -->
                        <div class="form-group">
                            <label for="cedula" class="font-weight-bold">
                                <i class="text-danger">*</i> Cédula Trabajador
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-id-card"></i>
                                    </span>
                                </div>
                                <input type="number" class="form-control" name="cedula" id="cedula"
                                    placeholder="Número de cédula" value="<%=cedula%>" required>
                            </div>
                            <div class="invalid-feedback" id="cedula-error">
                                La cédula es obligatoria
                            </div>
                        </div>

                        <!-- Campo Nombre -->
                        <div class="form-group">
                            <label for="nombre" class="font-weight-bold">
                                <i class="text-danger">*</i> Nombre Trabajador
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="nombre" id="nombre"
                                    placeholder="Nombre completo del trabajador" value="<%=nombre%>" required>
                            </div>
                            <div class="invalid-feedback" id="nombre-error">
                                El nombre es obligatorio
                            </div>
                        </div>

                        <!-- Campo NIT -->
                        <div class="form-group">
                            <label for="nittra" class="font-weight-bold">
                                <i class="text-danger">*</i> NIT Empresa
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-building"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="nittra" id="nittra"
                                    placeholder="Número de Identificación Tributaria" value="<%=nittra%>" required>
                            </div>
                            <div class="invalid-feedback" id="nittra-error">
                                El NIT es obligatorio
                            </div>
                        </div>

                        <!-- Campo Razón Social -->
                        <div class="form-group">
                            <label for="razontra" class="font-weight-bold">
                                <i class="text-danger">*</i> Razón Social
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-industry"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="razontra" id="razontra"
                                    placeholder="Razón social de la empresa" value="<%=razontra%>" required>
                            </div>
                            <div class="invalid-feedback" id="razontra-error">
                                La razón social es obligatoria
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="text-center mt-4">
                            <button type="button" class="btn btn-success rounded-pill" id="bt_guardar">
                                <i class="fa fa-save mr-2"></i>
                                <% if(id && id> 0){ %>Actualizar Trabajador<% }else{ %>Crear Trabajador<% } %>
                            </button>
                            <button type="button" class="btn btn-secondary rounded-pill ml-2" id="bt_cancelar">
                                <i class="fa fa-times mr-2"></i>
                                Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Los datos serán validados antes de <% if(id && id> 0){ %>actualizar<% }else{ %>crear<% } %> el
                                    trabajador.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }

    .form-check-input:checked {
        background-color: #28a745;
        border-color: #28a745;
    }

    .form-check-input:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }
</style>