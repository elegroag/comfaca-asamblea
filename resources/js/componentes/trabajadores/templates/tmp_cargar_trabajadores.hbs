<div class="container-fluid">
    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-upload mr-2"></i>
                Cargue Masivo de Trabajadores
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Seleccione un archivo para cargar trabajadores de forma masiva.
                            El archivo debe estar en formato CSV con la estructura adecuada.
                        </p>
                    </div>
                </div>
            </div>

            <form id="formulario_carga_trabajadores">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo de Archivo -->
                        <div class="form-group">
                            <label for="archivo_cargue" class="font-weight-bold">
                                <i class="text-danger">*</i> Archivo de Trabajadores
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-file-excel-o"></i>
                                    </span>
                                </div>
                                <input type="file" class="d-none" id="archivo_cargue" name="archivo_cargue"
                                    data-event="upload" onchange="handleFiles()" accept=".csv,.xlsx,.xls">
                                <div class="form-control" data-toggle-file="searchfile" id="name_archivo"
                                    name="name_archivo" style="line-height: 2; cursor: pointer;">
                                    <i class="fa fa-file-upload mr-2"></i>
                                    <span id="file-name-text">Seleccione un archivo...</span>
                                </div>
                                <div class="input-group-append">
                                    <button type="button" data-toggle-file="searchfile" class="btn btn-outline-primary"
                                        title="Buscar archivo">
                                        <i class="fa fa-search"></i>
                                    </button>
                                    <button type="button" id="remover_archivo" class="btn btn-outline-danger" disabled
                                        title="Remover archivo">
                                        <i class="fa fa-times"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="invalid-feedback" id="archivo-error">
                                Debe seleccionar un archivo válido
                            </div>
                            <small class="form-text text-muted">
                                Formatos aceptados: CSV, Excel (.xlsx, .xls)
                            </small>
                        </div>

                        <!-- Instrucciones del Formato -->
                        <div class="form-group">
                            <div class="alert alert-warning border-0 bg-light">
                                <div class="d-flex align-items-start">
                                    <i class="fa fa-exclamation-triangle fa-2x mr-3"></i>
                                    <div>
                                        <h6 class="alert-heading mb-2">Formato del Archivo</h6>
                                        <p class="mb-2">
                                            El archivo debe ser CSV separado por punto y coma (;) con las siguientes
                                            columnas en este orden:
                                        </p>
                                        <ol class="mb-0 small">
                                            <li><strong>Columna 1</strong> - Cédula</li>
                                            <li><strong>Columna 2</strong> - Nombre</li>
                                            <li><strong>Columna 3</strong> - NIT Empresa</li>
                                            <li><strong>Columna 4</strong> - Razón Social</li>
                                        </ol>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Campo Validación -->
                        <div class="form-group mt-4">
                            <label class="font-weight-bold mb-2">
                                <i class="fa fa-cogs mr-1"></i>
                                Opciones de Procesamiento
                            </label>
                            <div class="card border-0 bg-light">
                                <div class="card-body">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="cruzar_data"
                                            name="cruzar_data" value="1">
                                        <label class="form-check-label" for="cruzar_data">
                                            <i class="fa fa-check-square mr-2"></i>
                                            Cruzar con base de empresas y pre-registros
                                        </label>
                                    </div>
                                    <small class="text-muted">
                                        <i class="fa fa-info-circle mr-1"></i>
                                        Marque esta opción para validar los datos contra las bases existentes
                                    </small>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="text-center mt-4">
                            <button type="button" id="bt_hacer_cargue" class="btn btn-warning rounded-pill" disabled>
                                <i class="fa fa-upload mr-2"></i>
                                Cargar Trabajadores
                            </button>
                            <button type="button" id="bt_cancelar" class="btn btn-secondary rounded-pill ml-2">
                                <i class="fa fa-times mr-2"></i>
                                Cancelar
                            </button>
                        </div>

                        <!-- Progreso de Carga -->
                        <div id="progress-container" class="mt-4" style="display: none;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="font-weight-bold">Progreso:</span>
                                <span id="progress-text">0%</span>
                            </div>
                            <div class="progress">
                                <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated"
                                    role="progressbar" style="width: 0%">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        El archivo será procesado y los trabajadores serán agregados al sistema.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
    }

    .btn-warning {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #212529;
    }

    .btn-warning:hover:not(:disabled) {
        background-color: #e0a800;
        border-color: #d39e00;
        color: #212529;
    }

    .progress-bar-animated {
        background-image: linear-gradient(45deg, rgba(255, 255, 255, .15) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, .15) 50%, rgba(255, 255, 255, .15) 75%, transparent 75%, transparent);
        background-size: 1rem 1rem;
        animation: progress-bar-stripes 1s linear infinite;
    }

    @keyframes progress-bar-stripes {
        0% {
            background-position: 1rem 0;
        }

        100% {
            background-position: 0 0;
        }
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    #name_archivo:hover {
        background-color: #f8f9fa;
    }

    .form-check-input:checked {
        background-color: #ffc107;
        border-color: #ffc107;
    }

    .form-check-input:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
    }
</style>