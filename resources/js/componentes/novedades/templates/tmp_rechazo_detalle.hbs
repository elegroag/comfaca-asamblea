<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-danger font-weight-bold mb-0">
                <i class="fa fa-times-circle mr-2"></i>
                Detalle de Rechazo
            </h3>
            <p class="text-muted mb-0">Información completa del rechazo</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="btn_back_list" class="btn btn-outline-danger rounded-pill">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Volver
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-info-circle mr-2"></i>
                Información del Rechazo
            </h5>
        </div>
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">
                    <!-- Card de Información Principal -->
                    <div class="card border-0 bg-light mb-4">
                        <div class="card-body">
                            <div class="row">
                                <!-- Columna Izquierda -->
                                <div class="col-md-6">
                                    <!-- Número Radicado -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-hashtag mr-1"></i>
                                            Número Radicado
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-file-text"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="radicado"
                                                    value="<%=novedad.id%>" />
                                                <span class="font-weight-bold text-danger">
                                                    <%=novedad.id%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Novedad Estructura -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-code mr-1"></i>
                                            Novedad Estructura
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-list-alt"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="estructura"
                                                    value="<%=novedad.estructura%>" />
                                                <span class="font-weight-bold">
                                                    <%=novedad.estructura%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna Derecha -->
                                <div class="col-md-6">
                                    <!-- Novedad Línea -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-code mr-1"></i>
                                            Novedad Línea
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-list-alt"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="linea"
                                                    value="<%=novedad.linea%>" />
                                                <span class="font-weight-bold">
                                                    <%=novedad.linea%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Estado -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-toggle-on mr-1"></i>
                                            Estado
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-info-circle"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="estado"
                                                    value="<%=novedad.estado%>" />
                                                <% if(novedad.estado=='A' ){ %>
                                                    <span class="badge badge-success">
                                                        <i class="fa fa-check-circle mr-1"></i>
                                                        Activo
                                                    </span>
                                                    <% }else{ %>
                                                        <span class="badge badge-secondary">
                                                            <i class="fa fa-pause-circle mr-1"></i>
                                                            Inactivo
                                                        </span>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Alerta de Rechazo -->
                    <div class="alert alert-danger border-0 bg-light mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-exclamation-triangle fa-2x mr-3"></i>
                            <div>
                                <h6 class="alert-heading mb-1">Información de Rechazo</h6>
                                <p class="mb-0">
                                    Esta novedad ha sido rechazada y requiere atención especial.
                                    Por favor revise los detalles y tome las acciones necesarias.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div class="text-center">
                        <button type="button" data-cid="<%=novedad.id%>" class="btn btn-warning rounded-pill btn-lg"
                            id="bt_procesar">
                            <i class="fa fa-cogs mr-2"></i>
                            Procesar Rechazo
                        </button>
                        <button type="button" class="btn btn-secondary rounded-pill btn-lg ml-2" id="bt_cancelar">
                            <i class="fa fa-times mr-2"></i>
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede procesar el rechazo para corregir los problemas detectados.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }
</style>