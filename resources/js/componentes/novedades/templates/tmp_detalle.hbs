<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-primary font-weight-bold mb-0">
                <i class="fa fa-file-text-o mr-2"></i>
                Detalle de Novedad
            </h3>
            <p class="text-muted mb-0">Información completa de la novedad</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="btn_back_list" class="btn btn-outline-primary rounded-pill">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Volver
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-info-circle mr-2"></i>
                Información de la Novedad
            </h5>
        </div>
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">
                    <!-- Card de Información Principal -->
                    <div class="card border-0 bg-light mb-4">
                        <div class="card-body">
                            <div class="row">
                                <!-- Columna Izquierda -->
                                <div class="col-md-6">
                                    <!-- Número Radicado -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-hashtag mr-1"></i>
                                            Número Radicado
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-file-text"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="radicado"
                                                    value="<%=novedad.id%>" />
                                                <span class="font-weight-bold text-primary">
                                                    <%=novedad.id%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Novedad Línea -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-code mr-1"></i>
                                            Novedad Línea
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-list-alt"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="linea"
                                                    value="<%=novedad.linea%>" />
                                                <span class="font-weight-bold">
                                                    <%=novedad.linea%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Columna Derecha -->
                                <div class="col-md-6">
                                    <!-- Estado -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-toggle-on mr-1"></i>
                                            Estado
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-info-circle"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="estado"
                                                    value="<%=novedad.estado%>" />
                                                <% if(novedad.estado=='A' ){ %>
                                                    <span class="badge badge-success">
                                                        <i class="fa fa-check-circle mr-1"></i>
                                                        Activo
                                                    </span>
                                                    <% }else{ %>
                                                        <span class="badge badge-secondary">
                                                            <i class="fa fa-pause-circle mr-1"></i>
                                                            Inactivo
                                                        </span>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Enviado Plataforma -->
                                    <div class="form-group mb-3">
                                        <label class="font-weight-bold text-muted">
                                            <i class="fa fa-cloud-upload mr-1"></i>
                                            Enviado a Plataforma
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-sync"></i>
                                                </span>
                                            </div>
                                            <div class="form-control bg-white">
                                                <input type="text" class="d-none" name="syncro"
                                                    value="<%=novedad.syncro%>" />
                                                <% if(novedad.syncro=='S' ){ %>
                                                    <span class="badge badge-info">
                                                        <i class="fa fa-check mr-1"></i>
                                                        Sincronizado
                                                    </span>
                                                    <% }else{ %>
                                                        <span class="badge badge-warning">
                                                            <i class="fa fa-clock-o mr-1"></i>
                                                            Pendiente
                                                        </span>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card de Estructura -->
                    <div class="card border-0 bg-light mb-4">
                        <div class="card-header bg-white">
                            <h6 class="card-title mb-0">
                                <i class="fa fa-table mr-2"></i>
                                Estructura de Datos
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>
                                                <i class="fa fa-building mr-1"></i>
                                                NIT
                                            </th>
                                            <th>
                                                <i class="fa fa-industry mr-1"></i>
                                                Razón Social
                                            </th>
                                            <th>
                                                <i class="fa fa-id-card mr-1"></i>
                                                Ced. Representante
                                            </th>
                                            <th>
                                                <i class="fa fa-user-tie mr-1"></i>
                                                Nombre Representante
                                            </th>
                                            <th>
                                                <i class="fa fa-user mr-1"></i>
                                                Apoderado NIT
                                            </th>
                                            <th>
                                                <i class="fa fa-id-badge mr-1"></i>
                                                Apoderado Cédula
                                            </th>
                                            <th>
                                                <i class="fa fa-user-circle mr-1"></i>
                                                Apoderado Nombre
                                            </th>
                                            <th>
                                                <i class="fa fa-key mr-1"></i>
                                                Clave
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold">
                                                <span class="badge badge-primary">
                                                    <%=novedad.nit%>
                                                </span>
                                            </td>
                                            <td>
                                                <%=novedad.razon_social%>
                                            </td>
                                            <td>
                                                <%=novedad.cedula_representante%>
                                            </td>
                                            <td>
                                                <%=novedad.nombre_representante%>
                                            </td>
                                            <td>
                                                <%=novedad.apoderado_nit%>
                                            </td>
                                            <td>
                                                <%=novedad.apoderado_cedula%>
                                            </td>
                                            <td>
                                                <%=novedad.apoderado_nombre%>
                                            </td>
                                            <td>
                                                <span class="text-muted">
                                                    <%=novedad.clave%>
                                                </span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div class="text-center">
                        <button type="button" data-cid="<%=novedad.id%>" class="btn btn-success rounded-pill btn-lg"
                            id="bt_procesar">
                            <i class="fa fa-cogs mr-2"></i>
                            Procesar Novedad
                        </button>
                        <button type="button" class="btn btn-secondary rounded-pill btn-lg ml-2" id="bt_cancelar">
                            <i class="fa fa-times mr-2"></i>
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede procesar la novedad para sincronizarla con la plataforma.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .badge {
        font-size: 0.875rem;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }
</style>