<!-- Header con navegación -->
<div class="flex flex-col lg:flex-row justify-between items-center mb-6">
    <div class="lg:w-1/3">
        <h3 class="text-xl font-bold text-blue-600">Detalle Novedad</h3>
    </div>
    <div class="lg:w-2/3 lg:flex justify-end">
        <div class="flex justify-end">
            <button href='#'
                class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 shadow flex items-center gap-2"
                id='btn_back_list'>
                <i class="fa fa-heart"></i>
                Salir
            </button>
        </div>
    </div>
</div>

<!-- Contenedor principal -->
<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-lg shadow-lg p-6">
        <!-- Formulario de detalles -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <!-- Número radicado -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Número radicado:</label>
                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                    <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                        <i class="nc-icon nc-alert-circle-i text-gray-500"></i>
                    </div>
                    <div class="flex-1 px-3 py-2 bg-white text-gray-900 font-medium">
                        <%=novedad.id%>
                    </div>
                </div>
            </div>

            <!-- Novedad linea -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Novedad linea:</label>
                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                    <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                        <i class="nc-icon nc-badge text-gray-500"></i>
                    </div>
                    <div class="flex-1 px-3 py-2 bg-white text-gray-900 font-medium">
                        <%=novedad.linea%>
                    </div>
                </div>
            </div>

            <!-- Estado -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Estado:</label>
                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                    <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                        <i class="nc-icon nc-single-02 text-gray-500"></i>
                    </div>
                    <div class="flex-1 px-3 py-2 bg-white text-gray-900 font-medium">
                        <%=novedad.estado%>
                    </div>
                </div>
            </div>

            <!-- Enviado plataforma -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Enviado plataforma:</label>
                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                    <div class="flex items-center justify-center px-3 py-2 bg-gray-50 border-r border-gray-300">
                        <i class="nc-icon nc-single-02 text-gray-500"></i>
                    </div>
                    <div class="flex-1 px-3 py-2 bg-white text-gray-900 font-medium">
                        <%=novedad.syncro%>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de estructura -->
        <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Estructura:</h4>
            <div class="overflow-x-auto shadow-lg rounded-lg">
                <table class="min-w-full bg-white border border-gray-200">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Nit</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Razon social</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Cedula representante</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Nombre representante</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Apoderado nit</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Apoderado cedula</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Apoderado nombre</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Clave</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <tr>
                            <td class="px-4 py-3 text-sm text-gray-900 font-medium">
                                <%=novedad.nit %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600">
                                <%=novedad.razon_social %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-900">
                                <%=novedad.cedula_representante %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600">
                                <%=novedad.nombre_representante %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-900">
                                <%=novedad.apoderado_nit %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-900">
                                <%=novedad.apoderado_cedula %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600">
                                <%=novedad.apoderado_nombre %>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-900">
                                <%=novedad.clave %>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Botón de acción -->
        <div class="flex justify-center">
            <button type='button' data-cid='<%=novedad.id%>'
                class='bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-lg font-medium transition-colors duration-200 shadow flex items-center gap-2'
                id='bt_procesar'>
                <i class="fa fa-cog"></i>
                Procesar novedad
            </button>
        </div>
    </div>
</div>