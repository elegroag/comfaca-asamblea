<!-- Header con navegación -->
<div class="flex flex-col lg:flex-row justify-between items-center mb-6">
    <div class="lg:w-1/3">
        <h3 class="text-xl font-bold text-blue-600">Novedades</h3>
    </div>
    <div class="lg:w-2/3 lg:flex justify-end">
        <nav class="flex justify-end space-x-2">
            <!-- Espacio para botones de navegación si es necesario -->
        </nav>
    </div>
</div>

<!-- Contenedor de tabla -->
<div class="overflow-x-auto shadow-lg rounded-lg">
    <table class="min-w-full bg-white border border-gray-200" id='tb_data_novedades'>
        <!-- Header de la tabla -->
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    ID
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Línea
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Nit
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Cedrep
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Syncro
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Estado
                </th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                    <i class='nc-icon nc-tap-01'></i>
                </th>
            </tr>
        </thead>

        <!-- Cuerpo de la tabla -->
        <tbody class="bg-white divide-y divide-gray-200" id="show_rows">
            <!-- Las filas se insertarán dinámicamente aquí -->
        </tbody>
    </table>
</div>