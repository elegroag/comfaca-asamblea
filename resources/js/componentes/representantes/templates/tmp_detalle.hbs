<div class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
            <div class="mb-4 md:mb-0">
                <h5 class="text-xl font-bold text-blue-600">Representante Detalle</h5>
            </div>
            <div class="flex justify-end">
                <div id='showSubnav'></div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <div class="p-6">
                <form method="post" action="#" class='space-y-6'>
                    <div class="flex justify-center">
                        <div class="w-full max-w-2xl space-y-4">

                            <div class='form-group'>
                                <label for="cedrep" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Cedula representante
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-user text-gray-600"></i>
                                        </div>
                                    </div>
                                    <div class="flex-1">
                                        <div type="text"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-r-md bg-gray-50"
                                            name="cedrep">
                                            <%=representante.cedrep%>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class='form-group'>
                                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Nombre representante
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-user text-gray-600"></i>
                                        </div>
                                    </div>
                                    <div class="flex-1">
                                        <div class="w-full px-3 py-2 border border-gray-300 rounded-r-md bg-gray-50"
                                            name="nombre">
                                            <%=representante.nombre%>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class='form-group'>
                                <label for="clave" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Clave
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-key text-gray-600"></i>
                                        </div>
                                    </div>
                                    <div class="flex-1">
                                        <input type="text"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-r-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                            name="clave" id='clave' placeholder='clave'
                                            value="<%=representante.clave_ingreso%>" />
                                    </div>
                                </div>
                            </div>

                            <% renderInputNit=0 renderListNits=0 if(representante.cedrep> 0){
                                if(representante.registro_ingresos){
                                renderListNits = 1
                                } else {
                                renderInputNit = 1
                                }
                                } else {
                                renderInputNit = 1
                                }
                                if (renderInputNit == 1) { %>
                                <div class='form-group'>
                                    <label for="usuario" class="block text-sm font-medium text-gray-700 mb-2">
                                        <i class='text-red-500'>*</i> Nit
                                    </label>
                                    <div class="flex">
                                        <div class="flex-shrink-0">
                                            <div
                                                class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                                <i class="fas fa-building text-gray-600"></i>
                                            </div>
                                        </div>
                                        <div class="flex-1">
                                            <input type="text"
                                                class="w-full px-3 py-2 border border-gray-300 rounded-r-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                                name="nit" id='nit' placeholder='nit representa' />
                                        </div>
                                    </div>
                                </div>
                                <% } if (renderListNits==1) { _.each(representante.registro_ingresos, function(row){ %>
                                    <div class="bg-gray-50 rounded-lg p-4 mb-4">
                                        <h6 class="text-lg font-semibold text-gray-800 mb-4">Registro de Ingreso</h6>
                                        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
                                            <table class="w-full text-sm">
                                                <tbody class="divide-y divide-gray-200">
                                                    <tr class="hover:bg-gray-50 transition-colors">
                                                        <td class="px-4 py-3 text-sm font-medium text-gray-700 w-1/3">
                                                            NIT:</td>
                                                        <td class="px-4 py-3 text-sm text-gray-900 font-mono">
                                                            <%=row.nit%>
                                                        </td>
                                                    </tr>
                                                    <tr class="hover:bg-gray-50 transition-colors">
                                                        <td class="px-4 py-3 text-sm font-medium text-gray-700 w-1/3">
                                                            Razón Social:</td>
                                                        <td class="px-4 py-3 text-sm text-gray-900">
                                                            <%=row.razsoc%>
                                                        </td>
                                                    </tr>
                                                    <tr class="hover:bg-gray-50 transition-colors">
                                                        <td class="px-4 py-3 text-sm font-medium text-gray-700 w-1/3">
                                                            Representante cedula:</td>
                                                        <td class="px-4 py-3 text-sm text-gray-900 font-mono">
                                                            <%=row.cedrep%>
                                                        </td>
                                                    </tr>
                                                    <tr class="hover:bg-gray-50 transition-colors">
                                                        <td class="px-4 py-3 text-sm font-medium text-gray-700 w-1/3">
                                                            Representante nombre:</td>
                                                        <td class="px-4 py-3 text-sm text-gray-900">
                                                            <%=row.repleg%>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <% }) } %>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>