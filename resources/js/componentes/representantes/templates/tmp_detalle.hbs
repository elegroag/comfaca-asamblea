<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-info font-weight-bold mb-0">
                <i class="fa fa-user-circle mr-2"></i>
                Detalle de Representante
            </h3>
            <p class="text-muted mb-0">Información completa del representante</p>
        </div>
        <div class="col-md-6">
            <div id="showSubnav"></div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-info-circle mr-2"></i>
                Información del Representante
            </h5>
        </div>
        <div class="card-body">
            <form method="post" action="#" class="form">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Card de Información Principal -->
                        <div class="card border-0 bg-light mb-4">
                            <div class="card-body">
                                <div class="row">
                                    <!-- Columna Izquierda -->
                                    <div class="col-md-6">
                                        <!-- Cédula -->
                                        <div class="form-group mb-3">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-id-card mr-1"></i>
                                                Cédula Representante
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-id-card"></i>
                                                    </span>
                                                </div>
                                                <div class="form-control bg-white">
                                                    <span class="font-weight-bold text-primary">
                                                        <%=representante.cedrep%>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Nombre -->
                                        <div class="form-group mb-3">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-user mr-1"></i>
                                                Nombre Representante
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-user"></i>
                                                    </span>
                                                </div>
                                                <div class="form-control bg-white">
                                                    <span class="font-weight-bold">
                                                        <%=representante.nombre%>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Columna Derecha -->
                                    <div class="col-md-6">
                                        <!-- Clave -->
                                        <div class="form-group mb-3">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-key mr-1"></i>
                                                Clave de Ingreso
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-key"></i>
                                                    </span>
                                                </div>
                                                <input type="password" class="form-control" name="clave" id="clave"
                                                    placeholder="Clave de acceso"
                                                    value="<%=representante.clave_ingreso%>" readonly>
                                            </div>
                                        </div>

                                        <!-- Fecha de Registro -->
                                        <div class="form-group mb-3">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-calendar mr-1"></i>
                                                Fecha de Registro
                                            </label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-calendar"></i>
                                                    </span>
                                                </div>
                                                <div class="form-control bg-white">
                                                    <span class="font-weight-bold">
                                                        <%=representante.create_at%>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sección de NITs -->
                        <% renderInputNit=0 renderListNits=0 if(representante.cedrep> 0){
                            if(representante.registro_ingresos){
                            renderListNits = 1
                            } else {
                            renderInputNit = 1
                            }
                            } else {
                            renderInputNit = 1
                            }
                            if (renderInputNit == 1) { %>
                            <!-- Card de Asignación de NIT -->
                            <div class="card border-0 bg-light mb-4">
                                <div class="card-header bg-light">
                                    <h6 class="card-title mb-0">
                                        <i class="fa fa-building mr-2"></i>
                                        Asignar NIT al Representante
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label for="nit" class="font-weight-bold">
                                            <i class="text-danger">*</i> NIT Empresa
                                        </label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fa fa-building"></i>
                                                </span>
                                            </div>
                                            <input type="text" class="form-control" name="nit" id="nit"
                                                placeholder="Número de Identificación Tributaria">
                                        </div>
                                        <small class="text-muted">
                                            <i class="fa fa-info-circle mr-1"></i>
                                            Ingrese el NIT de la empresa que representa
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <% } if (renderListNits==1) { %>
                                <!-- Card de Empresas Asociadas -->
                                <div class="card border-0 bg-light mb-4">
                                    <div class="card-header bg-light">
                                        <h6 class="card-title mb-0">
                                            <i class="fa fa-building mr-2"></i>
                                            Empresas Asociadas
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <% _.each(representante.registro_ingresos, function(row){ %>
                                            <div class="card mb-3">
                                                <div class="card-body">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <div class="form-group mb-2">
                                                                <label class="font-weight-bold text-muted mb-1">
                                                                    <i class="fa fa-building mr-1"></i>
                                                                    NIT
                                                                </label>
                                                                <div class="d-flex align-items-center">
                                                                    <span class="badge badge-primary mr-2">
                                                                        <%=row.nit%>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <div class="form-group mb-2">
                                                                <label class="font-weight-bold text-muted mb-1">
                                                                    <i class="fa fa-industry mr-1"></i>
                                                                    Razón Social
                                                                </label>
                                                                <div class="d-flex align-items-center">
                                                                    <span class="font-weight-bold">
                                                                        <%=row.razsoc%>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="form-group mb-2">
                                                                <label class="font-weight-bold text-muted mb-1">
                                                                    <i class="fa fa-id-card mr-1"></i>
                                                                    Cédula Representante
                                                                </label>
                                                                <div class="d-flex align-items-center">
                                                                    <span class="badge badge-info">
                                                                        <%=row.cedrep%>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <div class="form-group mb-2">
                                                                <label class="font-weight-bold text-muted mb-1">
                                                                    <i class="fa fa-user-tie mr-1"></i>
                                                                    Nombre Representante
                                                                </label>
                                                                <div class="d-flex align-items-center">
                                                                    <span class="font-weight-bold">
                                                                        <%=row.repleg%>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Botones de Acción -->
                                    <div class="text-center mt-4">
                                        <button type="button" class="btn btn-info rounded-pill btn-lg" id="bt_editar">
                                            <i class="fa fa-edit mr-2"></i>
                                            Editar Representante
                                        </button>
                                        <button type="button" class="btn btn-secondary rounded-pill btn-lg ml-2"
                                            id="bt_cancelar">
                                            <i class="fa fa-arrow-left mr-2"></i>
                                            Volver
                                        </button>
                                    </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede editar la información del representante o asignar nuevas empresas.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }

    .form-control:focus {
        border-color: #17a2b8;
        box-shadow: 0 0 0 0.2rem rgba(23, 162, 184, 0.25);
    }
</style>