<div class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
            <div class="mb-4 md:mb-0">
                <h5 class="text-xl font-bold text-blue-600">
                    <%=title%>
                </h5>
            </div>
            <div class="flex justify-end">
                <div id='showSubnav'></div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <div class="p-6">
                <form method="post" action="#" class='space-y-6'>
                    <div class="flex justify-center">
                        <div class="w-full max-w-2xl space-y-4">

                            <div class='form-group'>
                                <label for="cedrep" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Cedula representante
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-user text-gray-600"></i>
                                        </div>
                                    </div>
                                    <% disable=(!isNew)? 'disabled' :'' %>
                                        <input type="text"
                                            class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 <%=disable%>"
                                            name="cedrep" id='cedrep' placeholder='cedrep'
                                            value="<%=representante.cedrep%>" <%=disable%> />
                                </div>
                            </div>

                            <div class='form-group'>
                                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Nombre representante
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-user text-gray-600"></i>
                                        </div>
                                    </div>
                                    <input type="text"
                                        class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        name="nombre" id='nombre' placeholder='nombre'
                                        value="<%=representante.nombre%>" />
                                </div>
                            </div>

                            <div class='form-group'>
                                <label for="clave" class="block text-sm font-medium text-gray-700 mb-2">
                                    <i class='text-red-500'>*</i> Clave
                                </label>
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <div
                                            class="flex items-center justify-center w-10 h-10 bg-gray-200 border border-r-0 rounded-l-md">
                                            <i class="fas fa-key text-gray-600"></i>
                                        </div>
                                    </div>
                                    <input type="text"
                                        class="flex-1 px-3 py-2 border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        name="clave" id='clave' placeholder='clave'
                                        value="<%=representante.clave_ingreso%>" />
                                </div>
                            </div>

                            <% check=(representante.acepta_politicas)? 'checked' :'' %>
                                <div class="space-y-4">
                                    <label class="block text-sm font-medium text-gray-700">Opciones disponibles</label>
                                    <div class="space-y-3">
                                        <label class="flex items-center space-x-3 cursor-pointer">
                                            <input type="checkbox"
                                                class="w-4 h-4 text-blue-600 focus:ring-blue-500 rounded border-gray-300"
                                                name='acepta_politicas' value="1" <%=check%>>
                                            <span class="text-sm text-gray-700">Acepta politicas</span>
                                        </label>

                                        <label class="flex items-center space-x-3 cursor-pointer">
                                            <input type="checkbox"
                                                class="w-4 h-4 text-blue-600 focus:ring-blue-500 rounded border-gray-300"
                                                name='tiene_soportes' value="1">
                                            <span class="text-sm text-gray-700">Presenta soportes</span>
                                        </label>
                                    </div>
                                </div>
                        </div>
                    </div>

                    <div class='mt-8'>
                        <div class='text-center'>
                            <% disable=(isNew)? 'disabled' :'' %>
                                <button type='button'
                                    class='px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 focus:ring-4 focus:ring-green-300 transition-all duration-200 transform hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100'
                                    id='bt_guardar' <%=disable%>>
                                    <i class="fas fa-play mr-2"></i>
                                    Continuar
                                </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>