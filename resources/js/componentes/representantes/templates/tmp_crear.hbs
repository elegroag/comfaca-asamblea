<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-success font-weight-bold mb-0">
                <i class="fa fa-plus-circle mr-2"></i>
                <%=title%>
            </h3>
            <p class="text-muted mb-0">Gestión de representantes del sistema</p>
        </div>
        <div class="col-md-6">
            <div id="showSubnav"></div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-user-plus mr-2"></i>
                <% if(isNew){ %>
                    Crear Nuevo Representante
                    <% }else{ %>
                        Editar Representante
                        <% } %>
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Complete los datos para <% if(isNew){ %>crear un nuevo<% }else{ %>editar el<% } %>
                                        representante.
                                        Los campos marcados con * son obligatorios.
                        </p>
                    </div>
                </div>
            </div>

            <form method="post" action="#" class="form" id="formulario_representante">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo Cédula -->
                        <div class="form-group">
                            <label for="cedrep" class="font-weight-bold">
                                <i class="text-danger">*</i> Cédula Representante
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-id-card"></i>
                                    </span>
                                </div>
                                <% disable=(!isNew)? 'disabled' :'' %>
                                    <input type="text" class="form-control" name="cedrep" id="cedrep"
                                        placeholder="Número de cédula" value="<%=representante.cedrep%>" <%=disable%>
                                    required>
                            </div>
                            <div class="invalid-feedback" id="cedrep-error">
                                La cédula es obligatoria
                            </div>
                        </div>

                        <!-- Campo Nombre -->
                        <div class="form-group">
                            <label for="nombre" class="font-weight-bold">
                                <i class="text-danger">*</i> Nombre Representante
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-user"></i>
                                    </span>
                                </div>
                                <input type="text" class="form-control" name="nombre" id="nombre"
                                    placeholder="Nombre completo del representante" value="<%=representante.nombre%>"
                                    required>
                            </div>
                            <div class="invalid-feedback" id="nombre-error">
                                El nombre es obligatorio
                            </div>
                        </div>

                        <!-- Campo Clave -->
                        <div class="form-group">
                            <label for="clave" class="font-weight-bold">
                                <i class="text-danger">*</i> Clave de Ingreso
                            </label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="fa fa-key"></i>
                                    </span>
                                </div>
                                <input type="password" class="form-control" name="clave" id="clave"
                                    placeholder="Clave de acceso" value="<%=representante.clave_ingreso%>" required>
                            </div>
                            <div class="invalid-feedback" id="clave-error">
                                La clave es obligatoria
                            </div>
                        </div>

                        <!-- Campo Opciones -->
                        <div class="form-group mt-4">
                            <label class="font-weight-bold mb-2">
                                <i class="fa fa-cogs mr-1"></i>
                                Opciones Disponibles
                            </label>
                            <div class="card border-0 bg-light">
                                <div class="card-body">
                                    <% check=(representante.acepta_politicas)? 'checked' :'' %>
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" name="acepta_politicas"
                                                value="1" <%=check%>>
                                            <label class="form-check-label" for="acepta_politicas">
                                                <i class="fa fa-check-square mr-2"></i>
                                                Acepta políticas
                                            </label>
                                        </div>

                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="tiene_soportes"
                                                value="1">
                                            <label class="form-check-label" for="tiene_soportes">
                                                <i class="fa fa-file mr-2"></i>
                                                Presenta soportes
                                            </label>
                                        </div>

                                        <small class="text-muted mt-2 d-block">
                                            <i class="fa fa-info-circle mr-1"></i>
                                            Marque las opciones aplicables para este representante
                                        </small>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="text-center mt-4">
                            <% disable=(isNew)? 'disabled' :'' %>
                                <button type="button" class="btn btn-success rounded-pill" id="bt_guardar" <%=disable%>>
                                    <i class="fa fa-save mr-2"></i>
                                    <% if(isNew){ %>Crear Representante<% }else{ %>Actualizar Representante<% } %>
                                </button>
                                <button type="button" class="btn btn-secondary rounded-pill ml-2" id="bt_cancelar">
                                    <i class="fa fa-times mr-2"></i>
                                    Cancelar
                                </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Los datos serán validados antes de <% if(isNew){ %>crear<% }else{ %>actualizar<% } %> el
                                    representante.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }

    .form-check-input:checked {
        background-color: #28a745;
        border-color: #28a745;
    }

    .form-check-input:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }
</style>