<div class="sidebar-header">
    <div class="user-info">
        <div class="user-avatar">
            <img src="https://ui-avatars.com/api/?name=<%= user.name %>&background=4F46E5&color=fff&size=40"
                alt="<%= user.name %>" />
        </div>
        <div class="user-details">
            <div class="user-name">
                <%= user.name %>
            </div>
            <div class="user-email">
                <%= user.email %>
            </div>
        </div>
    </div>
</div>

<nav class="sidebar-wrapper">
    <ul class="menu-list">
        <% if (menu && menu.length> 0) { %>
            <% _.each(menu, function(item) { %>
                <li class="menu-item <%= item.sidebar.sidebar_id ? 'submenu-item' : '' %> <%= item.sidebar.estado !== 'activo' ? 'disabled' : '' %>"
                    data-menu-id="<%= item.id %>" data-resource="<%= item.sidebar.resource_router %>">
                    <a href="<%= item.sidebar.resource_router ? '/' + item.sidebar.resource_router : '#' %>"
                        class="menu-link <%= item.hasChildren ? 'has-children' : '' %>" <%=item.sidebar.estado
                        !=='activo' ? 'onclick="return false;"' : '' %>>
                        <i class="<%= item.sidebar.icon %> menu-icon"></i>
                        <span class="menu-text">
                            <%= item.sidebar.label %>
                        </span>
                        <% if (item.hasChildren) { %>
                            <i class="nc-icon nc-minimal-down menu-arrow"></i>
                            <% } %>
                    </a>
                    <% if (item.hasChildren && item.children && item.children.length> 0) { %>
                        <ul class="submenu">
                            <% _.each(item.children, function(child) { %>
                                <li class="menu-item submenu-item <%= child.sidebar.estado !== 'activo' ? 'disabled' : '' %>"
                                    data-menu-id="<%= child.id %>" data-resource="<%= child.sidebar.resource_router %>">
                                    <a href="<%= child.sidebar.resource_router ? '/' + child.sidebar.resource_router : '#' %>"
                                        class="menu-link" <%=child.sidebar.estado !=='activo'
                                        ? 'onclick="return false;"' : '' %>>
                                        <i class="<%= child.sidebar.icon %> menu-icon"></i>
                                        <span class="menu-text">
                                            <%= child.sidebar.label %>
                                        </span>
                                    </a>
                                </li>
                                <% }); %>
                        </ul>
                        <% } %>
                </li>
                <% }); %>
                    <% } else { %>
                        <li class="menu-empty">No hay menús disponibles</li>
                        <% } %>
    </ul>
</nav>

<div class="sidebar-footer">
    <button class="logout-btn" id="bt_logout">
        <i class="nc-icon nc-button-power"></i>
        <span>Cerrar Sesión</span>
    </button>
</div>

<style>
    .sidebar-container {
        height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1000;
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    }

    /* Bootstrap v4 compatibility */
    .sidebar-container .d-flex {
        display: flex !important;
    }

    .sidebar-container .flex-column {
        flex-direction: column !important;
    }

    .sidebar-container .flex-grow-1 {
        flex-grow: 1 !important;
    }

    .sidebar-container .align-items-center {
        align-items: center !important;
    }

    .sidebar-container .justify-content-center {
        justify-content: center !important;
    }

    .sidebar-header {
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .user-info {
        display: flex;
        align-items: center;
    }

    .user-info.d-flex {
        display: flex !important;
    }

    .user-info.align-items-center {
        align-items: center !important;
    }

    .user-avatar img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .user-details {
        flex: 1;
        margin-left: 12px;
    }

    .user-details.flex-grow-1 {
        flex-grow: 1 !important;
    }

    .user-name {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 2px;
    }

    .user-email {
        font-size: 12px;
        opacity: 0.8;
    }

    .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        padding: 10px 0;
        width: 100%;
        box-sizing: border-box;
    }

    .menu-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .menu-item {
        margin-bottom: 2px;
    }

    .menu-link {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        position: relative;
    }

    .menu-link.d-flex {
        display: flex !important;
    }

    .menu-link.align-items-center {
        align-items: center !important;
    }

    .menu-link:hover {
        background: rgba(255, 255, 255, 0.1);
        padding-left: 15px;
        text-decoration: none;
        color: white;
    }

    .menu-link.active {
        background: rgba(255, 255, 255, 0.2);
        border-left: 1px solid white;
    }

    .menu-icon {
        width: 20px;
        margin-right: 12px;
        font-size: 16px;
    }

    .menu-text {
        flex: 1;
        font-size: 14px;
    }

    .menu-arrow {
        font-size: 12px;
        transition: transform 0.3s ease;
    }

    .menu-item.expanded .menu-arrow {
        transform: rotate(180deg);
    }

    .submenu {
        list-style: none;
        margin: 0;
        padding: 0;
        background: rgba(0, 0, 0, 0.1);
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
    }

    .menu-item.expanded .submenu {
        max-height: 500px;
    }

    .submenu-item .menu-link {
        padding: 10px 20px 10px 52px;
        font-size: 13px;
    }

    .submenu-item .menu-link:hover {
        padding-left: 20px;
    }

    .menu-item.disabled .menu-link {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .menu-item.disabled .menu-link:hover {
        background: transparent;
        padding-left: 20px;
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .logout-btn {
        width: 100%;
        padding: 12px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .logout-btn.d-flex {
        display: flex !important;
    }

    .logout-btn.align-items-center {
        align-items: center !important;
    }

    .logout-btn.justify-content-center {
        justify-content: center !important;
    }

    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
        text-decoration: none;
        color: white;
    }

    .menu-empty {
        padding: 20px;
        text-align: center;
        opacity: 0.7;
        font-size: 14px;
    }

    /* Responsive */
    @media (max-width: 768px) {
        #sidebarContainer {
            width: 100%;
            min-width: 100%;
            max-width: 100%;
            height: auto;
            position: relative;
        }

        .sidebar-nav {
            max-height: 300px;
        }

        .user-info {
            flex-direction: column;
            text-align: center;
        }

        .user-info.d-flex {
            flex-direction: column !important;
        }

        .user-details {
            margin-left: 0;
            margin-top: 8px;
        }

        /* Bootstrap v4 responsive fixes */
        .user-info.flex-column {
            flex-direction: column !important;
        }

        .menu-link.d-flex {
            display: flex !important;
        }

        .logout-btn.d-flex {
            display: flex !important;
        }
    }

    /* Large screens - ensure proper width with Bootstrap cols */
    @media (min-width: 992px) {
        #sidebarContainer {
            width: 100% !important;
            max-width: none !important;
        }
    }

    /* Sidebar collapsed state - compatible with Paper Dashboard */
    .sidebar-mini #sidebar {
        width: 80px !important;
        /* Igual que Paper Dashboard */
        min-width: 80px !important;
        max-width: 80px !important;
    }

    .sidebar-mini .user-details,
    .sidebar-mini .menu-text,
    .sidebar-mini .menu-arrow,
    .sidebar-mini .sidebar-footer span {
        display: none !important;
    }

    .sidebar-mini .user-avatar {
        margin: 0 auto;
    }

    .sidebar-mini .menu-link {
        padding: 12px;
        justify-content: center;
        position: relative;
    }

    .sidebar-mini .menu-icon {
        margin: 0;
        font-size: 18px;
    }

    .sidebar-mini .submenu {
        display: none;
    }

    .sidebar-mini .logout-btn {
        padding: 12px;
        justify-content: center;
    }

    .sidebar-mini .logout-btn i {
        margin: 0;
    }

    /* Override Paper Dashboard hover expansion */
    .sidebar-mini #sidebar:hover {
        width: 80px !important;
        /* Prevenir expansión del sidebar */
    }

    .sidebar-mini #sidebar:hover .sidebar-wrapper {
        width: 80px !important;
        /* Prevenir expansión del wrapper */
    }

    /* Hover effects for collapsed sidebar */
    .sidebar-mini .menu-link:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        padding-left: 12px !important;
    }

    .sidebar-mini .menu-item {
        position: relative;
    }

    .sidebar-mini .menu-item:hover .menu-text,
    .sidebar-mini .menu-item:hover .menu-arrow {
        display: none !important;
    }

    /* Main panel adjustment - Paper Dashboard compatible */
    .sidebar-mini .main-panel {
        width: calc(100% - 80px) !important;
    }

    /* Override Paper Dashboard transitions */
    .sidebar,
    .sidebar-wrapper,
    .main-panel {
        transition: all 0.3s ease !important;
    }

    /* Estados del menú */
    .menu-item.active>.menu-link {
        background: rgba(255, 255, 255, 0.15) !important;
        border-left: 1px solid #fff;
    }

    .menu-item.expanded>.submenu {
        display: block !important;
        max-height: 500px;
        opacity: 1;
        transition: all 0.3s ease;
    }

    .menu-item:not(.expanded)>.submenu {
        display: none !important;
        max-height: 0;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .menu-item.submenu-item.active>.menu-link {
        background: rgba(255, 255, 255, 0.1) !important;
        border-left: 2px solid rgba(255, 255, 255, 0.7);
    }

    .menu-link.active {
        background: rgba(255, 255, 255, 0.2) !important;
        color: #fff !important;
        font-weight: 500;
    }

    /* Hover para items activos */
    .menu-item.active:hover>.menu-link {
        background: rgba(255, 255, 255, 0.25) !important;
    }

    /* Estilos para submenús */
    .submenu {
        border-left: 1px solid rgba(255, 255, 255, 0.1);
        margin-left: 5px;
        padding-left: 5px;
    }

    .submenu .menu-link {
        padding: 8px 12px;
        font-size: 13px;
    }

    .submenu .menu-link:hover {
        background: rgba(255, 255, 255, 0.05) !important;
    }
</style>