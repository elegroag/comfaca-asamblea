<!-- Header -->

<div class="px-6 py-4 flex justify-between items-center">
    <div class="flex items-center space-x-4">
        <button id="sidebar-toggle" class="text-gray-500 hover:text-gray-700">
            ☰
        </button>
        <h1 class="text-xl font-semibold text-gray-800">
            <%= props.title || 'Dashboard' %>
        </h1>
    </div>

    <div class="flex items-center space-x-4">
        <div class="relative">
            <button class="text-gray-500 hover:text-gray-700">
                🔔
            </button>
            <span
                class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center">3</span>
        </div>

        <div class="flex items-center space-x-3">
            <div class="text-right">
                <div class="text-sm font-medium text-gray-900">
                    <%= props.auth.user.name %>
                </div>
                <div class="text-xs text-gray-500">
                    <%= props.auth.user.email %>
                </div>
            </div>
            <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white font-medium">
                <%= props.auth.user.name.charAt(0).toUpperCase() %>
            </div>
        </div>

        <button id="logout-btn" class="text-gray-500 hover:text-red-600 transition">
            🚪
        </button>
    </div>
</div>