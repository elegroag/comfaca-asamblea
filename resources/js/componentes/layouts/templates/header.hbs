<!-- Header -->

<div class="d-flex justify-content-between align-items-center px-4 py-3">
    <div class="d-flex align-items-center navbar-wrapper">
        <div class="navbar-minimize">
            <button id="minimizeSidebar" class="btn btn-sm btn-icon btn-round">
                <i class="nc-icon nc-minimal-right text-center visible-on-sidebar-mini"></i>
                <i class="nc-icon nc-minimal-left text-center visible-on-sidebar-regular"></i>
            </button>
        </div>
        <div class="navbar-toggle">
            <button type="button" class="navbar-toggler">
                <span class="navbar-toggler-bar bar1"></span>
                <span class="navbar-toggler-bar bar2"></span>
                <span class="navbar-toggler-bar bar3"></span>
            </button>
        </div>
        <h5 class="h5 mb-0 ml-3 text-dark">
            <%= props.title || 'Dashboard' %>
        </h5>
    </div>

    <div class="d-flex align-items-center">
        <div class="position-relative">
            <button class="btn btn-link text-muted p-0">
                🔔
            </button>
        </div>

        <div class="d-flex align-items-center ml-3">
            <div class="text-right mr-2">
                <div class="font-weight-bold text-dark">
                    <%= props.auth.user.name %>
                </div>
                <div class="small text-muted">
                    <%= props.auth.user.email %>
                </div>
            </div>
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white font-weight-bold"
                style="width: 32px; height: 32px;">
                <%= props.auth.user.name.charAt(0).toUpperCase() %>
            </div>
        </div>

        <button id="logout-btn" class="btn btn-link text-muted p-0 ml-3">
            <i class="nc-icon nc-button-power"></i>
        </button>
    </div>
</div>