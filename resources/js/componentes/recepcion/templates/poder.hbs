<div class='bg-white rounded-lg shadow-lg overflow-hidden'>
    <div class='p-4'>
        <div class='grid grid-cols-1 md:grid-cols-12 gap-4 items-center'>
            <div class="md:col-span-3">
                <div class="flex items-center space-x-3 p-3 bg-gray-100 rounded-lg">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center">
                            <span class="text-white text-xs font-bold">NIT</span>
                        </div>
                    </div>
                    <div class="flex-1">
                        <div class="text-sm font-mono">
                            <%=nit %>
                        </div>
                        <div class="text-xs text-gray-500">NIT</div>
                    </div>
                </div>
                <input type='hidden' name='crear_add_poder' id='crear_add_poder' value='<%=nit %>' />
            </div>
            <div class="md:col-span-6">
                <div class="flex items-center space-x-3 p-3 bg-gray-100 rounded-lg">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center">
                            <span class="text-white text-xs font-bold">RS</span>
                        </div>
                    </div>
                    <div class="flex-1">
                        <div class="text-sm">
                            <%=razsoc %>
                        </div>
                        <div class="text-xs text-gray-500">Razón social</div>
                    </div>
                </div>
            </div>
            <div class="md:col-span-3 flex justify-end">
                <button type='button'
                    class='p-2 bg-red-600 text-white rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-500 transition-colors'
                    id='borrar_poder' title="Eliminar poder">
                    <i class='fas fa-trash text-sm'></i>
                </button>
            </div>
        </div>
    </div>
</div>