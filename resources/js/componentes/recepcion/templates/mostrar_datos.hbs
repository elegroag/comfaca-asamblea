<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-primary font-weight-bold mb-0">
                <i class="fa fa-check-circle mr-2"></i>
                Resultado de Validación Previa
            </h3>
            <p class="text-muted mb-0">Información del representante y empresas asociadas</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="btn_back_list" class="btn btn-outline-primary rounded-pill">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Volver
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-user-check mr-2"></i>
                Validación del Representante
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Columna Izquierda - Datos del Representante -->
                <div class="col-md-6">
                    <!-- Información -->
                    <div class="alert alert-info border-0 bg-light mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-info-circle fa-2x mr-3"></i>
                            <div>
                                <h6 class="alert-heading mb-1">Información</h6>
                                <p class="mb-0">
                                    Aquí podrá encontrar toda la información relacionada con el representante legal y
                                    las empresas que representa.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Datos del Representante -->
                    <div class="card border-0 bg-light">
                        <div class="card-header bg-light">
                            <h6 class="card-title mb-0">
                                <i class="fa fa-user mr-2"></i>
                                Datos del Representante
                            </h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td width="40%">
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-id-card text-primary mr-2"></i>
                                                <strong>Identificación:</strong>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge badge-primary">
                                                <%=representante.cedrep%>
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-user text-info mr-2"></i>
                                                <strong>Representante:</strong>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="font-weight-bold">
                                                <%=capitalize(representante.nombre)%>
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-envelope text-warning mr-2"></i>
                                                <strong>Dirección email:</strong>
                                            </div>
                                        </td>
                                        <td>
                                            <% if(!representante.email){ %>
                                                <span class="text-muted">No disponible</span>
                                                <% }else{ %>
                                                    <span class="badge badge-info">
                                                        <%=capitalize(representante.email)%>
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-phone text-success mr-2"></i>
                                                <strong>Teléfono:</strong>
                                            </div>
                                        </td>
                                        <td>
                                            <% if(!representante.telefono){ %>
                                                <span class="text-muted">No disponible</span>
                                                <% }else{ %>
                                                    <span class="badge badge-success">
                                                        <%=representante.telefono%>
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Columna Derecha - Botón de Registro -->
                <div class="col-md-6">
                    <% if(tiene_incripcion==true){ %>
                        <div class="card border-0 bg-success text-white">
                            <div class="card-body text-center">
                                <h5 class="card-title mb-4">
                                    <i class="fa fa-sign-in-alt mr-2"></i>
                                    Registrar Ingreso
                                </h5>
                                <p class="mb-4">
                                    El representante está habilitado para ingresar a la asamblea.
                                </p>
                                <button type="button" id="bt_ficha_ingreso" class="btn btn-light rounded-pill">
                                    <i class="fa fa-arrow-right mr-2"></i>
                                    Registrar Ingreso Asamblea
                                </button>
                                <div class="mt-4">
                                    <img src="asamblea-logo.jpg" alt="Asamblea Logo" class="img-fluid rounded"
                                        style="max-height: 120px;">
                                </div>
                            </div>
                        </div>
                        <% }else{ %>
                            <div class="card border-0 bg-warning">
                                <div class="card-body text-center">
                                    <h5 class="card-title mb-4">
                                        <i class="fa fa-exclamation-triangle mr-2"></i>
                                        No Habilitado
                                    </h5>
                                    <p class="mb-4">
                                        El representante no está habilitado para ingresar a la asamblea.
                                    </p>
                                    <div class="mt-4">
                                        <img src="asamblea-logo.jpg" alt="Asamblea Logo" class="img-fluid rounded"
                                            style="max-height: 120px;">
                                    </div>
                                </div>
                            </div>
                            <% } %>
                </div>
            </div>

            <!-- Tabla de Empresas -->
            <div class="card border-0 bg-light mt-4">
                <div class="card-header bg-light">
                    <h6 class="card-title mb-0">
                        <i class="fa fa-building mr-2"></i>
                        Empresas Asociadas
                    </h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped" id="renderEmpresasMostrar">
                            <thead class="thead-light">
                                <tr>
                                    <th>
                                        <i class="fa fa-building mr-1"></i>
                                        Empresa
                                    </th>
                                    <th>
                                        <i class="fa fa-hashtag mr-1"></i>
                                        Nit
                                    </th>
                                    <th>
                                        <i class="fa fa-toggle-on mr-1"></i>
                                        Estado
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% _.each(empresas, function(empresa){ %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-building text-info mr-2"></i>
                                                <%=capitalize(empresa.razsoc)%>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-hashtag text-muted mr-2"></i>
                                                <span class="badge badge-secondary">
                                                    <%=empresa.nit%>
                                                </span>
                                            </div>
                                        </td>
                                        <td>
                                            <% if(empresa.inscripcion_estado !='Rechazada' ){ %>
                                                <span class="badge badge-success">
                                                    <i class="fa fa-check-circle mr-1"></i>
                                                    <%=empresa.inscripcion_estado%>
                                                </span>
                                                <% }else{ %>
                                                    <div class="d-flex align-items-center">
                                                        <span class="badge badge-danger mr-2">
                                                            <i class="fa fa-ban mr-1"></i>
                                                            NO APLICA PARA INGRESO
                                                        </span>
                                                        <button type="button" data-toggle="bt_rechazo"
                                                            data-cid="<%=empresa.nit%>"
                                                            data-cedrep="<%=representante.cedrep%>"
                                                            class="btn btn-primary btn-sm rounded-circle"
                                                            title="Ver detalles del rechazo">
                                                            <i class="fa fa-eye"></i>
                                                        </button>
                                                    </div>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tabla de Poderes -->
            <% v_poder=(poderes==false && poder==false) ? 'd-none' : '' %>
                <div class="card border-0 bg-light mt-4 <%=v_poder%>">
                    <div class="card-header bg-light">
                        <h6 class="card-title mb-0">
                            <i class="fa fa-file-signature mr-2"></i>
                            Poderes
                        </h6>
                    </div>
                    <div class="card-body">
                        <!-- Información sobre Poderes -->
                        <div class="alert alert-warning border-0 bg-light mb-4">
                            <div class="d-flex align-items-center">
                                <i class="fa fa-exclamation-triangle fa-2x mr-3"></i>
                                <div>
                                    <h6 class="alert-heading mb-1">Reglamento de Poderes</h6>
                                    <p class="mb-0">
                                        Según Artículo 33 - 5.5.6, el representante solo puede disponer de un poder.
                                        Este poder debe estar registrado y aprobado por parte de las personas de
                                        recepción de poderes.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover table-striped" id="renderPoderMostrar">
                                <thead class="thead-light">
                                    <tr>
                                        <th>
                                            <i class="fa fa-user-times mr-1"></i>
                                            Poderdante
                                        </th>
                                        <th>
                                            <i class="fa fa-hashtag mr-1"></i>
                                            Nit
                                        </th>
                                        <th>
                                            <i class="fa fa-toggle-on mr-1"></i>
                                            Estado
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(poder !=false){ %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fa fa-user-times text-danger mr-2"></i>
                                                    <%=capitalize(poder.razsoc)%>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fa fa-hashtag text-muted mr-2"></i>
                                                    <span class="badge badge-secondary">
                                                        <%=poder.nit%>
                                                    </span>
                                                </div>
                                            </td>
                                            <td>
                                                <% if(poder.inscripcion_estado !='Rechazada' ){ %>
                                                    <span class="badge badge-success">
                                                        <i class="fa fa-check-circle mr-1"></i>
                                                        <%=poder.inscripcion_estado%>
                                                    </span>
                                                    <% }else{ %>
                                                        <div class="d-flex align-items-center">
                                                            <span class="badge badge-danger mr-2">
                                                                <i class="fa fa-ban mr-1"></i>
                                                                NO APLICA PARA INGRESO
                                                            </span>
                                                            <button type="button" data-toggle="bt_rechazo"
                                                                data-cid="<%=poder.nit%>"
                                                                class="btn btn-primary btn-sm rounded-circle"
                                                                title="Ver detalles del rechazo">
                                                                <i class="fa fa-eye"></i>
                                                            </button>
                                                        </div>
                                                        <% } %>
                                            </td>
                                        </tr>
                                        <% } %>
                                            <% if(poderes !=false){ %>
                                                <% _.each(poderes, function(_poder){ %>
                                                    <% if(poder.nit !=_poder.nit){ %>
                                                        <tr>
                                                            <td>
                                                                <div class="d-flex align-items-center">
                                                                    <i class="fa fa-user-times text-danger mr-2"></i>
                                                                    <%=capitalize(_poder.razsoc)%>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <div class="d-flex align-items-center">
                                                                    <i class="fa fa-hashtag text-muted mr-2"></i>
                                                                    <span class="badge badge-secondary">
                                                                        <%=_poder.nit%>
                                                                    </span>
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <% if(_poder.estado !='R' ){ %>
                                                                    <span class="badge badge-success">
                                                                        <i class="fa fa-check-circle mr-1"></i>
                                                                        <%=_poder.inscripcion_estado%>
                                                                    </span>
                                                                    <% }else{ %>
                                                                        <div class="d-flex align-items-center">
                                                                            <span class="badge badge-danger mr-2">
                                                                                <i class="fa fa-ban mr-1"></i>
                                                                                NO APLICA PARA INGRESO
                                                                            </span>
                                                                            <button type="button"
                                                                                data-toggle="bt_rechazo"
                                                                                data-cid="<%=_poder.nit%>"
                                                                                class="btn btn-primary btn-sm rounded-circle"
                                                                                title="Ver detalles del rechazo">
                                                                                <i class="fa fa-eye"></i>
                                                                            </button>
                                                                        </div>
                                                                        <% } %>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                                            <% }) %>
                                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Verifique el estado de las empresas y poderes antes de proceder.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-building mr-1"></i>
                        Total de empresas: <span class="font-weight-bold">
                            <%=empresas.length%>
                        </span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }

    .thead-light th {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        font-weight: 600;
        color: #495057;
    }

    .table-borderless td {
        border: none;
        padding: 0.75rem;
    }

    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
    }

    .btn-primary:hover:not(:disabled) {
        background-color: #0056b3;
        border-color: #004085;
    }

    .img-fluid {
        max-width: 100%;
        height: auto;
    }

    .rounded {
        border-radius: 0.375rem;
    }
</style>