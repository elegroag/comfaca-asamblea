<div class="row">
    <div class="col-md-4">
        <span class="h4 mb-4 text-primary">Ingresos</span>
    </div>
    <div class="col">
        <nav class="nav justify-content-end">
            <a class="nav-link" id='bt_reporte_data' href="#" style='padding:.1rem 1rem'>
                <span class="btn btn-sm btn-icon btn-round btn-danger"><i
                        class="fa fa-file-pdf-o"></i></span>&nbsp;Reporte
            </a>
            <a class="nav-link" id='bt_export_data' href="#" style='padding:.1rem 1rem'>
                <span class="btn btn-sm btn-icon btn-round btn-success"><i
                        class="fa fa-file-excel-o"></i></span>&nbsp;Exportar
            </a>
        </nav>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-striped table-bordered dtr-inline" id='<%=datatable%>'>
        <thead>
            <tr>
                <th>Empresa</th>
                <th>NIT</th>
                <th>Cédula Representante</th>
                <th>Hora</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Votos</th>
                <th><i class='nc-icon nc-tap-01'></i></th>
            </tr>
        </thead>
        <tbody>
            <% _.each(asistencias, function(asistente, ai){ %>
                <tr>
                    <td>
                        <%=asistente.razsoc%>
                    </td>
                    <td>
                        <%=asistente.nit%>
                    </td>
                    <td>
                        <%=asistente.cedrep%>
                    </td>
                    <td>
                        <%=asistente.hora%>
                    </td>
                    <td>
                        <%=asistente.fecha%>
                    </td>
                    <td>
                        <% if(asistente.detalle_estado=='Activo' || asistente.detalle_estado=='Presente' ){ %>
                            <span class="badge badge-success">
                                <%=asistente.detalle_estado%>
                            </span>
                            <% }else if(asistente.detalle_estado=='Inactivo' || asistente.detalle_estado=='Ausente' ){
                                %>
                                <span class="badge badge-danger">
                                    <%=asistente.detalle_estado%>
                                </span>
                                <% }else{ %>
                                    <span class="badge badge-warning">
                                        <%=asistente.detalle_estado%>
                                    </span>
                                    <% } %>
                    </td>
                    <td>
                        <%=asistente.votos%>
                    </td>
                    <td>
                        <div class="btn-group">
                            <button type="button" data-toggle="bt_registro_ingreso" data-code="<%=asistente.documento%>"
                                class="btn btn-sm btn-info" title="Ver detalles">
                                <i class="fa fa-eye"></i>
                            </button>
                            <? if (Session::getData("SuperAdmin") == 1) { ?>
                            <button type="button" data-toggle="bt_borrar_ingreso" data-code="<%=asistente.documento%>"
                                class="btn btn-sm btn-danger" title="Eliminar">
                                <i class="fa fa-trash"></i>
                            </button>
                            <? } ?>
                        </div>
                    </td>
                </tr>
                <% }); %>
        </tbody>
    </table>
</div>



