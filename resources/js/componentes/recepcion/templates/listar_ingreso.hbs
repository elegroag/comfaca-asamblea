<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-primary font-weight-bold mb-0">
                <i class="fa fa-sign-in mr-2"></i>
                <span id="titulo_lista_recepcion">Ingresos Presenciales</span>
            </h3>
            <p class="text-muted mb-0">Gestión de ingresos y asistencia a la asamblea</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="bt_reporte_data" class="btn btn-danger rounded-pill mr-2">
                    <i class="fa fa-file-pdf-o mr-2"></i>
                    Reporte Quorum
                </button>
                <button type="button" id="bt_export_data" class="btn btn-success rounded-pill">
                    <i class="fa fa-file-excel-o mr-2"></i>
                    Exportar
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-list mr-2"></i>
                Lista de Ingresos
            </h5>
        </div>
        <div class="card-body">
            <!-- Tabla de Ingresos -->
            <div class="table-responsive">
                <table class="table table-hover table-striped" id="tb_data_asistencias">
                    <thead class="thead-light">
                        <tr>
                            <th>
                                <i class="fa fa-building mr-1"></i>
                                Empresa
                            </th>
                            <th>
                                <i class="fa fa-hashtag mr-1"></i>
                                Nit
                            </th>
                            <th>
                                <i class="fa fa-id-card mr-1"></i>
                                Cédula Representante
                            </th>
                            <th>
                                <i class="fa fa-clock-o mr-1"></i>
                                Hora
                            </th>
                            <th>
                                <i class="fa fa-calendar mr-1"></i>
                                Fecha
                            </th>
                            <th>
                                <i class="fa fa-toggle-on mr-1"></i>
                                Estado
                            </th>
                            <th>
                                <i class="fa fa-vote-yea mr-1"></i>
                                Votos
                            </th>
                            <th class="text-center">
                                <i class="fa fa-cogs mr-1"></i>
                                Acciones
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% _.each(asistencias, function(asistente, ai){ %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-building text-info mr-2"></i>
                                        <%=capitalize(asistente.razsoc)%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-hashtag text-muted mr-2"></i>
                                        <span class="badge badge-secondary">
                                            <%=asistente.nit%>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-id-card text-primary mr-2"></i>
                                        <span class="font-weight-bold">
                                            <%=asistente.cedrep%>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-clock-o text-warning mr-2"></i>
                                        <%=asistente.hora%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-calendar text-success mr-2"></i>
                                        <%=asistente.fecha%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if(asistente.detalle_estado=='Activo' || asistente.detalle_estado=='Presente'
                                            ){ %>
                                            <span class="badge badge-success">
                                                <i class="fa fa-check-circle mr-1"></i>
                                                <%=asistente.detalle_estado%>
                                            </span>
                                            <% }else if(asistente.detalle_estado=='Inactivo' ||
                                                asistente.detalle_estado=='Ausente' ){ %>
                                                <span class="badge badge-danger">
                                                    <i class="fa fa-times-circle mr-1"></i>
                                                    <%=asistente.detalle_estado%>
                                                </span>
                                                <% }else{ %>
                                                    <span class="badge badge-warning">
                                                        <i class="fa fa-clock-o mr-1"></i>
                                                        <%=asistente.detalle_estado%>
                                                    </span>
                                                    <% } %>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-vote-yea text-info mr-2"></i>
                                        <span class="badge badge-primary">
                                            <%=asistente.votos%>
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <button type="button" data-toggle="bt_registro_ingreso"
                                            data-code="<%=asistente.documento%>"
                                            class="btn btn-info btn-sm rounded-circle" title="Ver detalles del ingreso">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                        <? if (Session::getData("SuperAdmin") == 1) { ?>
                                        <button type="button" data-toggle="bt_borrar_ingreso"
                                            data-code="<%=asistente.documento%>"
                                            class="btn btn-danger btn-sm rounded-circle" title="Eliminar ingreso">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                        <? } ?>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Puede ver los detalles de cada ingreso o generar reportes de quorum.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-users mr-1"></i>
                        Total de ingresos: <span class="font-weight-bold">
                            <%=asistencias.length%>
                        </span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }

    .thead-light th {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        font-weight: 600;
        color: #495057;
    }

    .btn-group .btn {
        margin: 0 2px;
    }

    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
    }

    .btn-primary:hover:not(:disabled) {
        background-color: #0056b3;
        border-color: #004085;
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .btn-danger {
        background-color: #dc3545;
        border-color: #dc3545;
    }

    .btn-danger:hover:not(:disabled) {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .btn-info {
        background-color: #17a2b8;
        border-color: #17a2b8;
    }

    .btn-info:hover:not(:disabled) {
        background-color: #138496;
        border-color: #117a8b;
    }
</style>