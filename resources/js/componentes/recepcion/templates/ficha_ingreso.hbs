<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-info font-weight-bold mb-0">
                <i class="fa fa-file-alt mr-2"></i>Ficha de Registro
            </h3>
            <p class="text-muted mb-0">Información detallada del registro de asistencia</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <% if(votos> 0){ %>
                    <button type="button" id="bt_imprimir_ficha" class="btn btn-primary rounded-pill">
                        <i class="fa fa-print mr-2"></i>
                        Imprimir
                    </button>
                    <% } %>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-user-circle mr-2"></i>
                Datos del Representante
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-muted">
                                    <i class="fa fa-user mr-1"></i>
                                    Nombre Representante
                                </label>
                                <div class="form-control bg-white">
                                    <span class="font-weight-bold">
                                        <%=representante.nombre%>
                                    </span>
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-muted">
                                    <i class="fa fa-id-card mr-1"></i>
                                    Identificación
                                </label>
                                <div class="form-control bg-white">
                                    <span class="badge badge-primary">
                                        <%=representante.cedrep%>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Card de Empresas -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-building mr-2"></i>
                Empresas Asociadas
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="thead-light">
                        <tr>
                            <th>
                                <i class="fa fa-building mr-1"></i>
                                Empresa
                            </th>
                            <th>
                                <i class="fa fa-hashtag mr-1"></i>
                                Nit
                            </th>
                            <th>
                                <i class="fa fa-toggle-on mr-1"></i>
                                Estado
                            </th>
                            <th>
                                <i class="fa fa-file-signature mr-1"></i>
                                Poder
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% _.each(empresas, function(empresa){ %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-building text-info mr-2"></i>
                                        <%=empresa.razsoc%>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-hashtag text-muted mr-2"></i>
                                        <span class="badge badge-secondary">
                                            <%=empresa.nit%>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if(empresa.asistente_estado=='A' ){ %>
                                            <span class="badge badge-success">
                                                <i class="fa fa-check-circle mr-1"></i>
                                                Ya Ingreso
                                            </span>
                                            <% }else if(empresa.asistente_estado=='P' ){ %>
                                                <span class="badge badge-warning">
                                                    <i class="fa fa-clock-o mr-1"></i>
                                                    Pendiente
                                                </span>
                                                <% }else if(empresa.asistente_estado=='C' ){ %>
                                                    <span class="badge badge-danger">
                                                        <i class="fa fa-times-circle mr-1"></i>
                                                        Cancelado
                                                    </span>
                                                    <% }else if(empresa.asistente_estado=='I' ||
                                                        empresa.asistente_estado=='R' || !empresa.asistente_estado){ %>
                                                        <% out=(empresa.tiene_cartera> 0) ? 'Rechazada por cartera,
                                                            empresa en mora' : '' %>
                                                            <% out=(out=='' ) ? ((empresa.esta_poderdante> 0) ?
                                                                'Rechazada, empresa poderdante' : '') : out %>
                                                                <span class="badge badge-danger">
                                                                    <i class="fa fa-ban mr-1"></i>
                                                                    <%= (out=='' ) ? 'Rechazado en Pre-Registro' : out
                                                                        %>
                                                                </span>
                                                                <% } %>
                                    </div>
                                </td>
                                <td>
                                    <% if(poder !==false){ %>
                                        <% if(poder.nit1==empresa.nit){ %>
                                            <span class="badge badge-success">
                                                <i class="fa fa-check mr-1"></i>
                                                Apoderado
                                            </span>
                                            <% } %>
                                                <% }else{ %>
                                                    <span class="badge badge-secondary">
                                                        <i class="fa fa-minus mr-1"></i>
                                                        No disponible
                                                    </span>
                                                    <% } %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <% if(poder !==false){ %>
        <!-- Card de Poder -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-warning text-white">
                <h5 class="card-title mb-0">
                    <i class="fa fa-file-signature mr-2"></i>
                    Información de Poder
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card border-0 bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-center">
                                    <i class="fa fa-user-check mr-2"></i>
                                    Apoderado
                                </h6>
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-id-card mr-1"></i>
                                                Cédula
                                            </label>
                                            <div class="form-control bg-white">
                                                <span class="badge badge-primary">
                                                    <%=poder.cedrep1%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-hashtag mr-1"></i>
                                                NIT
                                            </label>
                                            <div class="form-control bg-white">
                                                <span class="badge badge-secondary">
                                                    <%=poder.nit1%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-center">
                                    <i class="fa fa-user-times mr-2"></i>
                                    Poderdante
                                </h6>
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-id-card mr-1"></i>
                                                Cédula
                                            </label>
                                            <div class="form-control bg-white">
                                                <span class="badge badge-primary">
                                                    <%=poder.cedrep2%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="font-weight-bold text-muted">
                                                <i class="fa fa-hashtag mr-1"></i>
                                                NIT
                                            </label>
                                            <div class="form-control bg-white">
                                                <span class="badge badge-secondary">
                                                    <%=poder.nit2%>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

            <!-- Card de Votos -->
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0">
                        <i class="fa fa-vote-yea mr-2"></i>
                        Información de Votos
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row justify-content-center">
                        <div class="col-md-4">
                            <div class="card border-0 bg-success text-white text-center">
                                <div class="card-body">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <i class="fa fa-box fa-3x mr-3"></i>
                                        <div class="display-4 font-weight-bold">
                                            <%=votos%>
                                        </div>
                                    </div>
                                    <h6 class="mt-3 mb-0">Votos Totales</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .badge {
        font-size: 0.875rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(23, 162, 184, 0.1);
    }

    .thead-light th {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        font-weight: 600;
        color: #495057;
    }

    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
    }

    .btn-primary:hover:not(:disabled) {
        background-color: #0056b3;
        border-color: #004085;
    }

    .display-4 {
        font-size: 3rem;
        font-weight: 300;
        line-height: 1.2;
    }

    .bg-success.text-white .display-4 {
        color: white !important;
    }

    .bg-success.text-white .fa-box {
        color: white !important;
    }
</style>