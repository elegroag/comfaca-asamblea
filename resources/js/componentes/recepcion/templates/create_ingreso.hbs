<div class="container-fluid">
    <!-- Header Principal -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h3 class="text-success font-weight-bold mb-0">
                <i class="fa fa-user-plus mr-2"></i>
                <span id="titulo_lista_recepcion">Crear Asistencia Empresa</span>
            </h3>
            <p class="text-muted mb-0">Registro de asistencia y creación de empresas</p>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end">
                <button type="button" id="btn_back_list" class="btn btn-outline-success rounded-pill">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Volver
                </button>
            </div>
        </div>
    </div>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="card-title mb-0">
                <i class="fa fa-plus-circle mr-2"></i>
                Nuevo Registro de Asistencia
            </h5>
        </div>
        <div class="card-body">
            <!-- Información -->
            <div class="alert alert-info border-0 bg-light mb-4">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-2x mr-3"></i>
                    <div>
                        <h6 class="alert-heading mb-1">Información</h6>
                        <p class="mb-0">
                            Ingrese el NIT de la empresa para registrar la asistencia.
                            Puede crear una nueva empresa si no existe en el sistema.
                        </p>
                    </div>
                </div>
            </div>

            <form method="post" action="#" class="form-horizontal">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <!-- Campo NIT -->
                        <div class="form-group row">
                            <label for="nit" class="col-sm-3 col-form-label font-weight-bold">
                                <i class="text-danger">*</i> NIT
                            </label>
                            <div class="col-sm-9">
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text">
                                            <i class="fa fa-hashtag"></i>
                                        </span>
                                    </div>
                                    <input type="text" class="form-control" name="nit" id="nit"
                                        placeholder="Número de identificación tributaria" required>
                                </div>
                                <div class="invalid-feedback" id="nit-error">
                                    El NIT es obligatorio
                                </div>
                            </div>
                        </div>

                        <!-- Opción de Crear Empresa -->
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label font-weight-bold">
                                Opciones
                            </label>
                            <div class="col-sm-9">
                                <div class="card border-0 bg-light">
                                    <div class="card-body">
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" name="crear_empresa"
                                                id="crear_empresa" value="1">
                                            <label class="custom-control-label" for="crear_empresa">
                                                <i class="fa fa-building mr-2"></i>
                                                Crear empresa para simulacros
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Campos Adicionales (Crear Empresa) -->
                        <div id="sh-crear_empresa" style="display: none;">
                            <!-- Cédula -->
                            <div class="form-group row">
                                <label for="cedrep" class="col-sm-3 col-form-label font-weight-bold">
                                    <i class="text-danger">*</i> Cédula
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-id-card"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="cedrep" id="cedrep"
                                            placeholder="Número de cédula">
                                    </div>
                                    <div class="invalid-feedback" id="cedrep-error">
                                        La cédula es obligatoria
                                    </div>
                                </div>
                            </div>

                            <!-- Nombres -->
                            <div class="form-group row">
                                <label for="nombres" class="col-sm-3 col-form-label font-weight-bold">
                                    <i class="text-danger">*</i> Nombres
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-user"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="nombres" id="nombres"
                                            placeholder="Nombres del representante">
                                    </div>
                                    <div class="invalid-feedback" id="nombres-error">
                                        Los nombres son obligatorios
                                    </div>
                                </div>
                            </div>

                            <!-- Apellidos -->
                            <div class="form-group row">
                                <label for="apellidos" class="col-sm-3 col-form-label font-weight-bold">
                                    <i class="text-danger">*</i> Apellidos
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-user"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="apellidos" id="apellidos"
                                            placeholder="Apellidos del representante">
                                    </div>
                                    <div class="invalid-feedback" id="apellidos-error">
                                        Los apellidos son obligatorios
                                    </div>
                                </div>
                            </div>

                            <!-- Razón Social -->
                            <div class="form-group row">
                                <label for="razsoc" class="col-sm-3 col-form-label font-weight-bold">
                                    <i class="text-danger">*</i> Razón Social
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-building"></i>
                                            </span>
                                        </div>
                                        <input type="text" class="form-control" name="razsoc" id="razsoc"
                                            placeholder="Nombre de la empresa">
                                    </div>
                                    <div class="invalid-feedback" id="razsoc-error">
                                        La razón social es obligatoria
                                    </div>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="form-group row">
                                <label for="email" class="col-sm-3 col-form-label font-weight-bold">
                                    Email
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-envelope"></i>
                                            </span>
                                        </div>
                                        <input type="email" class="form-control" name="email" id="email"
                                            placeholder="correo@ejemplo.com">
                                    </div>
                                    <div class="invalid-feedback" id="email-error">
                                        Ingrese un email válido
                                    </div>
                                </div>
                            </div>

                            <!-- Teléfono -->
                            <div class="form-group row">
                                <label for="telefono" class="col-sm-3 col-form-label font-weight-bold">
                                    Teléfono
                                </label>
                                <div class="col-sm-9">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">
                                                <i class="fa fa-phone"></i>
                                            </span>
                                        </div>
                                        <input type="tel" class="form-control" name="telefono" id="telefono"
                                            placeholder="Número de teléfono">
                                    </div>
                                    <div class="invalid-feedback" id="telefono-error">
                                        Ingrese un teléfono válido
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Opciones Adicionales -->
                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label font-weight-bold">
                                Opciones Adicionales
                            </label>
                            <div class="col-sm-9">
                                <div class="card border-0 bg-light">
                                    <div class="card-body">
                                        <div class="custom-control custom-switch mb-2">
                                            <input type="checkbox" class="custom-control-input" name="omit_estado"
                                                id="omit_estado">
                                            <label class="custom-control-label" for="omit_estado">
                                                <i class="fa fa-toggle-off mr-2"></i>
                                                Omitir estado
                                            </label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" name="is_habil"
                                                id="is_habil" checked>
                                            <label class="custom-control-label" for="is_habil">
                                                <i class="fa fa-check-circle mr-2"></i>
                                                Crear habil
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="form-group row">
                            <div class="col-sm-3"></div>
                            <div class="col-sm-9">
                                <button type="button" id="bt_registrar_inscripcion"
                                    class="btn btn-success rounded-pill">
                                    <i class="fa fa-save mr-2"></i>
                                    Registrar Asistencia
                                </button>
                                <button type="button" id="bt_cancelar" class="btn btn-secondary rounded-pill ml-2">
                                    <i class="fa fa-times mr-2"></i>
                                    Cancelar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-muted">
                        <i class="fa fa-info-circle mr-1"></i>
                        Complete los datos obligatorios para registrar la asistencia.
                    </small>
                </div>
                <div class="col-md-6 text-md-right">
                    <small class="text-muted">
                        <i class="fa fa-clock-o mr-1"></i>
                        Última actualización: <span id="last-update">-</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill {
        border-radius: 50px;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-success:hover:not(:disabled) {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-color: #ced4da;
        color: #495057;
    }

    .custom-control-input:checked~.custom-control-label::before {
        background-color: #28a745;
        border-color: #28a745;
    }

    .custom-control-input:focus~.custom-control-label::before {
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
    }

    .text-danger {
        color: #dc3545 !important;
    }
</style>

<script>
    // Toggle para mostrar/ocultar campos de crear empresa
    document.getElementById('crear_empresa').addEventListener('change', function () {
        const shCrearEmpresa = document.getElementById('sh-crear_empresa');
        if (this.checked) {
            shCrearEmpresa.style.display = 'block';
        } else {
            shCrearEmpresa.style.display = 'none';
        }
    });
</script>