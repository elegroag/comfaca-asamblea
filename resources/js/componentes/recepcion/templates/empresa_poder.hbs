<div class='grid grid-cols-1 md:grid-cols-2 gap-4 mb-4'>
    <div>
        <div class="flex items-center space-x-3 p-3 bg-gray-100 rounded-lg">
            <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center">
                    <span class="text-white text-xs font-bold">NIT</span>
                </div>
            </div>
            <div class="flex-1">
                <div class="text-sm text-gray-500">NIT</div>
                <div class="text-sm font-mono">
                    <%=empresa.nit %>
                </div>
            </div>
        </div>
    </div>
    <div>
        <div class="flex items-center space-x-3 p-3 bg-gray-100 rounded-lg">
            <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center">
                    <span class="text-white text-xs font-bold">RS</span>
                </div>
            </div>
            <div class="flex-1">
                <div class="text-sm text-gray-500">Razón social</div>
                <div class="text-sm">
                    <%=empresa.razsoc %>
                </div>
            </div>
        </div>
    </div>
</div>

<div class='grid grid-cols-1 md:grid-cols-2 gap-4 mb-4'>
    <div>
        <div class="text-sm font-medium text-gray-700 mb-2">Estado empresa</div>
    </div>
    <div>
        <% if(empresa.estado=="A" ){ %>
            <span
                class="inline-flex px-3 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full">Activa</span>
            <% } if(empresa.estado=="I" ){ %>
                <span class="inline-flex px-3 py-1 text-xs font-semibold text-red-800 bg-red-100 rounded-full">No
                    activa</span>
                <% } if(empresa.estado=="D" ){ %>
                    <span
                        class="inline-flex px-3 py-1 text-xs font-semibold text-yellow-800 bg-yellow-100 rounded-full">Desactualizada</span>
                    <% } %>
    </div>
</div>

<% if(has_voto_disponible==-1){ %>
    <div class='bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4'>
        <div class="text-sm font-medium text-yellow-800 mb-2">Reporte:</div>
        <div class="text-sm text-yellow-700">
            <%=msj %>
        </div>
    </div>
    <% }else{ %>
        <div class='flex justify-center mt-4'>
            <button type='button'
                class="px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-all duration-200 transform hover:scale-105 flex items-center space-x-2"
                name='aplicar_poder' id='aplicar_poder'>
                <i class="fas fa-heart"></i>
                <span>Aplicar poder</span>
            </button>
        </div>
        <% } %>