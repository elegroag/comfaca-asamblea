<div class="container-fluid">
	<!-- Card Principal -->
	<div class="card shadow-sm">
		<div class="card-header bg-primary text-white">
			<h5 class="card-title mb-0">
				<i class="fa fa-users mr-2"></i>
				Asamblea Activa
			</h5>
		</div>
		<div class="card-body">
			<div class="row">
				<!-- Columna Izquierda - Info Asamblea -->
				<div class="col-lg-4 col-md-5">
					<div class="card border-0 bg-light">
						<div class="card-body text-center">
							<!-- Logo de Asamblea -->
							<div class="mb-3">
								<img src="/asamblea-logo.png" alt="Logo Asamblea" class="rounded-circle img-fluid"
									style="width: 120px; height: 120px; object-fit: cover;">
							</div>

							<!-- Nombre de Asamblea -->
							<h6 class="card-title font-weight-bold text-primary">
								<%=asamblea.detalle%>
							</h6>

							<!-- Fecha Programada -->
							<div class="text-muted mb-3">
								<i class="fa fa-calendar-alt mr-2"></i>
								<%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
							</div>

							<!-- Botón Listar Asambleas -->
							<button type="button" id="bt_listar_asambleas" class="btn btn-primary btn-sm rounded-pill">
								<i class="fa fa-list mr-2"></i>
								Listar Asambleas
							</button>
						</div>
					</div>
				</div>

				<!-- Columna Derecha - Consensos -->
				<div class="col-lg-8 col-md-7">
					<% if(_.size(consensos)> 0){ %>
						<!-- Header de Consensos -->
						<div class="d-flex justify-content-between align-items-center mb-3">
							<h6 class="font-weight-bold mb-0">
								<i class="fa fa-handshake-o mr-2 text-success"></i>
								Consensos
							</h6>
							<div class="d-flex align-items-center gap-2">
								<span class="badge badge-info">
									<i class="fa fa-layer-group mr-1"></i>
									<%=_.size(consensos)%> consensos
								</span>
								<button type="button" id="bt_nuevo_consenso"
									class="btn btn-success btn-sm rounded-pill">
									<i class="fa fa-plus mr-1"></i>
									Crear Consenso
								</button>
							</div>
						</div>

						<!-- Tabla de Consensos -->
						<div class="table-responsive">
							<table class="table table-hover table-striped">
								<thead class="thead-light">
									<tr>
										<th>
											<i class="fa fa-info-circle mr-1"></i>
											Detalle
										</th>
										<th>
											<i class="fa fa-toggle-on mr-1"></i>
											Estado
										</th>
										<th>
											<i class="fa fa-clock-o mr-1"></i>
											Fecha
										</th>
										<th class="text-center">
											<i class="fa fa-cogs mr-1"></i>
											Acciones
										</th>
									</tr>
								</thead>
								<tbody id="tb_data_consensos">
									<% _.each(consensos, function(consenso){ %>
										<tr>
											<td>
												<div class="d-flex align-items-center">
													<i class="fa fa-file-text-o mr-2 text-muted"></i>
													<%=consenso.detalle%>
												</div>
											</td>
											<td>
												<% if(consenso.estado==='A' ){ %>
													<span class="badge badge-success">
														<i class="fa fa-check-circle mr-1"></i>
														Activo
													</span>
													<% }else{ %>
														<span class="badge badge-secondary">
															<i class="fa fa-pause-circle mr-1"></i>
															Inactivo
														</span>
														<% } %>
											</td>
											<td>
												<div class="d-flex align-items-center">
													<i class="fa fa-calendar mr-2 text-muted"></i>
													<%=moment(consenso.create_at).format('DD-MM-YYYY')%>
												</div>
											</td>
											<td class="text-center">
												<button data-code="<%=consenso.id%>"
													class="btn btn-primary btn-sm rounded-circle" type="button"
													data-toggle="consenso" title="Ver detalles del consenso">
													<i class="fa fa-eye"></i>
												</button>
											</td>
										</tr>
										<% })%>
								</tbody>
							</table>
						</div>

						<% }else{ %>
							<!-- Sin Consensos -->
							<div class="card border-0 bg-light">
								<div class="card-body text-center py-4">
									<div class="mb-3">
										<i class="fa fa-handshake-o fa-3x text-muted"></i>
									</div>
									<h6 class="font-weight-bold text-muted mb-2">
										No hay consensos creados
									</h6>
									<p class="text-muted mb-3">
										El sistema no dispone de consensos creados. Se requiere de crear un consenso
										para la Asamblea actual.
									</p>
									<button type="button" id="bt_nuevo_consenso"
										class="btn btn-success btn-rounded-pill">
										<i class="fa fa-plus mr-2"></i>
										Crear Primer Consenso
									</button>
								</div>
							</div>
							<% } %>
				</div>
			</div>
		</div>
	</div>
</div>