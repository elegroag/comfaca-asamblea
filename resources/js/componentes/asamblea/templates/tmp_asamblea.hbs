<!-- Título principal -->
<h5 class='text-2xl font-bold text-center text-gray-800 mt-4 mb-6'>Asamblea Activa</h5>

<!-- Contenido principal -->
<div class='flex flex-col lg:flex-row gap-6'>
	<!-- Columna izquierda - Información de la asamblea -->
	<div class='lg:w-1/3'>
		<div class="flex flex-col items-center space-y-4">
			<!-- Imagen de la asamblea -->
			<div class="relative">
				<div class="w-32 h-32 rounded-full overflow-hidden border-4 border-gray-200 shadow-lg">
					<?= Tag::image("asamblea-logo.png", "width: 100px", "class: w-full h-full object-cover") ?>
				</div>
			</div>

			<!-- Detalle de la asamblea -->
			<h6 class='text-lg font-semibold text-center text-gray-700'>
				<span class="font-bold">
					<%=asamblea.detalle%>
				</span>
			</h6>

			<!-- Fecha y botón -->
			<div class="text-center space-y-3">
				<p class="text-gray-600 font-medium">
					<%=moment(asamblea.fecha_programada).format('DD-MM-YYYY') %>
				</p>
				<button type='button' id='bt_listar_asambleas'
					class='bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 shadow'>
					Listar Asambleas
				</button>
			</div>
		</div>
	</div>

	<!-- Columna derecha - Consensos -->
	<div class='lg:w-2/3'>
		<% if(_.size(consensos)> 0){%>
			<!-- Header de consensos -->
			<div class='flex justify-between items-center mb-4'>
				<h6 class='text-lg font-semibold text-gray-700'>
					<span class="font-bold">Consensos</span>
				</h6>
				<button type='button' id='bt_nuevo_consenso'
					class='bg-green-500 hover:bg-green-600 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 shadow flex items-center gap-2'>
					<i class='fa fa-plus'></i>
					Crear Consenso
				</button>
			</div>

			<!-- Contador de consensos -->
			<p class="text-gray-600 mb-4">
				Número de consensos:
				<span id='num_consensos' class="font-semibold text-blue-600">
					<%=_.size(consensos)%>
				</span>
			</p>

			<!-- Tabla de consensos -->
			<div class="overflow-x-auto shadow-lg rounded-lg">
				<table class='min-w-full bg-white border border-gray-200'>
					<thead class="bg-gray-50 border-b border-gray-200">
						<tr>
							<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
								Detalle</th>
							<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
								Estado</th>
							<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
								Fecha</th>
							<th
								class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
								Acciones</th>
						</tr>
					</thead>
					<tbody id='tb_data_consensos' class="bg-white divide-y divide-gray-200">
						<% _.each(consensos, function(consenso){ %>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-4 py-3 text-sm text-gray-900">
									<%=consenso.detalle%>
								</td>
								<td class="px-4 py-3 text-sm">
									<span
										class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
                                <% if(consenso.estado === 'A'){ %>bg-green-100 text-green-800<% }else{ %>bg-red-100 text-red-800<% } %>">
										<%=consenso.estado%>
									</span>
								</td>
								<td class="px-4 py-3 text-sm text-gray-600">
									<%=consenso.create_at%>
								</td>
								<td class="px-4 py-3 text-sm text-center">
									<button data-code='<%=consenso.id%>'
										class='bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded text-xs font-medium transition-colors duration-200'
										type='button' data-toggle='consenso'>
										<i class='nc-icon nc-tap-01'></i>
									</button>
								</td>
							</tr>
							<% })%>
					</tbody>
				</table>
			</div>
			<%}else{%>
				<!-- Estado vacío -->
				<div class="text-center py-8">
					<h6 class='text-lg font-semibold text-gray-700 mb-4'>
						<span class="font-bold">Consensos</span>
					</h6>
					<div class="bg-gray-50 rounded-lg p-6 mb-4">
						<p class="text-gray-600 mb-4">
							El sistema no dispone de consensos creados. Se requiere de crear un consenso para la
							Asamblea actual.
						</p>
						<button type='button' id='bt_nuevo_consenso'
							class='bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 shadow flex items-center gap-2 mx-auto'>
							<i class='fa fa-plus'></i>
							Crear Consenso
						</button>
					</div>
				</div>
				<%}%>
	</div>
</div>