<!-- Mensaje informativo -->
<p class="text-center text-gray-600 mb-6">Se requiere de un detalle del consenso para la Asamblea activa.</p>

<!-- Contenedor del formulario -->
<div class='flex justify-center'>
	<div class='w-full max-w-2xl'>
		<!-- Campo de Detalle -->
		<div class='mb-6'>
			<label class='block text-sm font-medium text-gray-700 mb-2 text-right md:text-right'>
				<i class='text-red-500'>*</i> Detalle:
			</label>
			<div toggle-error='detalle' class="error text-red-500 text-sm mb-2" for="required"></div>
			<textarea rows='2'
				class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none transition-colors duration-200"
				id='detalle' name="detalle" placeholder='Detalle...'></textarea>
		</div>

		<!-- Campo de Estado -->
		<div class='mb-6'>
			<label class='block text-sm font-medium text-gray-700 mb-2 text-right md:text-right'>
				<i class='text-red-500'>*</i> Estado:
			</label>
			<div toggle-error='estado' class="error text-red-500 text-sm mb-2" for="required"></div>
			<select
				class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white transition-colors duration-200"
				name="estado">
				<option value=''>Ninguno</option>
				<option value='A'>Activo</option>
				<option value='P'>Pendiente</option>
				<option value='F'>Finalizada</option>
				<option value='X'>Cancelada</option>
			</select>
		</div>

		<!-- Botón de acción -->
		<div class='flex justify-center'>
			<button type='button' id='bt_crear_consenso'
				class='bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-lg font-medium transition-colors duration-200 shadow flex items-center gap-2'>
				<i class='fa fa-save'></i>
				Crear
			</button>
		</div>
	</div>
</div>