<div class="container-fluid">
	<!-- Card Principal -->
	<div class="card shadow-sm">
		<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
			<h5 class="card-title mb-0">
				<i class="fa fa-list-alt mr-2"></i>
				Lista de Asambleas
			</h5>
			<button type="button" id="bt_back" class="btn btn-light btn-sm rounded-pill">
				<i class="fa fa-arrow-left mr-2"></i>
				Volver
			</button>
		</div>
		<div class="card-body">
			<!-- Tabla de Asambleas -->
			<div class="table-responsive">
				<table class="table table-hover table-striped" id="tb_data_usuarios">
					<thead class="thead-light">
						<tr>
							<th>
								<i class="fa fa-info-circle mr-1"></i>
								Detalle
							</th>
							<th>
								<i class="fa fa-calendar-alt mr-1"></i>
								Fecha Programada
							</th>
							<th>
								<i class="fa fa-toggle-on mr-1"></i>
								Estado
							</th>
							<th class="text-center">
								<i class="fa fa-cogs mr-1"></i>
								Acciones
							</th>
						</tr>
					</thead>
					<tbody>
						<% _.each(asambleas, function(asamblea){ %>
							<tr>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-users mr-2 text-muted"></i>
										<%=asamblea.detalle%>
									</div>
								</td>
								<td>
									<div class="d-flex align-items-center">
										<i class="fa fa-calendar mr-2 text-muted"></i>
										<%=moment(asamblea.fecha_programada).format('DD-MM-YYYY')%>
									</div>
								</td>
								<td>
									<% if(asamblea.estado=='A' ){ %>
										<span class="badge badge-success">
											<i class="fa fa-check-circle mr-1"></i>
											Activa
										</span>
										<% }else{ %>
											<span class="badge badge-secondary">
												<i class="fa fa-pause-circle mr-1"></i>
												Inactiva
											</span>
											<% } %>
								</td>
								<td class="text-center">
									<button type="button" data-toggle="mostrar_asamblea" data-code="<%=asamblea.id%>"
										class="btn btn-primary btn-sm rounded-circle"
										title="Ver detalles de la asamblea">
										<i class="fa fa-eye"></i>
									</button>
								</td>
							</tr>
							<% }) %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<style>
	#tb_data_usuarios_wrapper {
		background: #ffffff;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		padding: 12px;
		color: #111827;
	}

	#tb_data_usuarios_wrapper .row {
		margin: 0;
		gap: 10px;
	}

	#tb_data_usuarios_wrapper .dt-length,
	#tb_data_usuarios_wrapper .dt-search {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 0.9rem;
		color: #374151;
	}

	#tb_data_usuarios_wrapper .form-select,
	#tb_data_usuarios_wrapper .form-control {
		border: 1px solid #d1d5db;
		border-radius: 8px;
		min-height: 34px;
		padding: 0.35rem 0.6rem;
		font-size: 0.875rem;
		box-shadow: none;
		background: #fff;
	}

	#tb_data_usuarios_wrapper .form-control:focus {
		border-color: #3b82f6;
		box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button {
		border-radius: 6px;
		margin: 0 2px;
		border: 1px solid #d1d5db;
		background: #fff;
		color: #374151;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button:hover {
		background: #f9fafb;
		border-color: #9ca3af;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button.current {
		background: #3b82f6 !important;
		border-color: #3b82f6 !important;
		color: #fff !important;
	}

	#tb_data_usuarios_wrapper .dataTables_paginate .paginate_button.disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	@media (max-width: 768px) {
		#tb_data_usuarios_wrapper .row {
			flex-direction: column;
		}

		#tb_data_usuarios_wrapper .dt-length,
		#tb_data_usuarios_wrapper .dt-search {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>